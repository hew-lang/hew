//! @name Supervisor
//! @description Supervision tree for fault-tolerant actors

actor Worker {
    let id: i64;

    receive fn work(x: i64) -> i64 {
        print("Worker ");
        print(id);
        print(" processing ");
        println(x);
        x
    }
}

supervisor WorkerPool {
    strategy: one_for_one;
    max_restarts: 5;
    window: 10;

    child w1: Worker(1);
    child w2: Worker(2);
}

fn main() {
    let sup = spawn WorkerPool;
    let w1 = supervisor_child(sup, 0);
    let w2 = supervisor_child(sup, 1);
    await w1.work(10);
    await w2.work(20);
    await w1.work(30);
    supervisor_stop(sup);
}
