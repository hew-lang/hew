fn while_let_probe() -> i64 {
    var current: Option<i64> = Some(3);
    var total: i64 = 0;
    while let Some(value) = current {
        total = total + value;
        if value > 0 {
            current = Some(value - 1);
        } else {
            let finished: Option<i64> = None;
            current = finished;
        }
    }
    total
}

fn while_let_use() -> i64 {
    while_let_probe()
}
