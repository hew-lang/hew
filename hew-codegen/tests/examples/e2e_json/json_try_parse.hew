import std::encoding::json;

fn main() {
    match json.try_parse("{\"name\": \"Hew\"}") {
        Ok(val) => {
            let name = val.get_field("name");
            println(name.get_string());
        },
        Err(err) => match err {
            ParseError::Invalid(message) => println(f"unexpected error: {message}"),
        },
    }

    let manual: json.ParseError = ParseError::Invalid("typed parse error");
    match manual {
        ParseError::Invalid(message) => println(message),
    }

    match json.try_parse("{invalid json}") {
        Ok(_) => println("unexpected ok"),
        Err(err) => match err {
            ParseError::Invalid(message) => println(message),
        },
    }
}
