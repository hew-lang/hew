// LSP smoke fixture for `await conn.read_string() | after duration`.
//
// Exercises the read_string method deadline form (NEW-6c).
// The import is left unresolved in the unit-test registry; the parser
// must accept the form and the LSP must not surface false parse errors.
import std::net;

actor StringReader {
    let port: i32;

    receive fn go() {
        let conn = net.connect(f"127.0.0.1:{port}");
        let _result = match await conn.read_string() | after 60ms {
            Ok(_body) => 42,
            Err(_e) => 7,
        };
    }
}

fn read_string_deadline_probe() -> i32 {
    7
}

fn read_string_deadline_coverage() -> i32 {
    read_string_deadline_probe()
}
