fn scenario_server_monitor_leak(kx: string, scenario: string, expected: i64) {
    var observed_one: bool = false;
    var attempts: i64 = 0;
    loop {
        let count = unsafe {
            hew_dist_monitor_remote_watcher_count()
        };
        if count == 1 {
            observed_one = true;
        } else {
            if count > 1 {
                println(f"FAIL {scenario} target-count={count}");
                return;
            }
        }
        if fs.exists(f"{kx}/leak.done") {
            break;
        }
        attempts = attempts + 1;
        if attempts >= 20000 {
            println(f"FAIL {scenario} client-timeout");
            return;
        }
        sleep(2ms);
    }
    var cleanup_attempts: i64 = 0;
    loop {
        let count = unsafe {
            hew_dist_monitor_remote_watcher_count()
        };
        if count == 0 {
            if !observed_one {
                println(f"FAIL {scenario} target-never-observed-registration");
                return;
            }
            publish_atomic(kx, "leak.verdict", "target=0");
            println(f"PASS {scenario} iterations={expected} target=0 max=1");
            return;
        }
        cleanup_attempts = cleanup_attempts + 1;
        if cleanup_attempts >= 5000 {
            println(f"FAIL {scenario} target-cleanup={count}");
            return;
        }
        sleep(2ms);
    }
}

fn scenario_client_monitor_leak(kv: RemotePid<KeyValue>, kx: string, scenario: string, iterations: i64) -> i64 {
    let probe = spawn MonitorLeakProbe(down_count: 0);
    match await probe.run(kv, iterations) {
        Result::Err(_) => {
            println(f"FAIL {scenario} probe-ask-error");
            2
        },
        Result::Ok(completed) => {
            if completed != iterations {
                println(f"FAIL {scenario} completed={completed}");
                return 3;
            }
            publish_atomic(kx, "leak.done", to_string(iterations));
            let verdict = wait_for_file(f"{kx}/leak.verdict");
            if verdict != "target=0" {
                println(f"FAIL {scenario} target-verdict={verdict}");
                return 4;
            }
            println(f"PASS {scenario} iterations={iterations} closed={completed} down=0 local=0 target=0 ids=distinct");
            0
        },
    }
}

fn scenario_quarantine_rejoin() -> i64 {
    let peer: u16 = 4242;
    let alive: i32 = 0;
    let dead: i32 = 2;
    unsafe {
        hew_dist_inject_swim_gossip(peer, alive, 5)
    };
    unsafe {
        hew_dist_inject_swim_gossip(peer, dead, 5)
    };
    let state_after_verdict = unsafe {
        hew_dist_member_state(peer)
    };
    if state_after_verdict != 2 {
        println("FAIL quarantine_rejoin not-dead-after-verdict");
        return 2;
    }
    let quarantined_after_verdict = unsafe {
        hew_dist_quarantine_contains(peer)
    };
    if quarantined_after_verdict != 1 {
        println("FAIL quarantine_rejoin not-quarantined-after-verdict");
        return 3;
    }
    unsafe {
        hew_dist_inject_swim_gossip(peer, alive, 5)
    };
    unsafe {
        hew_dist_inject_swim_gossip(peer, alive, 4)
    };
    let state_after_stale = unsafe {
        hew_dist_member_state(peer)
    };
    if state_after_stale != 2 {
        println("FAIL quarantine_rejoin resurrected-by-stale");
        return 4;
    }
    let quarantined_after_stale = unsafe {
        hew_dist_quarantine_contains(peer)
    };
    if quarantined_after_stale != 1 {
        println("FAIL quarantine_rejoin quarantine-cleared-by-stale");
        return 5;
    }
    println("PASS quarantine_rejoin stale-rejected");
    unsafe {
        hew_dist_inject_swim_gossip(peer, alive, 6)
    };
    let state_after_rejoin = unsafe {
        hew_dist_member_state(peer)
    };
    if state_after_rejoin != 0 {
        println("FAIL quarantine_rejoin not-readmitted-at-higher");
        return 6;
    }
    let quarantined_after_rejoin = unsafe {
        hew_dist_quarantine_contains(peer)
    };
    if quarantined_after_rejoin != 0 {
        println("FAIL quarantine_rejoin not-evicted-after-readmission");
        return 7;
    }
    println("PASS quarantine_rejoin readmitted-at=6");
    0
}

fn scenario_handshake_reject() -> i64 {
    match lookup_with_retry("kv") {
        Result::Err(_) => {
            println("PASS handshake_reject unroutable");
            0
        },
        Result::Ok(_) => {
            println("FAIL handshake_reject unauthorized-peer-routable");
            2
        },
    }
}

fn scenario_stale_incarnation_restart(old: RemotePid<KeyValue>, kx: string, port: string) -> i64 {
    let old_node = old.node_id();
    let old_incarnation = old.incarnation();
    println(f"READY_STALE_CAPTURED node={old_node} incarnation={old_incarnation}");
    let _ = wait_for_file(f"{kx}/server.restarted");
    Node::connect(f"1@127.0.0.1:{port}");

    var attempts: i64 = 0;
    loop {
        let candidate: Result<RemotePid<KeyValue>, LookupError> = Node::lookup("kv");
        match candidate {
            Result::Ok(fresh) => {
                let fresh_incarnation = fresh.incarnation();
                if fresh.node_id() == old_node && fresh_incarnation > old_incarnation {
                    match fresh.ask(KvReq::GetKey("restart-proof"), 5000) {
                        Result::Err(_) => {
                            println("FAIL stale_incarnation_restart fresh-pid-unusable");
                            return 4;
                        },
                        Result::Ok(KvResp::Ack) => {
                            println("FAIL stale_incarnation_restart fresh-pid-wrong-reply");
                            return 5;
                        },
                        Result::Ok(KvResp::Value(_)) => {},
                    }
                    match old.ask(KvReq::GetKey("restart-proof"), 5000) {
                        Result::Err(AskError::StaleRef) => {
                            println(f"PASS stale_incarnation_restart old={old_incarnation} new={fresh_incarnation} error=StaleRef");
                            return 0;
                        },
                        Result::Err(_) => {
                            println("FAIL stale_incarnation_restart old-pid-wrong-error");
                            return 6;
                        },
                        Result::Ok(_) => {
                            println("FAIL stale_incarnation_restart old-pid-succeeded");
                            return 7;
                        },
                    }
                }
            },
            Result::Err(_) => {},
        }
        attempts = attempts + 1;
        if attempts >= 200 {
            println("FAIL stale_incarnation_restart replacement-not-observed");
            return 3;
        }
        sleep(100ms);
    }
}

fn run_client(port: string, scenario: string) -> i64 {
    let kx = os.env("HEW_DIST_KX_DIR");
    Node::set_transport("tcp");
    stage_peer_credentials(kx, "client", "server", 1);
    Node::start("127.0.0.1:0");
    wait_for_server_listening(kx);
    let remote_addr = f"1@127.0.0.1:{port}";
    Node::connect(remote_addr);
    let status = if scenario == "handshake_reject" {
        scenario_handshake_reject()
    } else if scenario == "quarantine_rejoin" {
        scenario_quarantine_rejoin()
    } else if scenario == "identity_location" {
        let found_identity = lookup_identity_with_retry("identity");
        match found_identity {
            Result::Err(_) => {
                println(f"FAIL {scenario} lookup-unresolved");
                1
            },
            Result::Ok(identity) => {
                scenario_identity_location(identity)
            },
        }
    } else if scenario == "wire_cbor" {
        let found_wire = lookup_wire_with_retry("wire");
        match found_wire {
            Result::Err(_) => {
                println(f"FAIL {scenario} lookup-unresolved");
                1
            },
            Result::Ok(wp) => {
                scenario_wire_cbor(wp)
            },
        }
    } else if scenario == "remote_setup_exit_race" {
        let monitor_found = lookup_with_retry("monitor-race");
        match monitor_found {
            Result::Err(_) => {
                println("FAIL remote_setup_exit_race monitor-lookup-unresolved");
                1
            },
            Result::Ok(monitor_target) => {
                let link_found = lookup_with_retry("link-race");
                match link_found {
                    Result::Err(_) => {
                        println("FAIL remote_setup_exit_race link-lookup-unresolved");
                        1
                    },
                    Result::Ok(link_target) => {
                        scenario_remote_setup_exit_race(monitor_target, link_target)
                    },
                }
            },
        }
    } else {
        let found = lookup_with_retry("kv");
        match found {
            Result::Err(_) => {
                println(f"FAIL {scenario} lookup-unresolved");
                1
            },
            Result::Ok(kv) => {
                if scenario == "stale_incarnation_restart" {
                    scenario_stale_incarnation_restart(kv, kx, port)
                } else if scenario == "remote_ask" {
                    scenario_remote_ask(kv)
                } else {
                    if scenario == "remote_monitor_clean_exit" {
                        scenario_remote_monitor_clean_exit(kv)
                    } else {
                        if scenario == "remote_monitor_crash" {
                            scenario_remote_monitor_crash(kv)
                        } else {
                            if scenario == "remote_monitor_conn_drop" {
                                scenario_remote_monitor_conn_drop(kv)
                            } else {
                                if scenario == "remote_monitor_setup_after_drop" {
                                    scenario_remote_monitor_setup_after_drop(kv)
                                } else {
                                    if scenario == "partition_ask" {
                                        scenario_partition_ask(kv)
                                    } else {
                                        if scenario == "repoint_preserves_ref" {
                                            scenario_repoint_preserves_ref(kv)
                                        } else {
                                            if scenario == "monitor_watcher_node_death" {
                                                scenario_client_watcher_node_death(kv)
                                            } else {
                                                if scenario == "link_remote_clean_exit" {
                                                    scenario_link_remote_clean_exit(kv)
                                                } else {
                                                    if scenario == "link_remote_crash" {
                                                        scenario_link_remote_crash(kv)
                                                    } else {
                                                        if scenario == "link_remote_partition" {
                                                            scenario_link_remote_partition(kv)
                                                        } else {
                                                            if scenario == "link_remote_non_crashlinked" {
                                                                scenario_link_remote_non_crashlinked(kv)
                                                            } else {
                                                                if scenario == "cross_node_monitor_close_reclaim" {
                                                                    scenario_client_monitor_close_reclaim(kv)
                                                                } else {
                                                                    if scenario == "monitor_leak_low" {
                                                                        scenario_client_monitor_leak(kv, kx, scenario, 3)
                                                                    } else {
                                                                        if scenario == "monitor_leak_high" {
                                                                            scenario_client_monitor_leak(kv, kx, scenario, 50)
                                                                        } else {
                                                                            println(f"FAIL {scenario} unknown-scenario");
                                                                            90
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
        }
    };
    Node::shutdown();
    status
}

fn main() -> i64 {
    let role = os.env("HEW_DIST_ROLE");
    let port = os.env("HEW_DIST_PORT");
    var scenario = os.env("HEW_DIST_SCENARIO");
    if scenario == "" {
        scenario = "remote_ask";
    }
    if role == "server" {
        run_server(port, scenario);
        0
    } else {
        if role == "client" {
            run_client(port, scenario)
        } else {
            println(f"FAIL config unknown-role={role}");
            99
        }
    }
}
