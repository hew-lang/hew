fn gcd(a: i64, b: i64) -> i64 {
    var x = a;
    var y = b;
    while y != 0 {
        let temp = y;
        y = x % temp;
        x = temp;
    }
    x
}

fn lcm(a: i64, b: i64) -> i64 {
    a / gcd(a, b) * b
}

const ITERS: i64 = 5000000;

fn main() {
    var sum = 0;
    for i in 0 .. ITERS {
        sum = sum + lcm(1071, 462);
    }
    println(ITERS);
    println(sum);
}
