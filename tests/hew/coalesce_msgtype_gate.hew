//! Coalesce regression for spec section 6.3: equal keys on different message
//! types must not merge. A wide bounded queue is filled with beta messages,
//! then flooded with alpha messages carrying the same keys. Exact runtime
//! queue-order coverage lives in `hew-runtime`; this compiled fixture proves
//! the generated callback and spawn wiring preserve both message kinds.

import std::testing;

actor KindCoalescer {
    var alpha_count: i64 = 0;
    var beta_count: i64 = 0;
    var alpha_latest: i64 = -1;

    mailbox 64 overflow coalesce(id) fallback drop_new;

    receive fn alpha(id: i64, value: i64) {
        sleep(5ms);
        alpha_count = alpha_count + 1;
        alpha_latest = value;
    }

    receive fn beta(id: i64, value: i64) {
        sleep(5ms);
        beta_count = beta_count + 1;
    }

    receive fn alpha_seen() -> i64 {
        alpha_count
    }

    receive fn beta_seen() -> i64 {
        beta_count
    }

    receive fn latest() -> i64 {
        alpha_latest
    }
}

#[test]
fn coalesce_same_key_different_message_types_do_not_merge() {
    let worker = spawn KindCoalescer(
        alpha_count: 0,
        beta_count: 0,
        alpha_latest: -1,
    );

    for id in 0..64 {
        worker.beta(id, id);
    }
    for id in 0..64 {
        worker.alpha(id, id + 1000);
    }

    sleep(2000ms);
    var alpha_count: i64 = -1;
    var beta_count: i64 = -1;
    match await worker.alpha_seen() {
        Ok(value) => {
            alpha_count = value;
        },
        Err(_) => testing.assert_true(false),
    }
    match await worker.beta_seen() {
        Ok(value) => {
            beta_count = value;
        },
        Err(_) => testing.assert_true(false),
    }
    testing.assert_true(beta_count > alpha_count);
    match await worker.latest() {
        Ok(value) => testing.assert_true(value == -1 || value >= 1000),
        Err(_) => testing.assert_true(false),
    }
}
