// Acceptance fixture: pattern guard matching.
// Guards distinguish arms that share a binding pattern.
// Oracle: "big" for >10, "small" for >0, "non-positive" otherwise.
fn classify(n: i64) -> string {
    match n {
        x if x > 10 => "big",
        x if x > 0 => "small",
        _ => "non-positive",
    }
}

fn main() {
    print(classify(15));
    print("\n");
    print(classify(5));
    print("\n");
    print(classify(0));
    print("\n");
    print(classify(-3));
    print("\n");
}
