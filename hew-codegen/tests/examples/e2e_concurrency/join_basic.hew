// Test: Join expression - waits for all async results
actor Worker {
    let id: int;
    receive fn compute() -> int {
        self.id * 10
    }
}

fn main() {
    let w1 = spawn Worker(id: 1);
    let w2 = spawn Worker(id: 2);
    let w3 = spawn Worker(id: 3);
    let results = join {
        w1.compute(),
        w2.compute(),
        w3.compute(),
    };
    let sum = results.0 + results.1 + results.2;
    println(sum);
    stop(w1);
    stop(w2);
    stop(w3);
}
