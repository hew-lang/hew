actor BytesPopCrasher {
    receive fn boom() {
        let b: bytes = bytes::new();
        let _x: u8 = b.pop();
    }
}

actor BytesPopProbe {
    receive fn ping() -> i64 {
        0
    }
}

fn main() -> i64 {
    let crasher = spawn BytesPopCrasher;
    let probe = spawn BytesPopProbe;
    crasher.boom();
    sleep(300ms);
    match await probe.ping() {
        Ok(v) => v,
        Err(_) => 1,
    }
}

