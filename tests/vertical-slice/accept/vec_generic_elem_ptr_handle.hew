// #1929 Stage 1: the pointer-ABI element of an element-typed Vec method under
// a type parameter. `LocalPid<Counter>` is a Copy pointer-identity handle, so a
// `Vec<T>` `push`/`get` under the type parameter `T` re-resolves to
// `hew_vec_push_ptr` / `hew_vec_get_ptr`. The handle's actor identity must
// survive the round-trip: the retrieved pid bumps and reports the same actor.

actor Counter {
    var n: i64 = 0;
    receive fn bump() { n = n + 1; }
    receive fn report() { println(n); }
}

fn store_and_read<T>(v: Vec<T>, x: T) -> T {
    v.push(x);
    v.get(0)
}

fn main() {
    let c: LocalPid<Counter> = spawn Counter;
    let v: Vec<LocalPid<Counter>> = Vec::new();
    let same = store_and_read(v, c);
    same.bump();
    same.report();
}
