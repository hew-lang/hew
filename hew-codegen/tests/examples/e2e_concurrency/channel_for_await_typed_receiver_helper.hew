import std::channel::channel;

fn consume(rx: channel.Receiver<String>) {
    for await msg in rx {
        println(f"helper: [{msg}]");
    }

    println("helper done");
    rx.close();
}

fn main() {
    let (tx, rx) = channel.new(4);

    tx.send("alpha");
    tx.send("beta");
    tx.close();

    consume(rx);
}
