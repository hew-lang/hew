import std::fs;
import std::os;
import std::net::url;
import std::text::regex;
import std::time::cron;

fn main() -> i64 {
    let re = regex.new("[a-z]+");
    if !re.is_match("abc") {
        return 1;
    }
    re.close();

    let contents = fs.read("tests/vertical-slice/accept/std_panic_wrappers_success.hew");
    if contents.len() == 0 {
        return 2;
    }

    let arg0 = os.args(0);
    if arg0.len() == 0 {
        return 3;
    }

    let parsed = url.parse("https://x.com");
    let host = parsed.host();
    parsed.free();
    if host != "x.com" {
        return 4;
    }

    let expr = cron.parse("* * * * *");
    expr.free();
    0
}
