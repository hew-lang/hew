// Error handling with Result types

fn parse_number(s: String) -> Result<int, String> {
    if s == "42" {
        Ok(42)
    } else {
        Err("Invalid number")
    }
}

fn main() {
    let result = parse_number("42");
    match result {
        Ok(n) => println(n),
        Err(msg) => println(msg),
    }
}
