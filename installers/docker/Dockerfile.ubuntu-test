# syntax=docker/dockerfile:1
# Test image: verifies a Hew release tarball installs and works on Ubuntu 24.04.
#
# Build:
#   # First assemble the tarball (from repo root, after `make release`):
#   ./installers/docker/assemble-test-tarball.sh
#
#   # Then build and run:
#   docker build -f installers/docker/Dockerfile.ubuntu-test \
#     -t hew-ubuntu-test --build-context tarball=dist/test-tarball .
#   docker run --rm hew-ubuntu-test
#
# Or use the helper script which does all of the above:
#   ./installers/docker/run-ubuntu-test.sh
#
# What this tests (full end-to-end):
#   1. Module resolution — HEW_STD env var and FHS path (../share/hew) are used
#      to find stdlib .hew sources; checks std::string, std::fs, std::net::url.
#   2. libhew.a — verifies the combined library is present in /usr/local/lib/
#      (needed for linking Hew programs).
#   3. Full compile + link + run via `hew run` — exercises hew-codegen (MLIR
#      codegen), the C linker, and the Hew runtime.
#
# hew-codegen is built with HEW_STATIC_LINK=ON (the default), so LLVM/MLIR are
# statically linked.  The z3 interface is compiled into LLVMSupport but is never
# invoked by hew-codegen (code generation does not use z3's theorem prover), so
# z3 is filtered from LLVMSupport's interface link libraries at build time —
# leaving no runtime z3 dependency.

FROM ubuntu:24.04

# gcc + libc-dev: hew invokes the system C compiler to link compiled .o files.
# The runtime and stdlib are in libhew.a — no Rust needed at runtime.
RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc libc-dev ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy the pre-assembled release tarball contents from the named build context
# (assembled by assemble-test-tarball.sh). This mirrors the layout that a real
# release tarball extracts to, and that `make install` / deb / rpm / apk all
# install from.
COPY --from=tarball bin/hew           /usr/local/bin/hew
COPY --from=tarball lib/libhew.a      /usr/local/lib/libhew.a
COPY --from=tarball std/              /usr/local/share/hew/std/

# HEW_STD tells hew where the standard library lives.
# With binaries at /usr/local/bin/, hew also searches ../share/hew for std/.
ENV HEW_STD=/usr/local/share/hew/std

WORKDIR /work
COPY installers/docker/test-stdlib.hew /work/test.hew
COPY installers/docker/test-install.sh /work/test-install.sh
RUN chmod +x /work/test-install.sh

CMD ["/bin/bash", "/work/test-install.sh"]
