// Regression for #1699: Vec::set of a struct with owned fields must
// unregister the source identifier's __auto_field_drop entry so the
// struct's fields are not freed when the source variable leaves scope.
// Mirrors the Vec::push gap: nullOutDropSlot is a no-op for __auto_field_drop
// entries; the fix calls unregisterDroppable instead.  Fixes #1699.
type Pair {
    key: String;
    count: int;
}

fn build_pairs() -> Vec<Pair> {
    let v: Vec<Pair> = [];
    let placeholder = Pair { key: "placeholder", count: 0 };
    v.push(placeholder);
    let updated = Pair { key: "hello", count: 42 };
    v.set(0, updated);
    v
}

fn main() {
    let pairs = build_pairs();
    let first = pairs.get(0);
    if pairs.len() == 1 && first.key == "hello" && first.count == 42 {
        print("PASS\n");
    } else {
        print("FAIL\n");
    }
}
