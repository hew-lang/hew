// Regression for #1698: HashMap::insert must transfer ownership of both the
// key and value string identifiers. Previously, neither source identifier's
// drop slot was nulled after HashMapInsertOp, so on inner scope exit the
// runtime freed the string buffers that the map's storage now pointed at,
// leaving the map's slots with dangling pointers.
fn make_map() -> HashMap<string, string> {
    let m: HashMap<string, string> = HashMap::new();
    var i: i32 = 0;
    while i < 2 {
        let k: string = if i == 0 {
            "greeting"
        } else {
            "farewell"
        };
        let v: string = if i == 0 {
            "hello"
        } else {
            "goodbye"
        };
        m.insert(k, v);
        i = i + 1;
    }
    m
}

fn check(m: HashMap<string, string>) -> bool {
    m.contains_key("greeting") && m.contains_key("farewell") && m.len() == 2
}

fn main() {
    let m = make_map();
    if check(m) {
        print("PASS\n");
    } else {
        print("FAIL\n");
    }
}
