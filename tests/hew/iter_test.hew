fn test_take_str_more_than_length_clamps() {
    let v: Vec<String> = Vec::new();
    v.push("x"); v.push("y");
    let result = iter.take_str(v, 99);
    testing.assert_eq(result.len(), 2);
}

#[test]
fn test_take_str_zero_returns_empty() {
    let v: Vec<String> = Vec::new();
    v.push("x");
    let result = iter.take_str(v, 0);
    testing.assert_eq(result.len(), 0);
}

