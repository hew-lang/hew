import std::channel::channel;

fn main() {
    let (tx, rx) = channel.new(8);

    tx.send(10);
    tx.send(20);
    tx.send(30);
    tx.close();

    // Drain all messages and sum them.
    var total: int = 0;
    var done = false;
    while !done {
        match rx.recv() {
            Some(val) => { total = total + val; },
            None => { done = true; },
        }
    }

    println(total);
    rx.close();
}
