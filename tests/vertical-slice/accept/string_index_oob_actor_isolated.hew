actor StringIndexCrasher {
    receive fn boom() {
        let s: string = "abc";
        let _c: char = s[99];
    }
}

actor StringIndexProbe {
    receive fn ping() -> i64 {
        0
    }
}

fn main() -> i64 {
    let crasher = spawn StringIndexCrasher;
    let probe = spawn StringIndexProbe;
    crasher.boom();
    sleep(300ms);
    match await probe.ping() {
        Ok(v) => v,
        Err(_) => 1,
    }
}

