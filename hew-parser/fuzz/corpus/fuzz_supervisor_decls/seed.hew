actor SeedChild {
    receive fn ping(n: i64) -> i64 {
        n
    }
}

supervisor SeedSupervisor {
    strategy: one_for_one;
    intensity: 3 within 60s;
    child worker: SeedChild;
}

fn background_task() {}

fn seed_scope_fork() {
    scope {
        fork child_task = background_task();
    };
}
