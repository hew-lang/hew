// Regression: actor ask with an identifier arg whose type is NOT in the
// deep-copy set (String/Vec/HashMap/Closure) must call unregisterDroppable
// so the sender's scope does NOT fire the user drop after ownership has
// transferred to the receive handler.
//
// Token has a custom impl Drop that prints "drop:<id>".
// Before the fix, the sender retained a DropEntry for `tok`, which caused
// a second drop to appear AFTER "done" when the sender scope exited.
// With the fix, ownership transfers cleanly: the receiver drops `t` at
// handler scope exit, so "drop:7" appears once before the await result is
// printed, and never again after "done".

type Token {
    id: int;
}

impl Drop for Token {
    fn drop(t: Token) {
        println(f"drop:{t.id}");
    }
}

actor Vault {
    receive fn store(t: Token) -> int {
        t.id
    }
}

fn main() {
    let v = spawn Vault;
    let tok = Token { id: 7 };
    let n = await v.store(tok);
    // The receiver-side drop runs before the reply is observed here.
    // If unregisterDroppable did NOT fire, a second "drop:7" would appear
    // after "done", indicating the sender still owned the transferred value.
    println(n);
    println("done");
}
