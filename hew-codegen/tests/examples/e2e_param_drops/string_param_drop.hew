// Callee-side drop of a string parameter: the callee must free the string
// exactly once at scope exit when it is consumed (not returned).
// Caller-side ownership transfer: the caller must not attempt a second drop.

fn consume(s: string) {
    println(s);
    // s is dropped here — callee owns it
}

fn main() -> int {
    let greeting = "hello param drop";
    consume(greeting);
    // greeting was moved into consume — no drop here
    println("done");
    return 0;
}
