type Counter {
    value: int;
}

impl Counter {
    fn increment(c: Counter) -> Counter {
        Counter { value: c.value + 1 }
    }

    fn get(c: Counter) -> int {
        c.value
    }
}

fn main() {
    let c = Counter { value: 0 };
    let c2 = c.increment();
    let c3 = c2.increment();
    println(c3.get());
}
