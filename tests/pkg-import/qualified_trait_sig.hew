// Qualified trait-signature comparison under qualified-by-default.
//
// `hew::closableerr` exports a trait `Closable` whose `close` returns
// `Result<(), CloseError>` (the error type spelled BARE inside the defining
// module) and the `CloseError` type itself. The importer opts only the trait
// into scope (`::{ Closable }`) and leaves the error type qualified-by-default,
// so its `impl Closable for ClosableHandle` spells the return type
// `Result<(), closableerr.CloseError>`.
//
// The trait's recorded return type carries the bare `CloseError`; the impl's
// carries the qualified `closableerr.CloseError`. These name the one type, so
// `check_impl_method_against_trait` must shorten the known-module qualifier
// before the structural signature comparison. Without the shortening it reports
// a false `impl method 'ClosableHandle::close' returns 'Result<(), closableerr.CloseError>'
// but trait 'Closable' requires 'Result<(), CloseError>'` and the impl is
// rejected at type-check time.
//
// The method is invoked through receiver dispatch (`m.close()`) so the proof
// turns only on trait conformance, not on UFCS-call-arity resolution.
//
// Harness verb: hew run
// Expected: conformance passes, `close` returns Ok, the match prints `ok`.
import hew::closableerr::{Closable};

import hew::closableerr;

pub type ClosableHandle {
    id: i64;
}

impl Closable for ClosableHandle {
    fn close(handle: ClosableHandle) -> Result<(), closableerr.CloseError> {
        Ok(())
    }
}

fn main() {
    let m = ClosableHandle { id: 1 };
    match m.close() {
        Ok(_) => println("ok"),
        Err(_) => println("err"),
    }
}
