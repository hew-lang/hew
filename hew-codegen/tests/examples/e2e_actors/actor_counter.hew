// Test: Actor Counter
// Exercises: Named actor with mutable state, multiple message types
actor Counter {
    let value: int;
    receive fn increment(amount: int) {
        value = value + amount;
        println(f"Incremented by {amount}, now {value}");
    }
    receive fn decrement(amount: int) {
        value = value - amount;
        println(f"Decremented by {amount}, now {value}");
    }
    receive fn report() -> int {
        value
    }
}

fn main() {
    println("=== Actor Counter ===");
    let c = spawn Counter(value: 0);
    c.increment(5);
    c.increment(3);
    c.decrement(2);
    c.increment(10);
    c.decrement(1);
    await c.report();
    println("Done");
}
