//! Tests for std::text::template — Go-style text/template rendering.

import std::text::template;

import std::testing;

// ── Literal passthrough ───────────────────────────────────────────────
#[test]
fn literal_text_passthrough_returns_unchanged() {
    let ctx = template.new_ctx();
    let r = template.render("hello world", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "hello world"),
        Err(e) => panic(e),
    }
}

#[test]
fn empty_template_returns_empty_string() {
    let ctx = template.new_ctx();
    let r = template.render("", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, ""),
        Err(e) => panic(e),
    }
}

// ── {{.key}} scalar substitution ─────────────────────────────────────
#[test]
fn dot_key_string_substituted() {
    let ctx = template.new_ctx();
    template.ctx_set_str(ctx, "name", "Alice");
    let r = template.render("Hello {{.name}}!", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "Hello Alice!"),
        Err(e) => panic(e),
    }
}

#[test]
fn dot_key_int_substituted() {
    let ctx = template.new_ctx();
    template.ctx_set_int(ctx, "count", 42);
    let r = template.render("count={{.count}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "count=42"),
        Err(e) => panic(e),
    }
}

#[test]
fn dot_key_bool_true_substituted() {
    let ctx = template.new_ctx();
    template.ctx_set_bool(ctx, "flag", true);
    let r = template.render("flag={{.flag}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "flag=true"),
        Err(e) => panic(e),
    }
}

#[test]
fn dot_key_missing_key_expands_to_empty() {
    let ctx = template.new_ctx();
    let r = template.render("x={{.missing}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "x="),
        Err(e) => panic(e),
    }
}

#[test]
fn multiple_substitutions_in_one_template() {
    let ctx = template.new_ctx();
    template.ctx_set_str(ctx, "a", "foo");
    template.ctx_set_str(ctx, "b", "bar");
    let r = template.render("{{.a}} and {{.b}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "foo and bar"),
        Err(e) => panic(e),
    }
}

// ── {{if}} / {{else}} / {{end}} ───────────────────────────────────────
#[test]
fn if_true_branch_rendered() {
    let ctx = template.new_ctx();
    template.ctx_set_bool(ctx, "ok", true);
    let r = template.render("{{if .ok}}yes{{end}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "yes"),
        Err(e) => panic(e),
    }
}

#[test]
fn if_false_branch_suppressed() {
    let ctx = template.new_ctx();
    template.ctx_set_bool(ctx, "ok", false);
    let r = template.render("{{if .ok}}yes{{end}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, ""),
        Err(e) => panic(e),
    }
}

#[test]
fn if_else_true_branch_rendered() {
    let ctx = template.new_ctx();
    template.ctx_set_str(ctx, "active", "yes");
    let r = template.render("{{if .active}}on{{else}}off{{end}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "on"),
        Err(e) => panic(e),
    }
}

#[test]
fn if_else_false_branch_rendered() {
    let ctx = template.new_ctx();
    template.ctx_set_bool(ctx, "active", false);
    let r = template.render("{{if .active}}on{{else}}off{{end}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "off"),
        Err(e) => panic(e),
    }
}

#[test]
fn if_surrounds_literal_text_correctly() {
    let ctx = template.new_ctx();
    template.ctx_set_str(ctx, "show", "1");
    let r = template.render("A{{if .show}}B{{end}}C", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "ABC"),
        Err(e) => panic(e),
    }
}

// ── {{range}} / {{.}} ─────────────────────────────────────────────────
#[test]
fn range_non_empty_list_iterates_all_elements() {
    let ctx = template.new_ctx();
    let items: Vec<string> = Vec::new();
    items.push("a");
    items.push("b");
    items.push("c");
    template.ctx_set_list(ctx, "xs", items);
    let r = template.render("{{range .xs}}[{{.}}]{{end}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "[a][b][c]"),
        Err(e) => panic(e),
    }
}

#[test]
fn range_empty_list_produces_no_output() {
    let ctx = template.new_ctx();
    let empty: Vec<string> = Vec::new();
    template.ctx_set_list(ctx, "xs", empty);
    let r = template.render("{{range .xs}}X{{end}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, ""),
        Err(e) => panic(e),
    }
}

#[test]
fn range_dot_is_current_element() {
    let ctx = template.new_ctx();
    let items: Vec<string> = Vec::new();
    items.push("hello");
    template.ctx_set_list(ctx, "words", items);
    let r = template.render("{{range .words}}{{.}}{{end}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "hello"),
        Err(e) => panic(e),
    }
}

#[test]
fn range_surrounds_literal_text_correctly() {
    let ctx = template.new_ctx();
    let items: Vec<string> = Vec::new();
    items.push("x");
    template.ctx_set_list(ctx, "xs", items);
    let r = template.render("before{{range .xs}}{{.}}{{end}}after", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "beforexafter"),
        Err(e) => panic(e),
    }
}

// ── Nested directives ─────────────────────────────────────────────────
#[test]
fn nested_substitution_and_literal_in_range() {
    let ctx = template.new_ctx();
    template.ctx_set_str(ctx, "sep", ", ");
    let items: Vec<string> = Vec::new();
    items.push("one");
    items.push("two");
    template.ctx_set_list(ctx, "parts", items);
    // range body contains a literal plus {{.}} — the {{.sep}} lookup is for
    // the outer context scalar, not the range element
    let r = template.render("{{range .parts}}{{.}}{{end}}", ctx);
    match r {
        Ok(s) => testing.assert_eq_str(s, "onetwo"),
        Err(e) => panic(e),
    }
}

// ── Malformed template rejection ──────────────────────────────────────
#[test]
fn malformed_unclosed_brace_returns_error() {
    let ctx = template.new_ctx();
    let r = template.render("{{.name", ctx);
    match r {
        Ok(_) => panic("expected error for unclosed {{"),
        Err(e) => testing.assert_true(e.len() > 0),
    }
}

#[test]
fn malformed_unclosed_if_returns_error() {
    let ctx = template.new_ctx();
    template.ctx_set_str(ctx, "x", "1");
    let r = template.render("{{if .x}}body", ctx);
    match r {
        Ok(_) => panic("expected error for unclosed {{if}}"),
        Err(e) => testing.assert_true(e.len() > 0),
    }
}

#[test]
fn malformed_unclosed_range_returns_error() {
    let ctx = template.new_ctx();
    let items: Vec<string> = Vec::new();
    items.push("a");
    template.ctx_set_list(ctx, "xs", items);
    let r = template.render("{{range .xs}}body", ctx);
    match r {
        Ok(_) => panic("expected error for unclosed {{range}}"),
        Err(e) => testing.assert_true(e.len() > 0),
    }
}

#[test]
fn malformed_dot_outside_range_returns_error() {
    let ctx = template.new_ctx();
    let r = template.render("{{.}}", ctx);
    match r {
        Ok(_) => panic("expected error for {{.}} outside range"),
        Err(e) => testing.assert_true(e.len() > 0),
    }
}

#[test]
fn malformed_unexpected_end_returns_error() {
    let ctx = template.new_ctx();
    let r = template.render("{{end}}", ctx);
    match r {
        Ok(_) => panic("expected error for unexpected {{end}}"),
        Err(e) => testing.assert_true(e.len() > 0),
    }
}
