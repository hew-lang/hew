// Regression for #1699: Vec::push of a struct with owned fields must
// unregister the source identifier's __auto_field_drop entry so the
// struct's fields are not freed when the source variable leaves scope.
// Previously, dropFuncForMLIRType(elemType) without includeStructTypes
// returned empty for struct types, so the nullOutDropSlot guard was
// skipped; nullOutDropSlot itself also early-returns for __auto_field_drop
// entries (MLIRGen.cpp:6951).  The fix calls unregisterDroppable when the
// source binding carries __auto_field_drop.  Fixes #1699.
type Item {
    label: string;
    value: int;
}

fn build_items() -> Vec<Item> {
    let v: Vec<Item> = [];
    var i: i32 = 0;
    while i < 3 {
        let label: string = if i == 0 {
            "alpha"
        } else if i == 1 {
            "beta"
        } else {
            "gamma"
        };
        let item = Item { label: label, value: i as int };
        v.push(item);
        i = i + 1;
    }
    v
}

fn main() {
    let items = build_items();
    let first = items.get(0);
    let second = items.get(1);
    let third = items.get(2);
    if items.len() == 3 && first.label == "alpha" && second.label == "beta" && third.label == "gamma" {
        print("PASS\n");
    } else {
        print("FAIL\n");
    }
}
