//! Tests for std::vec helpers — index_of, first, last, min, max.

import std::vec;
import std::option;
import std::testing;

// ── index_of_i32 ──────────────────────────────────────────────────────────

#[test]
fn test_index_of_i32_found_first() {
    let v: Vec<i32> = Vec::new();
    v.push(10);
    v.push(20);
    v.push(30);
    testing.assert_eq(vec.index_of_i32(v, 10), 0);
}

#[test]
fn test_index_of_i32_found_middle() {
    let v: Vec<i32> = Vec::new();
    v.push(10);
    v.push(20);
    v.push(30);
    testing.assert_eq(vec.index_of_i32(v, 20), 1);
}

#[test]
fn test_index_of_i32_found_last() {
    let v: Vec<i32> = Vec::new();
    v.push(10);
    v.push(20);
    v.push(30);
    testing.assert_eq(vec.index_of_i32(v, 30), 2);
}

#[test]
fn test_index_of_i32_not_found() {
    let v: Vec<i32> = Vec::new();
    v.push(10);
    v.push(20);
    testing.assert_eq(vec.index_of_i32(v, 99), -1);
}

#[test]
fn test_index_of_i32_empty() {
    let v: Vec<i32> = Vec::new();
    testing.assert_eq(vec.index_of_i32(v, 5), -1);
}

#[test]
fn test_index_of_i32_returns_first_occurrence() {
    let v: Vec<i32> = Vec::new();
    v.push(7);
    v.push(7);
    v.push(7);
    testing.assert_eq(vec.index_of_i32(v, 7), 0);
}

// ── index_of_i64 ──────────────────────────────────────────────────────────

#[test]
fn test_index_of_i64_found() {
    let v: Vec<i64> = Vec::new();
    v.push(100);
    v.push(200);
    v.push(300);
    testing.assert_eq(vec.index_of_i64(v, 200), 1);
}

#[test]
fn test_index_of_i64_not_found() {
    let v: Vec<i64> = Vec::new();
    v.push(100);
    testing.assert_eq(vec.index_of_i64(v, 999), -1);
}

#[test]
fn test_index_of_i64_empty() {
    let v: Vec<i64> = Vec::new();
    testing.assert_eq(vec.index_of_i64(v, 0), -1);
}

#[test]
fn test_index_of_i64_returns_first_occurrence() {
    let v: Vec<i64> = Vec::new();
    v.push(9);
    v.push(9);
    v.push(9);
    testing.assert_eq(vec.index_of_i64(v, 9), 0);
}

// ── index_of_f64 ──────────────────────────────────────────────────────────

#[test]
fn test_index_of_f64_found() {
    let v: Vec<f64> = Vec::new();
    v.push(1.5);
    v.push(2.5);
    v.push(3.5);
    testing.assert_eq(vec.index_of_f64(v, 2.5), 1);
}

#[test]
fn test_index_of_f64_not_found() {
    let v: Vec<f64> = Vec::new();
    v.push(1.0);
    v.push(2.0);
    testing.assert_eq(vec.index_of_f64(v, 9.9), -1);
}

#[test]
fn test_index_of_f64_empty() {
    let v: Vec<f64> = Vec::new();
    testing.assert_eq(vec.index_of_f64(v, 0.0), -1);
}

#[test]
fn test_index_of_f64_returns_first_occurrence() {
    let v: Vec<f64> = Vec::new();
    v.push(7.7);
    v.push(7.7);
    v.push(7.7);
    testing.assert_eq(vec.index_of_f64(v, 7.7), 0);
}

// ── index_of_str ──────────────────────────────────────────────────────────

#[test]
fn test_index_of_str_found() {
    let v: Vec<String> = Vec::new();
    v.push("alpha");
    v.push("beta");
    v.push("gamma");
    testing.assert_eq(vec.index_of_str(v, "beta"), 1);
}

#[test]
fn test_index_of_str_not_found() {
    let v: Vec<String> = Vec::new();
    v.push("foo");
    v.push("bar");
    testing.assert_eq(vec.index_of_str(v, "baz"), -1);
}

#[test]
fn test_index_of_str_empty() {
    let v: Vec<String> = Vec::new();
    testing.assert_eq(vec.index_of_str(v, "x"), -1);
}

#[test]
fn test_index_of_str_returns_first_occurrence() {
    let v: Vec<String> = Vec::new();
    v.push("dup");
    v.push("dup");
    v.push("dup");
    testing.assert_eq(vec.index_of_str(v, "dup"), 0);
}

// ── first_i64 ─────────────────────────────────────────────────────────────

#[test]
fn test_first_i64_non_empty() {
    let v: Vec<i64> = Vec::new();
    v.push(1000);
    v.push(2000);
    let result = vec.first_i64(v);
    testing.assert_true(option.is_some_int(result));
    testing.assert_eq(option.unwrap_or_int(result, -1), 1000);
}

#[test]
fn test_first_i64_single_element_returns_some() {
    let v: Vec<i64> = Vec::new();
    v.push(55);
    let result = vec.first_i64(v);
    testing.assert_true(option.is_some_int(result));
    testing.assert_eq(option.unwrap_or_int(result, -1), 55);
}

#[test]
fn test_first_i64_empty_returns_none() {
    let v: Vec<i64> = Vec::new();
    testing.assert_true(option.is_none_int(vec.first_i64(v)));
}

// ── first_f64 ─────────────────────────────────────────────────────────────

#[test]
fn test_first_f64_non_empty() {
    let v: Vec<f64> = Vec::new();
    v.push(3.14);
    v.push(2.71);
    let result = vec.first_f64(v);
    testing.assert_true(option.is_some_f64(result));
    testing.assert_true(option.unwrap_or_f64(result, 0.0) == 3.14);
}

#[test]
fn test_first_f64_single_element_returns_some() {
    let v: Vec<f64> = Vec::new();
    v.push(1.5);
    let result = vec.first_f64(v);
    testing.assert_true(option.is_some_f64(result));
    testing.assert_true(option.unwrap_or_f64(result, 0.0) == 1.5);
}

#[test]
fn test_first_f64_empty_returns_none() {
    let v: Vec<f64> = Vec::new();
    testing.assert_true(option.is_none_f64(vec.first_f64(v)));
}

// ── first_str ─────────────────────────────────────────────────────────────

#[test]
fn test_first_str_non_empty() {
    let v: Vec<String> = Vec::new();
    v.push("hello");
    v.push("world");
    let result = vec.first_str(v);
    testing.assert_true(option.is_some_str(result));
    testing.assert_eq_str(option.unwrap_or_str(result, ""), "hello");
}

#[test]
fn test_first_str_single_element_returns_some() {
    let v: Vec<String> = Vec::new();
    v.push("only");
    let result = vec.first_str(v);
    testing.assert_true(option.is_some_str(result));
    testing.assert_eq_str(option.unwrap_or_str(result, ""), "only");
}

#[test]
fn test_first_str_empty_returns_none() {
    let v: Vec<String> = Vec::new();
    testing.assert_true(option.is_none_str(vec.first_str(v)));
}

