// Negative test: passing a field-accessing if expression to print() where
// the field type implements Display must be rejected.  The if expression
// yields holder.greeting in value position; without field-alias / partial-move
// tracking, Display::fmt would consume the field, then the caller's scope-exit
// drop of holder would drop greeting a second time → double-free.
type Greeting {
    text: string;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> string {
        val.text
    }
}

type Holder {
    greeting: Greeting;
}

fn main() {
    let flag = true;
    let holder = Holder { greeting: Greeting { text: "hello" } };
    print(if flag { holder.greeting } else { holder.greeting });
}
