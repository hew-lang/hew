// Validation: a #[wire] struct round-trips through the CBOR body codec.
// Build a Packet, encode it to bytes, decode the bytes back, and exit with the
// recovered field value (42), so a garbled round-trip changes the exit code.
#[wire]
struct Packet {
    id: i64 @1,
}

fn main() -> i64 {
    let p = Packet { id: 42 };
    let buf = p.encode();
    let back = Packet.decode(buf);
    back.id
}
