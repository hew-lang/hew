//! @name Arithmetic Operators
//! @description Integer arithmetic, comparison, and unary negation

fn main() {
    let a = 17;
    let b = 5;
    println(f"sum: {a + b}");
    println(f"diff: {a - b}");
    println(f"prod: {a * b}");
    println(f"quot: {a / b}");
    println(f"rem: {a % b}");
    println(f"neg: {0 - a}");
    println(f"a < b: {a < b}");
    println(f"a > b: {a > b}");
    println(f"a == b: {a == b}");
    println(f"a != b: {a != b}");
}
