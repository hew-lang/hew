// Regression test: generator receive fn with String param must drop the param
// when the generator body is exhausted (hew_string_drop at body exit).
// Before this fix the String was leaked; with ASan this surfaces as a leak;
// without it the allocation silently escapes.
//
// Yields int (not String) to stay within LLVM-compatible wrapper types.

actor Echo {
    receive gen fn count_up(greeting: String) -> int {
        var i: int = 0;
        while i < 3 {
            yield i;
            i = i + 1;
        }
        // `greeting` is dropped here via hew_string_drop
    }
}

fn main() {
    let e = spawn Echo;
    for await val in e.count_up("hello") {
        println(val);
    }
}
