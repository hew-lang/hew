trait Area {
    fn area(val: Self) -> int;
}

type Circle {
    radius: int;
}

type Rect {
    width: int;
    height: int;
}

impl Area for Circle {
    fn area(circ: Circle) -> int {
        3 * circ.radius * circ.radius
    }
}

impl Area for Rect {
    fn area(rect: Rect) -> int {
        rect.width * rect.height
    }
}

fn main() {
    let c = Circle { radius: 5 };
    let r = Rect { width: 4, height: 6 };
    println(c.area());
    println(r.area());
}
