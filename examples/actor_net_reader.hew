//! Status: aspirational (Hew roadmap: actor/supervisor codegen-rs runtime parity)
//! Description: Actor Net Reader example.

import std::net;

actor ServerReader {
    let conn: Connection;

    receive fn start(unused: i32) {
        let msg = conn.read_string();
        println(msg);
    }
}

fn main() {
    let listener = net.listen(":9001");
    let conn = listener.accept();
    let reader = spawn ServerReader(conn: conn);
    reader.start(0);
}
