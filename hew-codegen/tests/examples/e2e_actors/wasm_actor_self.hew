// Test: Self field mutation across receives
// Exercises: field mutation, multiple fields, print from handler
actor Accumulator {
    let total: int;
    let count: int;

    receive fn add(x: int) {
        total = total + x;
        count = count + 1;
    }

    receive fn report() {
        println(total);
        println(count);
    }
}

fn main() {
    let a = spawn Accumulator(total: 0, count: 0);
    a.add(10);
    a.add(20);
    a.add(30);
    a.report();
}
