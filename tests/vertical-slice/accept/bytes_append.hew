// `bytes.append(other)` extends the receiver with a copy of `other`. Appends
// b=[3,4] onto a=[1,2]; asserts a.len()==4 and the exact concatenated bytes,
// and that the source `other` is unchanged (append copies, never consumes).
fn main() -> i64 {
    let a: bytes = bytes::new();
    a.push(1);
    a.push(2);
    let other: bytes = bytes::new();
    other.push(3);
    other.push(4);
    a.append(other);
    if a.len() != 4 {
        return 91;
    }
    if a[0] != 1 {
        return 92;
    }
    if a[1] != 2 {
        return 93;
    }
    if a[2] != 3 {
        return 94;
    }
    if a[3] != 4 {
        return 95;
    }
    // The source is copied, not consumed -- it still reads its own two bytes.
    if other.len() != 2 {
        return 96;
    }
    if other[0] != 3 {
        return 97;
    }
    if other[1] != 4 {
        return 98;
    }
    0
}
