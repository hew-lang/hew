// Test: Ping Pong (Erlang classic)
// Exercises: Two actors exchanging messages
actor Pinger {
    let count: int;
    receive fn ping(n: int) -> int {
        println(f"Ping {n}");
        count = count + 1;
        count
    }
}

actor Ponger {
    let count: int;
    receive fn pong(n: int) -> int {
        println(f"Pong {n}");
        count = count + 1;
        count
    }
}

fn main() {
    println("=== Ping Pong ===");
    let pinger = spawn Pinger(count: 0);
    let ponger = spawn Ponger(count: 0);
    // Use await for deterministic ordering (no sleeps needed)
    await pinger.ping(1);
    await ponger.pong(1);
    await pinger.ping(2);
    await ponger.pong(2);
    await pinger.ping(3);
    await ponger.pong(3);
    println("Done");
}
