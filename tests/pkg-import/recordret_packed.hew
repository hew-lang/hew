// §0 probe: 16-byte record {i64,i32,i32} — RegisterPair with a packed second
// eightbyte (SysV/AAPCS), Indirect on MSVC. Characterizes whether the bare LLVM
// struct return matches the C ABI's two-register packing.
import hew::recordret;

fn main() {
    let p = recordret.packed();
    println(f"p={p.p} x={p.x} y={p.y}");
}
