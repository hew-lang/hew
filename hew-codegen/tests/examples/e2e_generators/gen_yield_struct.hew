// E2E: generator that yields a plain struct (POD-like, no Drop impl).
// Struct types lower to !llvm.ptr LLVM struct types via the type converter,
// so toLLVMStorageType() is a no-op for them — llvm.store accepts LLVMStructType
// directly and createDefaultValue handles LLVMStructType with llvm.mlir.undef.
// This fixture locks the decision: struct yield compiles and runs correctly.

type Point {
    x: int;
    y: int;
}

gen fn points() -> Point {
    yield Point { x: 1, y: 2 };
    yield Point { x: 10, y: 20 };
}

fn main() {
    for p in points() {
        println(p.x);
        println(p.y);
    }
}
