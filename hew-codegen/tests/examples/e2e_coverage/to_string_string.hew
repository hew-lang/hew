// Tests to_string with a string argument (clone path — returns a fresh owned copy).
// to_string(s: string) → clones s so both the original and the result are valid.
fn main() {
    let s = "hello";
    let t = to_string(s);
    println(t);
    println(to_string("world"));
    // Heap-allocated source: verify source and clone are independent.
    let a = "foo" + "bar";
    let b = to_string(a);
    println(b);
}
