import std::testing;

extern "C" {
    fn hew_bytes_from_str(s: string) -> bytes;
}

type Rec {
    s: string;
}

fn make_nested() -> ((string, i64), bool) {
    (("hi", 7), true)
}

#[test]
fn test_nested_tuple_return_drops_cleanly() {
    let t = make_nested();
    testing.assert_eq_str((t.0).0, "hi");
    testing.assert_eq((t.0).1, 7);
    testing.assert_true(t.1);
}

#[test]
fn test_vec_clone_deep_copies_nested_tuple_fields() {
    let xs: Vec<((string, i64), bool)> = Vec::new();
    xs.push((("a", 1), true));
    xs.push((("b", 2), false));

    let ys = xs.clone();
    xs.set(0, (("zzz", 9), true));

    let first = ys.get(0);
    let second = ys.get(1);
    testing.assert_eq(ys.len(), 2);
    testing.assert_eq_str((first.0).0, "a");
    testing.assert_eq((first.0).1, 1);
    testing.assert_true(first.1);
    testing.assert_eq_str((second.0).0, "b");
    testing.assert_eq((second.0).1, 2);
    testing.assert_true(!second.1);
}

#[test]
fn test_vec_clone_drops_nested_bytes_leaf_cleanly() {
    let xs: Vec<((bytes, i64), bool)> = Vec::new();
    let a: bytes = unsafe { hew_bytes_from_str("ab") };
    let b: bytes = unsafe { hew_bytes_from_str("cd") };
    xs.push(((a, 11), true));
    xs.push(((b, 12), false));

    let ys = xs.clone();
    let first = ys.get(0);
    let second = ys.get(1);
    testing.assert_eq(ys.len(), 2);
    testing.assert_eq_str((first.0).0.to_string(), "ab");
    testing.assert_eq((first.0).1, 11);
    testing.assert_true(first.1);
    testing.assert_eq_str((second.0).0.to_string(), "cd");
    testing.assert_eq((second.0).1, 12);
    testing.assert_true(!second.1);
}

#[test]
fn test_vec_clone_drops_nested_record_leaf_cleanly() {
    let xs: Vec<((Rec, i64), bool)> = Vec::new();
    xs.push(((Rec { s: "hi" }, 21), true));
    xs.push(((Rec { s: "bye" }, 22), false));

    let ys = xs.clone();
    xs.set(0, ((Rec { s: "changed" }, 99), true));

    let first = ys.get(0);
    let second = ys.get(1);
    testing.assert_eq(ys.len(), 2);
    testing.assert_eq_str(((first.0).0).s, "hi");
    testing.assert_eq((first.0).1, 21);
    testing.assert_true(first.1);
    testing.assert_eq_str(((second.0).0).s, "bye");
    testing.assert_eq((second.0).1, 22);
    testing.assert_true(!second.1);
}
