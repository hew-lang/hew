// dist_node.hew — shared two-process distributed E2E node program.
//
// ONE program, two roles, selected at runtime by environment variables. Both
// the server and the client are compiled from this single file so the
// serializable message types (KvReq / KvResp / KvPut) are identical on both
// sides of the wire by construction — there is no second file to drift out of
// sync.
//
// Driven by the Rust harness in hew-cli/tests/distributed_two_process_e2e.rs.
// Configuration is read from the environment so new scenarios can be added by
// the harness without changing the program's command-line shape:
//
//   HEW_DIST_ROLE     "server" | "client"   (required)
//   HEW_DIST_PORT     loopback TCP port the harness pre-allocated  (required)
//   HEW_DIST_SCENARIO scenario name for the client role  (default "remote_ask")
//
// Readiness protocol (deterministic, no fixed sleeps for correctness):
//   - The server prints "READY <port>" on a line of its own AFTER the actor is
//     registered. The harness blocks on that line before launching the client.
//   - The client retries Node::lookup in a bounded poll loop until registry
//     gossip resolves the remote actor (or a deadline elapses), rather than
//     sleeping a fixed interval and hoping gossip arrived.
//
// Output contract (the harness asserts on these, with teeth):
//   - "PASS <scenario> <detail>"  on success
//   - "FAIL <scenario> <detail>"  on any mismatch; main returns non-zero
import std::os;

import std::link_monitor::{ MonitorError };

// Self-stop FFI: the cross-node clean-exit scenario drives the remote actor to
// the Stopped terminal state from within its own handler. `stop(self)` is not a
// working surface yet, so the actor calls the runtime self-stop directly.
//
// hew_node_api_unregister: the stale_ref scenario re-points a registered name to
// a DIFFERENT actor (unregister + re-register), superseding the old serial so a
// captured RemotePid fails closed with StaleRef. `Node::unregister` is not yet a
// Hew surface, so the server calls the runtime api directly.
extern "C" {
    fn hew_actor_self_stop();
    fn hew_actor_self_id() -> i64;
    fn hew_node_api_unregister(name: string) -> i32;
    fn hew_node_api_lookup(name: string) -> i64;
    fn hew_pid_local_node() -> u16;
    fn hew_pid_node(pid: i64) -> u16;
    fn hew_pid_serial(pid: i64) -> u64;
    fn hew_pid_incarnation(pid: i64) -> u32;
}

// `record` is Serializable — required for RemotePid messaging across the wire.
record KvPut {
    key: string,
    val: string
}

enum KvReq {
    Put(KvPut);
    GetKey(string);
    // Cross-node monitor scenarios: fire-and-forget commands that drive the
    // remote actor to a terminal state so a monitoring client observes the
    // cross-node DOWN with the right reason.
    StopSelf;
    CrashSelf;
}

enum KvResp {
    Ack;
    Value(string);
}

// ── #[wire] cross-process body types ─────────────────────────────────────────
//
// The KV types above are plain record/enum: they cross the wire as Serializable
// types and get @N tags by the codec's positional fallback. The types below are
// explicitly #[wire]-annotated with EXPLICIT @N field/variant tags, so they
// exercise the tag-keyed CBOR body the positional path does not — a struct as an
// @N-keyed map, an enum as a unit tag (Ping) or a map-of-one (Move). Both the
// request (WireCmd) and the reply (WireResult) are #[wire] types, so the
// explicit-@N body is proven crossing the wire in BOTH directions.
#[wire]
type WirePoint {
    x: i64 @1,
    y: i64 @2,
}

// Enum variant wire tags are the declaration ordinal (Ping = 0, Move = 1);
// the #[wire] enum surface tags variants positionally. The struct fields above
// carry EXPLICIT @N tags — that is the explicit-tag body this scenario proves.
#[wire]
enum WireCmd {
    Ping;
    Move(WirePoint);
}

// WireResult is the #[wire] struct reply: `tag` is which variant the server saw
// (0 = Ping, 1 = Move); `sum` is x + y for Move, or 0 for Ping.
#[wire]
type WireResult {
    tag: i64 @1,
    sum: i64 @2,
}

actor KeyValue {
    let store: HashMap<string, string>;
    receive fn handle(req: KvReq) -> KvResp {
        match req {
            KvReq::Put(kv) => {
                store.insert(kv.key, kv.val);
                KvResp::Ack
            },
            KvReq::GetKey(k) => {
                match store.get(k) {
                    Some(v) => KvResp::Value(v),
                    None => KvResp::Value(""),
                }
            },
            // Clean exit: the actor stops itself, transitioning to the Stopped
            // terminal state, which the cross-node monitor reports as a DOWN
            // carrying the clean-exit reason.
            KvReq::StopSelf => {
                unsafe {
                    hew_actor_self_stop()
                };
                KvResp::Ack
            },
            // Crash: a deliberate panic transitions the actor to the Crashed
            // terminal state, reported as a DOWN carrying the crash reason.
            KvReq::CrashSelf => {
                panic("crash requested by cross-node monitor scenario");
                KvResp::Ack
            },
        }
    }
    receive fn count() -> i64 {
        store.len()
    }
}

impl ActorMsg for KeyValue {
    type Msg = KvReq;
    type Reply = KvResp;
}

// Actor for the #[wire] cross-process scenario. It receives a #[wire] enum and
// replies with a #[wire] struct, so the explicit-@N tagged body is exercised on
// both the request and the reply leg of a remote ask.
actor WireProbe {
    let calls: i64;
    receive fn handle(cmd: WireCmd) -> WireResult {
        match cmd {
            WireCmd::Ping => WireResult { tag: 0, sum: 0 },
            WireCmd::Move(p) => WireResult { tag: 1, sum: p.x + p.y },
        }
    }
}

impl ActorMsg for WireProbe {
    type Msg = WireCmd;
    type Reply = WireResult;
}

record DistIdentity {
    packed: i64,
    node_id: u16,
    serial: u64,
    incarnation: u32,
}

enum IdentityReq {
    Inspect;
}

enum IdentityResp {
    Value(DistIdentity);
}

actor IdentityProbe {
    receive fn handle(_req: IdentityReq) -> IdentityResp {
        let packed = unsafe {
            hew_actor_self_id()
        };
        let node_id = unsafe {
            hew_pid_local_node()
        };
        let serial = unsafe {
            hew_pid_serial(packed)
        };
        let incarnation = unsafe {
            hew_pid_incarnation(packed)
        };
        IdentityResp::Value(DistIdentity {
            packed: packed,
            node_id: node_id,
            serial: serial,
            incarnation: incarnation,
        })
    }
}

impl ActorMsg for IdentityProbe {
    type Msg = IdentityReq;
    type Reply = IdentityResp;
}

// ── Cross-node link ───────────────────────────────────────────────────────────
//
// The link scenarios prove the OTP "linked processes die together" semantic
// across the node boundary: a LOCAL actor links a REMOTE actor with
// `link_remote(pid, PartitionPolicy::CrashLinked)`, and when the remote actor
// dies (clean exit, crash, or partition) the LOCAL linked actor CRASHES too.
//
// The headline divergence from monitor: a `CrashLinked` link-down lands in the
// local actor's MAILBOX as a SYS_MSG_EXIT and crashes a non-trapping actor — it
// does NOT land in a monitor recv slot (a link that reused the monitor recv-slot
// delivery would fail-OPEN: the linked actor would never crash). The fixture
// proves the crash by LOCALLY monitoring the linker actor from `main`: when the
// cross-node link-down crashes the linker, the local monitor observes a DOWN
// carrying the Crashed reason (5). A non-`CrashLinked` policy must NOT crash the
// linker — that negative case gives the policy discriminator teeth.
//
// `Linker` holds the remote KeyValue pid and a policy selector; on a `link_go`
// ask it establishes the cross-node link from inside its own handler (so the
// implicit `self` subject of `link_remote` is THIS actor — the one that must
// crash on the remote's death). The ask reply is the linker's own actor id, so
// `main` learns the id to poll its terminal state after the remote dies.
//
// `main` then polls `hew_link_probe_terminal_state(linker_id)`: the runtime
// records each actor's terminal reason in a probe-only ledger (gated by
// HEW_LINK_PROBE), so the death survives the actor's free. A `CrashLinked`
// cascade records Crashed (5); a survivor never reaches terminal (sentinel).
extern "C" {
    fn hew_link_probe_terminal_state(actor_id: i64) -> i64;
}

// Test-introspection probes for the SWIM rejoin-admission gate: drive a gossip
// entry into the local cluster, read a peer's membership state, and read whether a
// peer is quarantined. These let the rejoin scenario exercise the admission gate
// deterministically (no failure-detector race).
extern "C" {
    fn hew_dist_inject_swim_gossip(node_id: u16, state: i32, incarnation: u64) -> i64;
    fn hew_dist_member_state(node_id: u16) -> i64;
    fn hew_dist_quarantine_contains(node_id: u16) -> i64;
    // Deterministic partition seam for scenario_partition_ask: fail every pending
    // remote ask CLOSED with Partition through the production reply-table fan-out
    // (the same seam the SWIM-DEAD verdict reaches). Returns the count failed (0
    // when none are pending yet). Not user-callable.
    fn hew_dist_partition_pending_remote_asks() -> i64;
}

// Deterministic partition seam for `scenario_partition_ask`. A fire-and-forget
// injector that, the instant the client's remote ask registers as pending,
// resolves it CLOSED with Partition through the production reply-table fan-out
// (`hew_dist_partition_pending_remote_asks`). This removes the dependence on the
// OS socket-teardown detector and the SWIM failure detector — whose latency is
// unbounded under host load — that otherwise made the typed fail-closed verdict
// race the ask deadline (the historical source of this test's flake).
//
// The harness still kills the server (a real teardown), so the route genuinely
// dies; the injector fixes only WHEN the in-flight ask is failed closed, not
// WHETHER. Teeth preserved: a broken fan-out leaves the ask pending -> it times
// out -> scenario_partition_ask still reports FAIL.
actor PartitionInjector {
    receive fn arm() {

        // Poll until a remote ask is pending, then fail it closed via the
        // production fan-out. Bounded (~30s, under the harness 40s cap) so a true
        // deadlock surfaces as a timeout rather than an infinite spin; on give-up
        // the ask falls back to the socket / failure-detector path (the original
        // behaviour) -- never a fabricated success.
        var spins: i64 = 0;
        loop {
            let failed = unsafe {
                hew_dist_partition_pending_remote_asks()
            };
            if failed >= 1 {
                return;
            }
            spins = spins + 1;
            if spins >= 15000 {
                return;
            }
            sleep(2ms);
        }
    }
}

actor Linker {
    // 0 = CrashLinked (the linked actor crashes); 1 = MonitorLost (non-fatal).
    let policy_sel: i64;

    // Establish the cross-node link from inside this actor's own handler so the
    // implicit `self` subject of `link_remote` is THIS actor. The remote peer is
    // passed as a message argument (a RemotePid is an opaque i64 pid; storing it
    // in actor state is not a supported clone-layout shape, so it rides the
    // message instead). Returns its own actor id (or -1 on a registration
    // failure) so `main` can poll its terminal state.
    receive fn link_go(peer: RemotePid<KeyValue>) -> i64 {
        let status = if policy_sel == 0 {
            link_remote(peer, PartitionPolicy::CrashLinked)
        } else {
            link_remote(peer, PartitionPolicy::MonitorLost)
        };
        let ok = match status {
            Result::Ok(_) => true,
            Result::Err(_) => false,
        };
        // Return this actor's id on success, 0 on failure. The id is a packed pid
        // (node<<48 | serial) and can be NEGATIVE as an i64 when the node id is
        // large, so the caller must test `== 0`, never `< 0`. The probe casts to
        // u64, so a negative-as-i64 id round-trips correctly.
        if ok {
            unsafe {
                hew_actor_self_id()
            }
        } else {
            0
        }
    }
    // Liveness probe: a surviving linker answers; a crashed one cannot.
    receive fn ping() -> i64 {
        7
    }
}

// Bounded poll for the remote actor: retry Node::lookup until registry gossip
// resolves it, instead of a single fixed-interval sleep. ~50 attempts at 100 ms
// = 5 s deadline, generous for loopback gossip while still failing closed if the
// peer never registers.
fn lookup_with_retry(name: string) -> Result<RemotePid<KeyValue>, LookupError> {
    var attempts: i64 = 0;
    loop {
        let found: Result<RemotePid<KeyValue>, LookupError> = Node::lookup(name);
        match found {
            Result::Ok(pid) => {
                return Ok(pid);
            },
            Result::Err(e) => {
                attempts = attempts + 1;
                if attempts >= 50 {
                    return Err(e);
                }
                sleep(100ms);
            },
        }
    }
}

// Same bounded poll, typed for the WireProbe actor (the #[wire] scenario).
fn lookup_wire_with_retry(name: string) -> Result<RemotePid<WireProbe>, LookupError> {
    var attempts: i64 = 0;
    loop {
        let found: Result<RemotePid<WireProbe>, LookupError> = Node::lookup(name);
        match found {
            Result::Ok(pid) => {
                return Ok(pid);
            },
            Result::Err(e) => {
                attempts = attempts + 1;
                if attempts >= 50 {
                    return Err(e);
                }
                sleep(100ms);
            },
        }
    }
}

fn lookup_identity_with_retry(name: string) -> Result<RemotePid<IdentityProbe>, LookupError> {
    var attempts: i64 = 0;
    loop {
        let found: Result<RemotePid<IdentityProbe>, LookupError> = Node::lookup(name);
        match found {
            Result::Ok(pid) => {
                return Ok(pid);
            },
            Result::Err(e) => {
                attempts = attempts + 1;
                if attempts >= 50 {
                    return Err(e);
                }
                sleep(100ms);
            },
        }
    }
}

fn run_server(port: string, scenario: string) {
    let addr = f"127.0.0.1:{port}";
    Node::set_transport("tcp");
    Node::start(addr);
    let s: HashMap<string, string> = HashMap::new();
    let kv = spawn KeyValue(store: s);
    Node::register("kv", kv);
    // Also register the #[wire] probe actor so the wire_cbor scenario has a
    // remote target. Registering both keeps run_server scenario-independent.
    let wp = spawn WireProbe(calls: 0);
    Node::register("wire", wp);
    let identity = spawn IdentityProbe;
    Node::register("identity", identity);

    // Readiness signal: emitted ONLY after the actors are registered, so the
    // harness never launches the client against a half-started node.
    println(f"READY {port}");
    if scenario == "monitor_watcher_node_death" {
        // For this scenario the server drives the assertion: poll the watcher
        // count until it drops to 0 (prune fired) and print the result.
        // The harness reads this PASS line from the server's stdout.
        scenario_server_watcher_node_death(0);
    } else {
        if scenario == "cross_node_monitor_close_reclaim" {
            // The server watches its target-side count rise then fall after
            // the client closes its cross-node monitor (CTRL_DEMONITOR received).
            scenario_server_monitor_close_reclaim();
        } else {
            if scenario == "stale_ref" {
                // StaleRef scenario: after a settle window (long enough for the
                // client to look up "kv" and capture the original actor's pid),
                // re-point "kv" to a DIFFERENT actor. The unregister + register
                // bumps the registration incarnation and supersedes the original
                // serial; the removal+add gossip propagates the re-point so the
                // client supersedes its captured serial. The client then observes
                // StaleRef on the captured ref.
                sleep(1s);
                let _ = unsafe {
                    hew_node_api_unregister("kv")
                };
                let s2: HashMap<string, string> = HashMap::new();
                let kv2 = spawn KeyValue(store: s2);
                Node::register("kv", kv2);
                println("SERVER_REPOINTED stale_ref");
                sleep(2m);
            } else {
                // All other scenarios: stay alive until the harness kills us.
                sleep(2m);
            }
        }
    }
    Node::shutdown();
}

// Scenario: remote_ask
//
// The client connects, puts two entries via fire-and-forget send, then issues
// two blocking remote asks and checks the exact returned values. This is the
// first assertion: a real cross-process ask round-trip with exact-value teeth.
fn scenario_remote_ask(kv: RemotePid<KeyValue>) -> i64 {
    let send1 = kv.send(KvReq::Put(KvPut { key: "hello", val: "world" }));
    match send1 {
        Result::Err(_) => {
            println("FAIL remote_ask put-hello-send-error");
            return 2;
        },
        Result::Ok(_) => {},
    }
    let send2 = kv.send(KvReq::Put(KvPut { key: "count", val: "42" }));
    match send2 {
        Result::Err(_) => {
            println("FAIL remote_ask put-count-send-error");
            return 3;
        },
        Result::Ok(_) => {},
    }
    // Brief settle so the fire-and-forget sends are applied before the ask.
    // (send is async; the ask below is the synchronization point we assert on.)
    sleep(200ms);
    let ask1 = kv.ask(KvReq::GetKey("hello"), 5000);
    match ask1 {
        Result::Err(_) => {
            println("FAIL remote_ask get-hello-ask-error");
            return 4;
        },
        Result::Ok(resp) => {
            match resp {
                KvResp::Value(v) => {
                    if v == "world" {
                        println("PASS remote_ask get-hello=world");
                    } else {
                        println(f"FAIL remote_ask get-hello={v}");
                        return 5;
                    }
                },
                KvResp::Ack => {
                    println("FAIL remote_ask get-hello-got-ack");
                    return 5;
                },
            }
        },
    }
    let ask2 = kv.ask(KvReq::GetKey("count"), 5000);
    match ask2 {
        Result::Err(_) => {
            println("FAIL remote_ask get-count-ask-error");
            return 6;
        },
        Result::Ok(resp) => {
            match resp {
                KvResp::Value(v) => {
                    if v == "42" {
                        println("PASS remote_ask get-count=42");
                    } else {
                        println(f"FAIL remote_ask get-count={v}");
                        return 7;
                    }
                },
                KvResp::Ack => {
                    println("FAIL remote_ask get-count-got-ack");
                    return 7;
                },
            }
        },
    }
    0
}

// Scenario: wire_cbor
//
// Sends a #[wire] enum (WireCmd) with EXPLICIT @N variant tags via two remote
// asks — a payload variant (Move, the map-of-one body) and a unit variant (Ping,
// the bare-tag body) — and checks the #[wire] struct reply (WireResult, an
// @N-keyed map) field-by-field. This is the distinct thing this scenario proves: an
// explicit-@N tagged CBOR body crossing two OS processes in both directions,
// which the plain-record/enum remote_ask scenario does not exercise.
fn scenario_wire_cbor(wp: RemotePid<WireProbe>) -> i64 {
    // Payload variant: Move(WirePoint { x: 3, y: 4 }) → server replies
    // WireResult { tag: 1, sum: 7 }.
    let ask_move = wp.ask(WireCmd::Move(WirePoint { x: 3, y: 4 }), 5000);
    match ask_move {
        Result::Err(_) => {
            println("FAIL wire_cbor move-ask-error");
            return 2;
        },
        Result::Ok(res) => {
            if res.tag == 1 {
                println(f"PASS wire_cbor move-tag={res.tag}");
            } else {
                println(f"FAIL wire_cbor move-tag={res.tag}");
                return 3;
            }
            if res.sum == 7 {
                println(f"PASS wire_cbor move-sum={res.sum}");
            } else {
                println(f"FAIL wire_cbor move-sum={res.sum}");
                return 4;
            }
        },
    }
    // Unit variant: Ping → server replies WireResult { tag: 0, sum: 0 }.
    let ask_ping = wp.ask(WireCmd::Ping, 5000);
    match ask_ping {
        Result::Err(_) => {
            println("FAIL wire_cbor ping-ask-error");
            return 5;
        },
        Result::Ok(res) => {
            if res.tag == 0 {
                println(f"PASS wire_cbor ping-tag={res.tag}");
            } else {
                println(f"FAIL wire_cbor ping-tag={res.tag}");
                return 6;
            }
            if res.sum == 0 {
                println(f"PASS wire_cbor ping-sum={res.sum}");
            } else {
                println(f"FAIL wire_cbor ping-sum={res.sum}");
                return 7;
            }
        },
    }
    0
}

// Scenario: identity_location
//
// Proves the runtime identity tuple across two OS processes. Registry gossip
// yields a packed remote pid whose `(node_id, serial)` location exactly matches
// the actor's self-reported identity, whose registration incarnation is the
// fresh value 0, and whose node is a live SWIM member distinct from this client.
fn scenario_identity_location(identity: RemotePid<IdentityProbe>) -> i64 {
    let raw = unsafe {
        hew_node_api_lookup("identity")
    };
    if raw == 0 {
        println("FAIL identity_location raw-lookup-zero");
        return 2;
    }
    let local_node = unsafe {
        hew_pid_local_node()
    };
    let remote_node = unsafe {
        hew_pid_node(raw)
    };
    let remote_serial = unsafe {
        hew_pid_serial(raw)
    };
    let remote_incarnation = unsafe {
        hew_pid_incarnation(raw)
    };
    let member_state = unsafe {
        hew_dist_member_state(remote_node)
    };
    if local_node == 0 || remote_node == 0 || local_node == remote_node {
        println("FAIL identity_location node-ids-not-distinct");
        return 3;
    }
    if remote_serial == 0 {
        println("FAIL identity_location serial-zero");
        return 4;
    }
    if remote_incarnation != 0 {
        println(f"FAIL identity_location client-incarnation={remote_incarnation}");
        return 5;
    }
    if member_state != 0 {
        println(f"FAIL identity_location member-state={member_state}");
        return 6;
    }
    let inspected = identity.ask(IdentityReq::Inspect, 5000);
    match inspected {
        Result::Err(_) => {
            println("FAIL identity_location inspect-ask-error");
            return 7;
        },
        Result::Ok(resp) => {
            match resp {
                IdentityResp::Value(actual) => {
                    if actual.packed != raw {
                        println("FAIL identity_location packed-mismatch");
                        return 8;
                    }
                    if actual.node_id != remote_node {
                        println("FAIL identity_location node-mismatch");
                        return 9;
                    }
                    if actual.serial != remote_serial {
                        println("FAIL identity_location serial-mismatch");
                        return 10;
                    }
                    if actual.incarnation != remote_incarnation {
                        println("FAIL identity_location incarnation-mismatch");
                        return 11;
                    }
                },
            }
        },
    }
    println(f"PASS identity_location local={local_node} remote={remote_node} serial={remote_serial} incarnation={remote_incarnation} state={member_state}");
    0
}

// Scenario: remote_monitor_clean_exit
//
// The client monitors the remote KeyValue actor, then tells it to stop. The
// monitor must deliver exactly one DOWN carrying the clean-exit reason (6).
fn scenario_remote_monitor_clean_exit(kv: RemotePid<KeyValue>) -> i64 {
    let setup: Result<MonitorRef, MonitorError> = monitor(kv);
    match setup {
        Result::Err(_) => {
            println("FAIL remote_monitor_clean_exit setup-error");
            1
        },
        Result::Ok(m) => {
            let send_stop = kv.send(KvReq::StopSelf);
            match send_stop {
                Result::Err(_) => {
                    println("FAIL remote_monitor_clean_exit stop-send-error");
                    return 2;
                },
                Result::Ok(_) => {},
            }
            let reason = m.recv_down(10000);
            if reason == 6 {
                println(f"PASS remote_monitor_clean_exit reason={reason}");
            } else {
                println(f"FAIL remote_monitor_clean_exit reason={reason}");
                return 3;
            }
            // Negative guard for exactly-once: a second recv must time out (-2),
            // proving no duplicate DOWN was delivered for the same registration.
            let dup = m.recv_down(1000);
            if dup == -2 {
                println("PASS remote_monitor_clean_exit no-dup");
            } else {
                println(f"FAIL remote_monitor_clean_exit dup-reason={dup}");
                return 4;
            }
            0
        },
    }
}

// Scenario: remote_monitor_crash
//
// The client monitors the remote KeyValue actor, then tells it to crash. The
// monitor must deliver exactly one DOWN carrying the crash reason (5).
fn scenario_remote_monitor_crash(kv: RemotePid<KeyValue>) -> i64 {
    let setup: Result<MonitorRef, MonitorError> = monitor(kv);
    match setup {
        Result::Err(_) => {
            println("FAIL remote_monitor_crash setup-error");
            1
        },
        Result::Ok(m) => {
            let send_crash = kv.send(KvReq::CrashSelf);
            match send_crash {
                Result::Err(_) => {
                    println("FAIL remote_monitor_crash crash-send-error");
                    return 2;
                },
                Result::Ok(_) => {},
            }
            let reason = m.recv_down(10000);
            if reason == 5 {
                println(f"PASS remote_monitor_crash reason={reason}");
            } else {
                println(f"FAIL remote_monitor_crash reason={reason}");
                return 3;
            }
            let dup = m.recv_down(1000);
            if dup == -2 {
                println("PASS remote_monitor_crash no-dup");
            } else {
                println(f"FAIL remote_monitor_crash dup-reason={dup}");
                return 4;
            }
            0
        },
    }
}

// Scenario: remote_monitor_conn_drop
//
// The client monitors the remote actor, then the harness kills the server
// process. The monitor must deliver exactly one DOWN carrying the MonitorLost
// sentinel (-1) for the connection-drop / partition cause — distinct from the
// clean-exit and crash reasons.
fn scenario_remote_monitor_conn_drop(kv: RemotePid<KeyValue>) -> i64 {
    let setup: Result<MonitorRef, MonitorError> = monitor(kv);
    match setup {
        Result::Err(_) => {
            println("FAIL remote_monitor_conn_drop setup-error");
            1
        },
        Result::Ok(m) => {
            // Signal readiness so the harness knows the monitor is registered
            // before it kills the server. The actor stays alive; only the
            // connection drops.
            println("READY_DROP remote_monitor_conn_drop");
            let reason = m.recv_down(30000);
            if reason == -1 {
                println(f"PASS remote_monitor_conn_drop reason={reason}");
            } else {
                println(f"FAIL remote_monitor_conn_drop reason={reason}");
                return 3;
            }
            let dup = m.recv_down(1000);
            if dup == -2 {
                println("PASS remote_monitor_conn_drop no-dup");
            } else {
                println(f"FAIL remote_monitor_conn_drop dup-reason={dup}");
                return 4;
            }
            0
        },
    }
}

// Scenario: remote_monitor_setup_after_drop
//
// The harness kills the server after READY_DROP. Once route teardown reaches the
// client, monitor(RemotePid) must return Err(MonitorError::Partition) rather than
// a zero-valued or inert MonitorRef.
fn scenario_remote_monitor_setup_after_drop(kv: RemotePid<KeyValue>) -> i64 {
    println("READY_DROP remote_monitor_setup_after_drop");
    var attempts: i64 = 0;
    loop {
        let setup: Result<MonitorRef, MonitorError> = monitor(kv);
        match setup {
            Result::Err(MonitorError::Partition) => {
                println("PASS remote_monitor_setup_after_drop error=Partition");
                return 0;
            },
            Result::Err(_) => {
                println("FAIL remote_monitor_setup_after_drop wrong-error");
                return 2;
            },
            Result::Ok(monitor_ref) => {
                monitor_ref.close();
                attempts = attempts + 1;
                if attempts >= 100 {
                    println("FAIL remote_monitor_setup_after_drop never-failed");
                    return 3;
                }
                sleep(100ms);
            },
        }
    }
}

// Scenario: partition_ask
//
// The partition gate. The client looks up the remote actor, signals
// READY_DROP so the harness can kill the server (dropping the route to the
// peer), then issues a remote ask to the now-unreachable actor. The invariant
// under test is: the ask FAILS CLOSED — it resolves to a typed AskError WITHOUT
// hanging — rather than blocking to the client ceiling or fabricating a value.
//
// The EXACT fail-closed cause is timing-dependent: a two-process SIGKILL races
// three independent fail paths, any of which is a correct fail-closed verdict
// for a peer that is gone:
//   * RoutingFailed   — the reader thread tore down the route before the ask was
//                       set up, so the ask is refused before it leaves the node.
//   * ConnectionDropped — the socket-drop path failed the pending ask.
//   * Partition       — the SWIM failure detector declared the peer dead and
//                       fanned out to the pending ask (the deterministic
//                       socket-open-but-peer-dead path).
//   * NodeNotRunning / SendFailed / StaleRef — narrower fail-closed races on the
//                       same teardown.
// Which one wins shifts with host load (under CI load RoutingFailed dominates;
// on a quiet host the ask is more often still pending and surfaces as
// ConnectionDropped). The gate therefore accepts ANY fail-closed cause EXCEPT
// Timeout: a Timeout means the ask waited its WHOLE deadline because none of the
// proactive fail-closed paths fired — that is the hang-to-deadline this gate
// exists to catch, so it is retried (in case the verdict is mid-propagation)
// and then fails.
//
// Teeth that remain: (a) a Result::Ok after READY_DROP is rejected (the route is
// still live — never-partitioned), so a wrong success cannot pass; (b) every ask
// carries a 1 s timeout, so an unresolved ask cannot hang past that, and the
// whole scenario is bounded far under the 40 s client ceiling; (c) the resolving
// fast-fail must return BEFORE its own 1 s deadline (no-hang bound, asserted
// explicitly), so a fail-closed-by-timeout cannot masquerade as a proactive one.
//
// The deterministic SWIM-DEAD-while-socket-open Partition path is proven exactly
// in-process by the runtime unit test
// `swim_dead_wakes_pending_remote_ask_with_partition`; this two-process fixture
// pins the broader no-hang + typed-fail-closed invariant across the wire.
fn scenario_partition_ask(kv: RemotePid<KeyValue>) -> i64 {
    // Signal the harness to kill the server now that the route is established.
    println("READY_DROP partition_ask");
    // Arm the deterministic partition seam: a concurrent injector fails the
    // in-flight remote ask closed with Partition through the production
    // reply-table fan-out the instant it registers, so the typed fail-closed
    // verdict no longer races the socket-teardown / SWIM detector latency (the
    // historical source of this test's flake). The harness kill above is the real
    // teardown; the injector only bounds WHEN the pending ask is failed closed,
    // never WHETHER. The reply table holds only application asks (the lookup that
    // resolved `kv` already completed), so the sole pending entry is this scenario's
    // `kv.ask` — draining it cannot disturb any healthy in-flight request.
    let injector = spawn PartitionInjector;
    injector.arm();
    // Per-ask timeout: an unresolved ask cannot block longer than this, so even a
    // pure Timeout is bounded far under the client ceiling — the no-hang floor.
    let ask_timeout_ms: u64 = 1000;
    // No-hang bound: a PROACTIVE fail-closed verdict resolves the ask well before
    // its own deadline. If an Err comes back only at (or past) the full timeout,
    // the proactive path did not fire — treat it as a Timeout, not a fast-fail.
    let fast_fail_ceiling_ms: i64 = 900;
    var attempts: i64 = 0;
    loop {
        let started = instant::now();
        let probe = kv.ask(KvReq::GetKey("hello"), ask_timeout_ms);
        let elapsed_ms = started.elapsed().millis();
        match probe {
            Result::Ok(_) => {
                // The route is still live (kill in flight) — a success here is
                // NOT a partition. Retry briefly; never accept it as a pass.
                attempts = attempts + 1;
                if attempts >= 20 {
                    println("FAIL partition_ask never-partitioned");
                    return 2;
                }
                sleep(200ms);
            },
            Result::Err(e) => {
                // A Timeout — or any Err that only surfaced at the full deadline —
                // means no proactive fail-closed path fired (a hang-to-deadline).
                // Retry a bounded number of times in case the verdict is still
                // propagating, then fail.
                let timed_out = match e {
                    AskError::Timeout => true,
                    _ => elapsed_ms >= fast_fail_ceiling_ms,
                };
                if timed_out {
                    attempts = attempts + 1;
                    if attempts >= 20 {
                        println("FAIL partition_ask reason=timeout");
                        return 3;
                    }
                    sleep(200ms);
                } else {
                    // A proactive, fast typed fail-closed verdict — the invariant
                    // holds. Name the cause for diagnostics; any of these is a
                    // correct outcome for a peer that is gone.
                    match e {
                        AskError::Partition => println(f"PASS partition_ask reason=partition ms={elapsed_ms}"),
                        AskError::ConnectionDropped => println(f"PASS partition_ask reason=conn-dropped ms={elapsed_ms}"),
                        AskError::RoutingFailed => println(f"PASS partition_ask reason=routing-failed ms={elapsed_ms}"),
                        AskError::NodeNotRunning => println(f"PASS partition_ask reason=node-not-running ms={elapsed_ms}"),
                        AskError::SendFailed => println(f"PASS partition_ask reason=send-failed ms={elapsed_ms}"),
                        AskError::StaleRef => println(f"PASS partition_ask reason=stale-ref ms={elapsed_ms}"),
                        _ => println(f"PASS partition_ask reason=fail-closed ms={elapsed_ms}"),
                    }
                    return 0;
                }
            },
        }
    }
}

// Scenario: stale_ref
//
// StaleRef identity-hardening proof: the client looks up "kv" and
// captures a RemotePid for the ORIGINAL actor. The server then re-points "kv" to
// a DIFFERENT actor (unregister + re-register), which supersedes the original
// serial. Once the re-point gossip propagates, the client's CAPTURED ref must
// fail closed with StaleRef on BOTH send and ask — never silently deliver to the
// replacement, never a generic routing error.
//
// Teeth: the test fails if the captured ref ever succeeds (delivered to the new
// actor) and requires the EXACT StaleRef discriminant on both verbs.
fn scenario_stale_ref(kv: RemotePid<KeyValue>) -> i64 {
    // Poll the captured ref until the re-point supersedes it. Bounded: ~60
    // attempts at 100 ms = 6 s, generous for the 1 s server settle + gossip
    // while still failing closed if StaleRef never fires.
    var attempts: i64 = 0;
    loop {
        let probe = kv.send(KvReq::Put(KvPut { key: "x", val: "y" }));
        match probe {
            Result::Ok(_) => {
                // Still routing to the original (pre-re-point) — retry until the
                // supersession propagates. A success AFTER the deadline is a
                // failure: the captured ref must go stale.
                attempts = attempts + 1;
                if attempts >= 60 {
                    println("FAIL stale_ref send-never-stale");
                    return 2;
                }
                sleep(100ms);
            },
            Result::Err(e) => {
                match e {
                    SendError::StaleRef => {
                        // send is stale; now require ask to be stale too (the
                        // shared gate fires on every verb).
                        let ask_probe = kv.ask(KvReq::GetKey("x"), 2000);
                        match ask_probe {
                            Result::Ok(_) => {
                                println("FAIL stale_ref ask-succeeded-after-send-stale");
                                return 3;
                            },
                            Result::Err(ae) => {
                                match ae {
                                    AskError::StaleRef => {
                                        println("PASS stale_ref send=stale ask=stale");
                                        return 0;
                                    },
                                    _ => {
                                        println("FAIL stale_ref ask-wrong-error");
                                        return 4;
                                    },
                                }
                            },
                        }
                    },
                    _ => {
                        // Any non-StaleRef error before supersession is a routing
                        // race (the re-point removal may transiently drop the
                        // route); retry within the deadline rather than accept it.
                        attempts = attempts + 1;
                        if attempts >= 60 {
                            println("FAIL stale_ref send-wrong-error");
                            return 5;
                        }
                        sleep(100ms);
                    },
                }
            },
        }
    }
}

// Scenario: monitor_watcher_node_death
//
// Two-process fixture: the watcher node dies and the target-side
// RemoteWatcher entries it registered are pruned, keeping the table bounded.
//
// Server role: registers the target actor, prints READY, then polls
// hew_dist_monitor_remote_watcher_count() until it drops to 0 (the prune
// fired) and prints the exact count that was registered before the death.
// Target actor stays alive and re-monitorable afterward.
//
// Client role: connects, registers a monitor on the server's "kv" actor,
// prints READY_CLIENT_WATCHER so the harness knows the watch is live, then
// sleeps until the harness kills it. The kill simulates a watcher-node crash.
extern "C" {
    fn hew_dist_monitor_remote_watcher_count() -> i64;
}

fn scenario_server_watcher_node_death(_kv_serial: i64) {
    // Phase 1: wait until at least one RemoteWatcher entry appears (the client
    // connected and registered its monitor via CTRL_MONITOR_REQ).
    var registered: i64 = 0;
    var wait_attempts: i64 = 0;
    loop {
        let c = unsafe {
            hew_dist_monitor_remote_watcher_count()
        };
        if c > 0 {
            registered = c;
            // Signal that the monitor registration has been received and processed.
            // The harness reads this line before killing the client, ensuring the
            // kill arrives after — not before — the target-side entry is recorded.
            println(f"READY_SERVER_WATCHER_REGISTERED monitor_watcher_node_death count={registered}");
            break;
        }
        wait_attempts = wait_attempts + 1;
        if wait_attempts >= 200 {
            // Emit diagnostic count to distinguish no-runtime (-1) from table-empty (0).
            println(f"FAIL monitor_watcher_node_death server-no-watcher-registered last-count={c}");
            return;
        }
        sleep(100ms);
    }
    // Phase 2: poll until the count drops back to 0 (prune fired on connection-drop).
    var prune_attempts: i64 = 0;
    loop {
        let c = unsafe {
            hew_dist_monitor_remote_watcher_count()
        };
        if c == 0 {
            // Table is empty: the prune fired correctly.
            println(f"PASS monitor_watcher_node_death pruned={registered}");
            return;
        }
        prune_attempts = prune_attempts + 1;
        if prune_attempts >= 200 {
            println(f"FAIL monitor_watcher_node_death pruned-timeout count={c}");
            return;
        }
        sleep(100ms);
    }
}

fn scenario_client_watcher_node_death(kv: RemotePid<KeyValue>) -> i64 {
    // Register a monitor on the server's long-lived actor.
    let setup: Result<MonitorRef, MonitorError> = monitor(kv);
    match setup {
        Result::Err(_) => {
            println("FAIL monitor_watcher_node_death setup-error");
            1
        },
        Result::Ok(m) => {
            // Signal readiness so the harness knows CTRL_MONITOR_REQ has been sent.
            // The server then confirms receipt (READY_SERVER_WATCHER_REGISTERED)
            // before the harness kills this process, closing the registration race.
            println("READY_CLIENT_WATCHER monitor_watcher_node_death");
            // Block until this process is killed (SIGKILL from harness). The
            // generous timeout keeps the Result owner alive and in scope so its
            // MonitorRef payload does not demonitor before the harness kill arrives.
            m.recv_down(120000)
        },
    }
}

// ── Cross-node link scenarios ────────────────────────────────────────────────

// Spawn a Linker, send it to establish the cross-node link (capturing its actor
// id from the reply), drive the remote actor to a terminal state, then poll the
// linker's terminal state. With CrashLinked the linker must reach Crashed (5):
// the cross-node link-down landed in its mailbox as a SYS_MSG_EXIT and crashed
// it. `policy_sel` 0 = CrashLinked. `drive` selects how the remote dies.
fn link_cascade_common(kv: RemotePid<KeyValue>, scenario: string, drive: string) -> i64 {
    let linker = spawn Linker(policy_sel: 0);
    // Establish the link from inside the linker's own handler; the reply is its
    // actor id (or -1 on a registration failure).
    let linker_id = await linker.link_go(kv);
    let lid = match linker_id {
        Result::Ok(id) => id,
        Result::Err(_) => {
            println(f"FAIL {scenario} link-ask-error");
            return 2;
        },
    };
    if lid == 0 {
        println(f"FAIL {scenario} link-register-failed");
        return 3;
    }
    // Drive the remote actor to its terminal state per the scenario.
    if drive == "stop" {
        let t = kv.send(KvReq::StopSelf);
        match t {
            Result::Err(_) => {
                println(f"FAIL {scenario} stop-send-error");
                return 4;
            },
            Result::Ok(_) => {},
        }
    } else {
        if drive == "crash" {
            let t = kv.send(KvReq::CrashSelf);
            match t {
                Result::Err(_) => {
                    println(f"FAIL {scenario} crash-send-error");
                    return 4;
                },
                Result::Ok(_) => {},
            }
        }
        // drive == "partition": the harness kills the server; nothing to send.
    }
    if drive == "partition" {
        // Signal readiness so the harness kills the server now that the link is
        // established. The remote actor stays alive; only the connection drops.
        println(f"READY_DROP {scenario}");
    }
    // Poll the linker's terminal state until the cascade crashes it (or a bound
    // elapses). The probe returns the recorded terminal reason or -999 while live.
    var attempts: i64 = 0;
    loop {
        let st = unsafe {
            hew_link_probe_terminal_state(lid)
        };
        if st == 5 {
            println(f"PASS {scenario} linker-crashed reason={st}");
            return 0;
        }
        if st >= 0 {
            // Reached a terminal state other than Crashed — unexpected for a
            // CrashLinked cascade (a clean Stopped would be a fail-open bug).
            println(f"FAIL {scenario} linker-terminal-wrong reason={st}");
            return 5;
        }
        attempts = attempts + 1;
        if attempts >= 300 {
            println(f"FAIL {scenario} linker-never-crashed");
            return 6;
        }
        sleep(100ms);
    }
}

fn scenario_link_remote_clean_exit(kv: RemotePid<KeyValue>) -> i64 {
    link_cascade_common(kv, "link_remote_clean_exit", "stop")
}

fn scenario_link_remote_crash(kv: RemotePid<KeyValue>) -> i64 {
    link_cascade_common(kv, "link_remote_crash", "crash")
}

fn scenario_link_remote_partition(kv: RemotePid<KeyValue>) -> i64 {
    link_cascade_common(kv, "link_remote_partition", "partition")
}

// Negative case: a non-CrashLinked link policy (MonitorLost) must NOT crash the
// linker when the remote dies. After driving the remote to a clean exit, the
// linker must STILL answer a liveness ask — proving the policy discriminator has
// teeth and a non-CrashLinked link does not synthesize a fatal EXIT.
fn scenario_link_remote_non_crashlinked(kv: RemotePid<KeyValue>) -> i64 {
    let linker = spawn Linker(policy_sel: 1);
    let linker_id = await linker.link_go(kv);
    let lid = match linker_id {
        Result::Ok(id) => id,
        Result::Err(_) => {
            println("FAIL link_remote_non_crashlinked link-ask-error");
            return 2;
        },
    };
    if lid == 0 {
        println("FAIL link_remote_non_crashlinked link-register-failed");
        return 3;
    }
    let t = kv.send(KvReq::StopSelf);
    match t {
        Result::Err(_) => {
            println("FAIL link_remote_non_crashlinked stop-send-error");
            return 4;
        },
        Result::Ok(_) => {},
    }
    // Give the cross-node link-down ample time to (wrongly) crash the linker.
    sleep(1500ms);
    // The probe must NOT report a terminal state — the linker survived.
    let st = unsafe {
        hew_link_probe_terminal_state(lid)
    };
    if st >= 0 {
        println(f"FAIL link_remote_non_crashlinked linker-crashed reason={st}");
        return 5;
    }
    // Liveness confirmation: a surviving linker still answers an ask.
    let ping = await linker.ping();
    match ping {
        Result::Ok(_) => {
            println("PASS link_remote_non_crashlinked linker-survived");
            0
        },
        Result::Err(_) => {
            println("FAIL link_remote_non_crashlinked linker-unreachable");
            6
        },
    }
}

// Cross-node demonitor reclamation (server-driven, mirrors the watcher-node-death
// proof). The client monitors the remote actor, then explicitly
// closes the MonitorRef. The close must route to the cross-node teardown (not
// the local-table no-op), sending a CTRL_DEMONITOR to the peer. The SERVER
// observes its target-side entry appear (count>0) then disappear (count==0)
// after the demonitor — proving the close reached the peer (the watcher-side
// entry was reclaimed locally AND the peer was told). The server prints the
// PASS; this client just registers, signals ready, closes, and exits cleanly.
fn scenario_server_monitor_close_reclaim() {
    var registered: i64 = 0;
    var wait_attempts: i64 = 0;
    loop {
        let c = unsafe {
            hew_dist_monitor_remote_watcher_count()
        };
        if c > 0 {
            registered = c;
            println(f"READY_SERVER_WATCHER_REGISTERED cross_node_monitor_close_reclaim count={registered}");
            break;
        }
        wait_attempts = wait_attempts + 1;
        if wait_attempts >= 200 {
            println(f"FAIL cross_node_monitor_close_reclaim server-no-watcher last-count={c}");
            return;
        }
        sleep(100ms);
    }
    var reclaim_attempts: i64 = 0;
    loop {
        let c = unsafe {
            hew_dist_monitor_remote_watcher_count()
        };
        if c == 0 {
            println(f"PASS cross_node_monitor_close_reclaim reclaimed={registered}");
            return;
        }
        reclaim_attempts = reclaim_attempts + 1;
        if reclaim_attempts >= 200 {
            println(f"FAIL cross_node_monitor_close_reclaim reclaim-timeout count={c}");
            return;
        }
        sleep(100ms);
    }
}

fn scenario_client_monitor_close_reclaim(kv: RemotePid<KeyValue>) -> i64 {
    let setup: Result<MonitorRef, MonitorError> = monitor(kv);
    match setup {
        Result::Err(_) => {
            println("FAIL cross_node_monitor_close_reclaim setup-error");
            1
        },
        Result::Ok(m) => {
            // Signal the watch is live so the server records the target-side
            // entry and confirms before the explicit close sends CTRL_DEMONITOR.
            println("READY_CLIENT_WATCHER cross_node_monitor_close_reclaim");
            sleep(800ms);
            m.close();
            // Keep the node alive after the close so the control frame is
            // delivered before Node::shutdown tears down the connection.
            sleep(800ms);
            0
        },
    }
}

// Scenario: quarantine_rejoin
//
// Proves the fail-closed rejoin-admission boundary through the full compiled
// stack. A buried peer (DEAD) is quarantined; a stale (<=-incarnation) ALIVE
// gossip replay must NOT resurrect it, while a strictly-higher-incarnation rejoin
// IS admitted and evicts the quarantine entry. The membership gossip frames are
// driven deterministically through the runtime so there is no failure-detector
// race; the resurrection-guard negative half is the assertion with teeth.
//
// MEMBER_* states: ALIVE = 0, DEAD = 2.
fn scenario_quarantine_rejoin() -> i64 {
    let peer: u16 = 4242;
    let alive: i32 = 0;
    let dead: i32 = 2;
    // Establish the peer ALIVE at incarnation 5, then bury it (DEAD at 5). The
    // DEAD verdict quarantines it at incarnation 5.
    unsafe {
        hew_dist_inject_swim_gossip(peer, alive, 5)
    };
    unsafe {
        hew_dist_inject_swim_gossip(peer, dead, 5)
    };
    let state_after_verdict = unsafe {
        hew_dist_member_state(peer)
    };
    if state_after_verdict != 2 {
        println("FAIL quarantine_rejoin not-dead-after-verdict");
        return 2;
    }
    let quarantined_after_verdict = unsafe {
        hew_dist_quarantine_contains(peer)
    };
    if quarantined_after_verdict != 1 {
        println("FAIL quarantine_rejoin not-quarantined-after-verdict");
        return 3;
    }
    // Negative half (the resurrection guard): a stale ALIVE replay at an
    // incarnation <= the buried one must NOT resurrect the peer. Try equal (5) and
    // lower (4); after each the peer must stay DEAD and quarantined.
    unsafe {
        hew_dist_inject_swim_gossip(peer, alive, 5)
    };
    unsafe {
        hew_dist_inject_swim_gossip(peer, alive, 4)
    };
    let state_after_stale = unsafe {
        hew_dist_member_state(peer)
    };
    if state_after_stale != 2 {
        println("FAIL quarantine_rejoin resurrected-by-stale");
        return 4;
    }
    let quarantined_after_stale = unsafe {
        hew_dist_quarantine_contains(peer)
    };
    if quarantined_after_stale != 1 {
        println("FAIL quarantine_rejoin quarantine-cleared-by-stale");
        return 5;
    }
    println("PASS quarantine_rejoin stale-rejected");

    // Positive half: a strictly-higher-incarnation rejoin (6 > 5) IS admitted;
    // the peer returns ALIVE and the quarantine entry is evicted.
    unsafe {
        hew_dist_inject_swim_gossip(peer, alive, 6)
    };
    let state_after_rejoin = unsafe {
        hew_dist_member_state(peer)
    };
    if state_after_rejoin != 0 {
        println("FAIL quarantine_rejoin not-readmitted-at-higher");
        return 6;
    }
    let quarantined_after_rejoin = unsafe {
        hew_dist_quarantine_contains(peer)
    };
    if quarantined_after_rejoin != 0 {
        println("FAIL quarantine_rejoin not-evicted-after-readmission");
        return 7;
    }
    println("PASS quarantine_rejoin readmitted-at=6");
    0
}

fn run_client(port: string, scenario: string) -> i64 {
    let remote_addr = f"127.0.0.1:{port}";
    Node::set_transport("tcp");
    Node::start("127.0.0.1:0");
    Node::connect(remote_addr);
    // Scenario dispatch. New scenarios add a branch here plus a scenario_*
    // function above; the harness selects via HEW_DIST_SCENARIO. The #[wire]
    // scenario targets the WireProbe actor ("wire"); the rest target KeyValue
    // ("kv").
    let status = if scenario == "quarantine_rejoin" {
        // Membership-gate scenario: driven entirely through injected gossip on the
        // local cluster, so it needs no remote actor lookup.
        scenario_quarantine_rejoin()
    } else if scenario == "identity_location" {
        let found_identity = lookup_identity_with_retry("identity");
        match found_identity {
            Result::Err(_) => {
                println(f"FAIL {scenario} lookup-unresolved");
                1
            },
            Result::Ok(identity) => {
                scenario_identity_location(identity)
            },
        }
    } else if scenario == "wire_cbor" {
        let found_wire = lookup_wire_with_retry("wire");
        match found_wire {
            Result::Err(_) => {
                println(f"FAIL {scenario} lookup-unresolved");
                1
            },
            Result::Ok(wp) => {
                scenario_wire_cbor(wp)
            },
        }
    } else {
        let found = lookup_with_retry("kv");
        match found {
            Result::Err(_) => {
                println(f"FAIL {scenario} lookup-unresolved");
                1
            },
            Result::Ok(kv) => {
                if scenario == "remote_ask" {
                    scenario_remote_ask(kv)
                } else {
                    if scenario == "remote_monitor_clean_exit" {
                        scenario_remote_monitor_clean_exit(kv)
                    } else {
                        if scenario == "remote_monitor_crash" {
                            scenario_remote_monitor_crash(kv)
                        } else {
                            if scenario == "remote_monitor_conn_drop" {
                                scenario_remote_monitor_conn_drop(kv)
                            } else {
                                if scenario == "remote_monitor_setup_after_drop" {
                                    scenario_remote_monitor_setup_after_drop(kv)
                                } else {
                                    if scenario == "partition_ask" {
                                        scenario_partition_ask(kv)
                                    } else {
                                        if scenario == "stale_ref" {
                                            scenario_stale_ref(kv)
                                        } else {
                                            if scenario == "monitor_watcher_node_death" {
                                                scenario_client_watcher_node_death(kv)
                                            } else {
                                                if scenario == "link_remote_clean_exit" {
                                                    scenario_link_remote_clean_exit(kv)
                                                } else {
                                                    if scenario == "link_remote_crash" {
                                                        scenario_link_remote_crash(kv)
                                                    } else {
                                                        if scenario == "link_remote_partition" {
                                                            scenario_link_remote_partition(kv)
                                                        } else {
                                                            if scenario == "link_remote_non_crashlinked" {
                                                                scenario_link_remote_non_crashlinked(kv)
                                                            } else {
                                                                if scenario == "cross_node_monitor_close_reclaim" {
                                                                    scenario_client_monitor_close_reclaim(kv)
                                                                } else {
                                                                    println(f"FAIL {scenario} unknown-scenario");
                                                                    90
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
        }
    };
    Node::shutdown();
    status
}

fn main() -> i64 {
    let role = os.env("HEW_DIST_ROLE");
    let port = os.env("HEW_DIST_PORT");
    var scenario = os.env("HEW_DIST_SCENARIO");
    if scenario == "" {
        scenario = "remote_ask";
    }
    if role == "server" {
        run_server(port, scenario);
        0
    } else {
        if role == "client" {
            run_client(port, scenario)
        } else {
            println(f"FAIL config unknown-role={role}");
            99
        }
    }
}
