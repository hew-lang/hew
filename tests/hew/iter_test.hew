// ── count_str ──────────────────────────────────────────────────────────────

#[test]
fn test_count_str_prefix_match() {
    let v: Vec<String> = Vec::new();
    v.push("foo"); v.push("bar"); v.push("baz");
    testing.assert_eq(iter.count_str(v, (s: String) => s.starts_with("b")), 2);
}

#[test]
fn test_count_str_none_match() {
    let v: Vec<String> = Vec::new();
    v.push("foo"); v.push("qux");
    testing.assert_eq(iter.count_str(v, (s: String) => s.starts_with("z")), 0);
}

#[test]
fn test_count_str_empty_vec() {
    let v: Vec<String> = Vec::new();
    testing.assert_eq(iter.count_str(v, (s: String) => s.len() > 0), 0);
