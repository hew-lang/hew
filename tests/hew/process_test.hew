//! Tests for std::process argument handling.

import std::fs;
import std::process;
import std::string;
import std::testing;
import std::time::datetime;

fn cleanup_file(file_path: String) {
    if fs.exists(file_path) {
        fs.delete(file_path);
    }
}

fn kill_zero_exit_code(pid: String) -> int {
    let args: Vec<String> = Vec::new();
    args.push("-0");
    args.push(pid);
    process.run_argv("kill", args).exit_code
}

fn read_pid_with_retry(pid_path: String) -> String {
    var attempts = 0;
    while attempts < 50 {
        if fs.exists(pid_path) {
            return string.trim(fs.read(pid_path));
        }
        sleep_ms(100);
        attempts = attempts + 1;
    }
    panic("expected child to write its pid file");
    ""
}

#[test]
fn test_try_run_argv_preserves_spaced_and_empty_arguments() {
    let args: Vec<String> = Vec::new();
    args.push("<%s>|<%s>|<%s>");
    args.push("hello world");
    args.push("");
    args.push("tail");

    match process.try_run_argv("printf", args) {
        Ok(output) => {
            testing.assert_true(output.exit_code == 0);
            testing.assert_eq_str(output.stdout, "<hello world>|<>|<tail>");
            testing.assert_eq_str(output.stderr, "");
        },
        Err(_) => panic("expected try_run_argv to succeed"),
    }
}

#[test]
fn test_try_run_args_rejects_mismatched_arg_count_with_guidance() {
    match process.try_run_args("printf", "one two", 1) {
        Ok(_) => panic("expected arg_count mismatch"),
        Err(err) => match err {
            ProcessError::InvalidArguments(message) => {
                testing.assert_true(message.contains("arg_count"));
                testing.assert_true(message.contains("process.try_run_argv"));
            },
            _ => panic("expected ProcessError::InvalidArguments"),
        },
    }
}

#[test]
fn test_run_argv_replaces_legacy_run_args_usage() {
    let args: Vec<String> = Vec::new();
    args.push("<%s>|<%s>");
    args.push("alpha");
    args.push("beta");

    let output = process.run_argv("printf", args);
    testing.assert_true(output.exit_code == 0);
    testing.assert_eq_str(output.stdout, "<alpha>|<beta>");
    testing.assert_eq_str(output.stderr, "");
}

#[test]
fn test_try_run_argv_missing_command_returns_launch_failed() {
    let args: Vec<String> = Vec::new();

    match process.try_run_argv("hew-process-command-that-does-not-exist", args) {
        Ok(_) => panic("expected missing command error"),
        Err(err) => match err {
            ProcessError::LaunchFailed(_) => {},
            _ => panic("expected ProcessError::LaunchFailed"),
        },
    }
}

#[test]
fn test_child_drop_reaps_running_process() {
    let pid_path = f"tests/hew/_process_drop_{datetime.now_nanos()}.pid";
    cleanup_file(pid_path);

    {
        let child = process.start(f"echo $$ > {pid_path}; sleep 60");
        let pid = read_pid_with_retry(pid_path);
        testing.assert_true(kill_zero_exit_code(pid) == 0);
    }

    let pid = string.trim(fs.read(pid_path));
    var attempts = 0;
    var reaped = false;
    while attempts < 50 {
        if kill_zero_exit_code(pid) != 0 {
            reaped = true;
            break;
        }
        sleep_ms(100);
        attempts = attempts + 1;
    }

    cleanup_file(pid_path);
    testing.assert_true(reaped);
}
