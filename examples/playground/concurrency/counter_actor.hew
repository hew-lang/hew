//! @name Counter Actor
//! @description A simple actor that counts messages

actor Counter {
    let count: i64;

    receive fn increment(n: i64) -> i64 {
        count = count + n;
        print("Count is now: ");
        println(count);
        count
    }
}

fn main() {
    let c = spawn Counter(count: 0);
    await c.increment(5);
    await c.increment(3);
    let total = c.increment(12);
    print("Final total: ");
    println(total);
}
