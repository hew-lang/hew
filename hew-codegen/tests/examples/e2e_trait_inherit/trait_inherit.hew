trait Animal {
    fn legs(val: Self) -> int;
}

trait Pet: Animal {
    fn name(val: Self) -> int;
}

type Dog {
    leg_count: int;
    name_id: int;
}

impl Animal for Dog {
    fn legs(d: Dog) -> int {
        return d.leg_count;
    }
}

impl Pet for Dog {
    fn name(d: Dog) -> int {
        return d.name_id;
    }
}

fn describe(p: dyn Pet) -> int {
    return p.legs() + p.name();
}

fn main() {
    let d = Dog { leg_count: 4, name_id: 10 };
    println(describe(d));
}
