// Enum payload values with Option<i64>
import std::option;

fn main() {
    // Option<i64> is the built-in "value or nothing" enum.
    let val1: Option<i64> = Some(42);
    let val2: Option<i64> = None;
    // match gives you full control over each case.
    match val1 {
        Some(x) => println(x),
        None => println("no value"),
    }
    // unwrap_or_int is the stdlib shortcut for a fallback value.
    println(option.unwrap_or_int(val1, 0));
    println(option.unwrap_or_int(val2, 99));
}
