// Negative test: multi-arm timed select should be rejected on WASM.
// Timed select with multiple arms enqueues asks before hew.select.first
// runs; without WASI clock_time_get the timeout cannot be implemented
// correctly, so the codegen must reject this pattern.
actor Responder {
    let value: int;
    receive fn get() -> int {
        value
    }
}

fn main() {
    let a = spawn Responder(value: 1);
    let b = spawn Responder(value: 2);
    let result = select {
        x from a.get() => x,
        y from b.get() => y,
        after 100ms => -1,
    };
    println(result);
}
