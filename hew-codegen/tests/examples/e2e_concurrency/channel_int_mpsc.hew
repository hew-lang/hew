import std::channel::channel;

fn producer(tx: Sender, base: int) {
    tx.send(base + 1);
    tx.send(base + 2);
    tx.close();
}

fn main() {
    let (tx, rx) = channel.new(8);
    let tx2 = tx.clone();

    // Two producers send distinct integer ranges.
    producer(tx, 100);
    producer(tx2, 200);

    // Drain all messages and print.
    var count: int = 0;
    var done = false;
    while !done {
        match rx.recv() {
            Some(val) => {
                let v: int = val;
                println(v);
                count = count + 1;
            },
            None => { done = true; },
        }
    }

    println(count);
    rx.close();
}
