#[test]
fn test_count_f64_none_match() {
    let v: Vec<f64> = Vec::new();
    v.push(-1.0); v.push(-2.0);
    testing.assert_eq(iter.count_f64(v, (x: f64) => x > 0.0), 0);
}

#[test]
fn test_count_f64_empty_vec() {
    let v: Vec<f64> = Vec::new();
    testing.assert_eq(iter.count_f64(v, (x: f64) => x > 0.0), 0);
}

// ── product ────────────────────────────────────────────────────────────────

#[test]
fn test_product_three_elements() {
    let v: Vec<int> = Vec::new();
    v.push(2); v.push(3); v.push(4);
    testing.assert_eq(iter.product(v), 24);
}

#[test]
fn test_product_empty_vec_returns_one() {
    let v: Vec<int> = Vec::new();
    testing.assert_eq(iter.product(v), 1);
}

#[test]
fn test_product_single_element() {
    let v: Vec<int> = Vec::new();
    v.push(7);
    testing.assert_eq(iter.product(v), 7);
}

