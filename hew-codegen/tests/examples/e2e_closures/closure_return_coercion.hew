// Test closure return-type coercion: a closure returning i32
// (e.g. string.len()) is passed where fn(string) -> int (i64) is expected.
// The codegen must widen the return value automatically.

fn apply(f: fn(string) -> int, s: string) -> int {
    f(s)
}

fn main() {
    // Closure stored in a variable infers i32 from string.len(),
    // then coerced to fn(string) -> int (i64) at the call site.
    let len_fn = (s: string) => s.len();
    let result = apply(len_fn, "hello");
    println(f"{result}");
}
