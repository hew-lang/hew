// Stress test: Mass actor spawn
// Spawns 500 worker actors, each sends done() to a collector.
// Exercises: high actor count, fan-in message pattern, scheduler load.
actor Collector {
    let count: int;
    receive fn done() {
        count = count + 1;
    }
    receive fn get_count() -> int {
        count
    }
}

actor Worker {
    let id: int;
    let collector: Collector;
    receive fn work() {
        collector.done();
    }
}

fn main() {
    let collector = spawn Collector(count: 0);
    for i in 0..500 {
        let worker_id: int = i;
        let w = spawn Worker(id: worker_id, collector: collector);
        w.work();
        // await close(w) drains the worker's mailbox before the next iteration,
        // guaranteeing collector.done() has been enqueued before we proceed.
        // This replaces the timing-sensitive sleep_ms barrier.
        await close(w);
    }
    let count = await collector.get_count();
    println(count);
}
