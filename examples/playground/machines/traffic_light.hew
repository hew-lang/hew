//! @name Traffic Light
//! @description A traffic signal state machine

machine TrafficLight {
    events {
        Tick;
    }

    state Red;
    state Green;
    state Yellow;

    on Tick: Red => Green {
        Green
    }
    on Tick: Green => Yellow {
        Yellow
    }
    on Tick: Yellow => Red {
        Red
    }
}
