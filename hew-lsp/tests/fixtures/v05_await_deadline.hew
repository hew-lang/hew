// LSP smoke fixture for `await expr | after duration` deadline forms.
//
// Exercises Expr::Await(Expr::Timeout { … }) parse paths without requiring
// std::net — uses actor ask so the fixture is self-contained.
actor Responder {
    receive fn ask(value: i32) -> i32 {
        value
    }
}

fn await_deadline_probe() -> i32 {
    7
}

fn await_deadline_coverage() -> i32 {
    let r = spawn Responder;
    let _result = match await r.ask(1) | after 5000ms {
        Ok(v) => v,
        Err(_e) => await_deadline_probe(),
    };
    await_deadline_probe()
}
