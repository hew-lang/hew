// Negative test: passing a block expression that yields a field to print()
// where the field type implements Display must be rejected.  The block
// `{ holder.greeting }` yields holder.greeting in value position; without
// field-alias / partial-move tracking, Display::fmt would consume the field,
// then the caller's scope-exit drop of holder would drop greeting a second
// time → double-free.
type Greeting {
    text: string;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> string {
        val.text
    }
}

type Holder {
    greeting: Greeting;
}

fn main() {
    let holder = Holder { greeting: Greeting { text: "hello" } };
    print({ holder.greeting });
}
