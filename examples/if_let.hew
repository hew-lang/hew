//! Status: aspirational (Hew roadmap: v0.6 stdlib/data-structure port plus codegen-rs parity)
//! Description: If Let example.

fn main() {
    let value = Some(5);
    let result = if let Some(x) = value {
        x
    } else {
        0
    };
    if let Some(x) = Some(result) {
        println(x);
    } else {
        println(0);
    }
}
