// Regression: to_string({ g }) where the type has a Display impl.
// The block wrapper yields the owned identifier; Display::fmt consumes it, so
// caller-side drop registration for `g` must be removed after the call.
pub type Greeting {
    who: String;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> String {
        "hello, " + val.who
    }
}

fn main() {
    let g = Greeting { who: "world" };
    let s = to_string({ g });
    println(s);
}
