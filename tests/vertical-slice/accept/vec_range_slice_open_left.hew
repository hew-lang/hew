// W3.013 S0 verify: open-left range-slice `xs[..b]` on Vec<i32>.
//
// MIR lowers open start to ConstI64(0); hew_vec_slice_range_i32(vec, 0, 3).
//
// xs = [10, 20, 30, 40, 50]
// xs[..3] = [10, 20, 30]  →  len = 3  →  exit 3
fn main() -> i64 {
    let xs: Vec<i32> = Vec::new();
    xs.push(10);
    xs.push(20);
    xs.push(30);
    xs.push(40);
    xs.push(50);
    let s: Vec<i32> = xs[..3];
    s.len()
}
