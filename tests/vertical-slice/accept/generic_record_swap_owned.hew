// Generic record swap that moves an owned string field across instantiations:
// `Pair<i64, string>` -> `Pair<string, i64>`. The returned generic owned record
// is dropped exactly once at the caller; the swap callee transfers ownership of
// the string into the new instantiation. 100k iterations surface a double-free
// (SIGSEGV) or a leak.
type Pair<A, B> {
    first: A;
    second: B;
}

fn swap<A, B>(p: Pair<A, B>) -> Pair<B, A> {
    Pair { first: p.second, second: p.first }
}

fn round(print_it: bool) -> i64 {
    let a = "owned";
    let b = "value";
    let label = a + "-" + b;
    let p = Pair { first: 1, second: label };
    let q = swap(p);
    if print_it {
        println(q.first);
    }
    q.second
}

fn main() -> i64 {
    var i: i64 = 0;
    while i < 100000 {
        round(i == 0);
        i = i + 1;
    }
    0
}
