// Regression: an actor state field whose semantic type is a user-Drop
// struct must (1) invoke the user's drop callback, then (2) recurse
// into the nested struct's owned subfields. The original open-coded
// per-actor state-drop only emitted (1) and stopped, so any owned
// subfield (here, `String` inside `Wrapper`) leaked at teardown.
//
// Routing through `emitFieldDropsForUserStruct` (which calls the user
// drop op then recurses via the same helper at MLIRGen.cpp:6814-6815)
// produces both prints below.
type Wrapper {
    name: String;
}

impl Drop for Wrapper {
    fn drop(w: Wrapper) {
        println(f"wrapper_drop:{w.name}");
    }
}

actor Holder {
    let w: Wrapper;
    init(arg: Wrapper) {
        w = arg;
    }
    receive fn ping() -> int {
        1
    }
}

fn main() {
    let s: String = f"alpha";
    let starter = Wrapper { name: s };
    let h = spawn Holder(arg: starter);
    let n = await h.ping();
    println(n);
    println("done");
}
