//! Status: aspirational (Hew roadmap: v0.6 concurrency surfaces plus codegen-rs parity)
//! Description: Actor call-and-await example with no used return value.

actor Messenger {
    receive fn print_message(msg: i64) -> i64 {
        println(msg);
        println(42);
        0
    }
}

fn main() {
    let messenger = spawn Messenger;
    await messenger.print_message(100);
    println(999);
}
