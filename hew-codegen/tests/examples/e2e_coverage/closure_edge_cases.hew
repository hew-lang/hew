// Test: Closure edge cases — closures returning closures, closures
// capturing mutable variables in sequence, higher-order functions.
// Exercises: MLIRGenExpr (lambda codegen), closure capture, higher-order fns.

fn make_adder(base: int) -> fn(int) -> int {
    (x: int) => base + x
}

fn make_multiplier(factor: int) -> fn(int) -> int {
    (x: int) => x * factor
}

fn apply(f: fn(int) -> int, val: int) -> int {
    f(val)
}

fn apply_twice(f: fn(int) -> int, val: int) -> int {
    f(f(val))
}

fn mutable_capture_sequence() -> int {
    var counter = 0;
    let inc = () => {
        counter = counter + 1;
        counter
    };
    inc();
    inc();
    inc();
    counter
}

fn capture_multiple_vars() -> int {
    let a = 10;
    let b = 20;
    let c = 30;
    let sum_all = () => a + b + c;
    sum_all()
}

fn closure_modifies_outer() -> int {
    var total = 0;
    let add_to = (n: int) => {
        total = total + n;
    };
    add_to(5);
    add_to(10);
    add_to(15);
    total
}

fn main() {
    // Higher-order: make_adder
    let add5 = make_adder(5);
    println(add5(10));
    println(add5(20));

    // Higher-order: make_multiplier
    let times3 = make_multiplier(3);
    println(times3(7));

    // Apply function
    println(apply(add5, 100));

    // Apply twice: add5(add5(0)) = 10
    println(apply_twice(make_adder(5), 0));

    // Mutable capture
    println(mutable_capture_sequence());

    // Capture multiple variables
    println(capture_multiple_vars());

    // Closure modifies outer
    println(closure_modifies_outer());
}
