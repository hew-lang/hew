//! Regression tests for record/enum-with-collection-field `Vec` push ownership.
//!
//! A record or enum whose field is a `Vec`/`HashMap`/`HashSet` is a valid owned
//! `Vec` element. Copy-in `.push` DEEP-CLONES the element so the outer `Vec`
//! owns its own storage and the live source keeps sole ownership of its heap
//! fields (and its scope-exit drop). Each test mutates the source AFTER the push
//! and asserts the stored element is unaffected — the copy-in property that
//! fails when the push aliases instead of deep-cloning, and a companion to the
//! memory-safety leak oracle that pins the source's exactly-once field drop.

import std::testing;

type Boxed {
    payload: [i64];
}

enum Reply {
    Nil;
    Num(i64);
    Arr([Reply]);
}

// ── record-with-Vec-field: copy-in independence ────────────────────────────

// Pushing the SAME record twice yields two independent clones, and mutating
// the source's collection field afterward leaves both stored clones intact.
#[test]
fn test_record_collection_field_push_is_copy_in() {
    var xs: [Boxed] = [];
    var src = Boxed { payload: [10, 20] };
    xs.push(src);
    xs.push(src);
    src.payload.push(30);
    testing.assert_eq(xs.len(), 2);
    let a = xs[0];
    let b = xs[1];
    testing.assert_eq(a.payload.len(), 2);
    testing.assert_eq(a.payload[0], 10);
    testing.assert_eq(a.payload[1], 20);
    testing.assert_eq(b.payload.len(), 2);
    testing.assert_eq(b.payload[1], 20);
    // The live source kept growing without disturbing the stored clones.
    testing.assert_eq(src.payload.len(), 3);
    testing.assert_eq(src.payload[2], 30);
}

// A freshly built source per push still yields the exact stored contents.
#[test]
fn test_record_collection_field_push_reads_back_exact() {
    var xs: [Boxed] = [];
    xs.push(Boxed { payload: [1, 2, 3] });
    xs.push(Boxed { payload: [4] });
    testing.assert_eq(xs.len(), 2);
    testing.assert_eq(xs[0].payload.len(), 3);
    testing.assert_eq(xs[0].payload[2], 3);
    testing.assert_eq(xs[1].payload.len(), 1);
    testing.assert_eq(xs[1].payload[0], 4);
}

// ── self-recursive enum (Redis/JSON reply shape) ───────────────────────────

// Pushing the nested-vec variant exercises the recursive enum clone/drop thunk
// through the inner `Vec<Reply>`; the stored length reflects each pushed value.
#[test]
fn test_self_recursive_enum_push() {
    var xs: [Reply] = [];
    xs.push(Reply::Num(7));
    xs.push(Reply::Arr([Reply::Nil, Reply::Num(9)]));
    testing.assert_eq(xs.len(), 2);
    let head = xs[0];
    match head {
        Reply::Num(n) => testing.assert_eq(n, 7),
        _ => testing.assert_true(false),
    }
}

// A live self-recursive-enum source pushed by value is deep-cloned; the source
// stays independently readable after the push.
#[test]
fn test_self_recursive_enum_live_source_push() {
    var xs: [Reply] = [];
    let src = Reply::Arr([Reply::Nil, Reply::Num(9)]);
    xs.push(src);
    xs.push(src);
    testing.assert_eq(xs.len(), 2);
    match src {
        Reply::Arr(items) => testing.assert_eq(items.len(), 2),
        _ => testing.assert_true(false),
    }
}
