// Regression test: nested struct containing only a handle field passed as an
// actor receive fn parameter. The inner regex.Pattern must transfer ownership
// to the receiver, be nulled in the sender recursively through the outer
// struct wrapper, and then be explicitly freed by the receiver.

import std::text::regex;

type Inner {
    pat: Pattern;
}

type Outer {
    inner: Inner;
}

actor Matcher {
    let matched: bool;
    let missed: bool;

    receive fn check(msg: Outer) {
        matched = msg.inner.pat.is_match("hello123");
        missed = msg.inner.pat.is_match("no digits");
        msg.inner.pat.free();
    }

    receive fn get_matched() -> bool {
        matched
    }

    receive fn get_missed() -> bool {
        missed
    }
}

fn main() {
    let m = spawn Matcher(matched: false, missed: false);
    {
        let msg = Outer { inner: Inner { pat: re"[0-9]+" } };
        m.check(msg);
        // msg was moved into check(); accessing msg.inner.pat after the move
        // is a compile-time use-of-moved-value error. The actor results below verify
        // the pattern was correctly transferred and used inside the actor.
    };
    println(await m.get_matched());
    println(await m.get_missed());
}
