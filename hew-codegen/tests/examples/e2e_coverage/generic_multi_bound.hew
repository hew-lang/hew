// Test: Multiple trait impls, dyn dispatch, and generic functions
// with multiple type parameters.
// Exercises: single-trait dyn dispatch on different types, cross-type
// dyn comparison, generic triple structures, monomorphisation.

trait Named {
    fn name(val: Self) -> string;
}

trait Scored {
    fn score(val: Self) -> int;
}

type Player {
    tag: string;
    points: int;
}

type Team {
    label: string;
    wins: int;
}

type Bot {
    id: int;
    rating: int;
}

impl Named for Player {
    fn name(p: Player) -> string { p.tag }
}
impl Scored for Player {
    fn score(p: Player) -> int { p.points }
}

impl Named for Team {
    fn name(t: Team) -> string { t.label }
}
impl Scored for Team {
    fn score(t: Team) -> int { t.wins }
}

impl Named for Bot {
    fn name(b: Bot) -> string { f"Bot-{b.id}" }
}
impl Scored for Bot {
    fn score(b: Bot) -> int { b.rating }
}

// dyn with single trait - Named
fn show_name(val: dyn Named) {
    println(val.name());
}

// dyn with single trait - Scored
fn show_score(val: dyn Scored) {
    println(val.score());
}

// dyn score comparison across different concrete types
fn higher_score(a: dyn Scored, b: dyn Scored) -> string {
    if a.score() > b.score() {
        "first"
    } else {
        if a.score() == b.score() {
            "tie"
        } else {
            "second"
        }
    }
}

// Generic triple wrapper
type Triple<A, B, C> {
    one: A;
    two: B;
    three: C;
}

fn make_triple<A, B, C>(a: A, b: B, c: C) -> Triple<A, B, C> {
    Triple { one: a, two: b, three: c }
}

fn main() {
    let p = Player { tag: "Alice", points: 150 };
    let t = Team { label: "Hawks", wins: 42 };
    let b = Bot { id: 7, rating: 88 };

    // dyn Named dispatch on three different types
    show_name(p);
    show_name(t);
    show_name(b);

    // dyn Scored dispatch
    show_score(Player { tag: "Carol", points: 200 });
    show_score(Team { label: "Eagles", wins: 38 });
    show_score(Bot { id: 3, rating: 95 });

    // Cross-type dyn score comparison
    println(higher_score(
        Player { tag: "X", points: 100 },
        Player { tag: "Y", points: 100 },
    ));
    println(higher_score(
        Player { tag: "Z", points: 50 },
        Team { label: "T", wins: 30 },
    ));
    println(higher_score(
        Bot { id: 1, rating: 999 },
        Player { tag: "W", points: 500 },
    ));

    // Generic triple with named types, then dispatch each via dyn
    let tri = make_triple<Player, Team, Bot>(
        Player { tag: "Dan", points: 10 },
        Team { label: "Wolves", wins: 20 },
        Bot { id: 1, rating: 30 },
    );
    show_name(tri.one);
    show_name(tri.two);
    show_name(tri.three);
    show_score(tri.one);
    show_score(tri.two);
    show_score(tri.three);
}
