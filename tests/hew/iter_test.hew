    testing.assert_true(result.get(1) == 2.0);
}

#[test]
fn test_take_f64_more_than_length_clamps() {
    let v: Vec<f64> = Vec::new();
    v.push(1.0); v.push(2.0);
    let result = iter.take_f64(v, 100);
    testing.assert_eq(result.len(), 2);
}

#[test]
fn test_take_f64_zero_returns_empty() {
    let v: Vec<f64> = Vec::new();
    v.push(1.0);
    let result = iter.take_f64(v, 0);
    testing.assert_eq(result.len(), 0);
}

