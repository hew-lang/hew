// Regression: an actor whose state holds a plain struct (no `impl Drop`)
// with an owned field (e.g. `String`) must release that owned field when
// the actor is killed.
//
// Before routing the per-actor state-drop body through the shared
// `emitFieldDropsForUserStruct` helper, the open-coded actor loop emitted
// `hew::DropOp` with the literal sentinel `__auto_field_drop` as a
// callee. That sentinel is not a real symbol — the helper interprets it
// as "recurse into nested fields" — so the open-coded path produced an
// `unreconciled unrealized_conversion_cast` build failure (or, after
// lowering rewrites, a link error against `__auto_field_drop`). Routing
// through the helper resolves the sentinel by recursion, so the program
// builds, runs, and the inner `String` field is released by
// `hew_string_drop` at teardown.
//
// The expected output is just the program output; resource release is
// tracked by ASAN/LSAN in CI rather than printed.
type Holder {
    text: String;
}

actor Owner {
    let holder: Holder;
    init(h: Holder) {
        holder = h;
    }
    receive fn ping() -> int {
        1
    }
}

fn main() {
    let s: String = f"auto-field-drop-ok";
    let h = Holder { text: s };
    let a = spawn Owner(h: h);
    let n = await a.ping();
    println(n);
    println("done");
}
