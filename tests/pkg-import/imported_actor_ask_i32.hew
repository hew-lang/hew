// Imported-actor ask replying i32: the ask site must register the
// Result<i32, AskError> layout in the importing crate.
import hew::testffi;

fn main() {
    let db = spawn testffi.Db(seed: 7);
    match await db.count32() {
        Ok(v) => println(f"count32={v}"),
        Err(_) => println("ask failed"),
    }
}
