// Test: wire encode/decode roundtrip with string fields survives buf free
#[wire]
struct Greeting {
    name: string,
    message: string,
}

fn main() {
    let g = Greeting { name: "Alice", message: "hello" };
    let buf = g.encode();
    let g2 = Greeting.decode(buf);
    println(g2.to_json());
}
