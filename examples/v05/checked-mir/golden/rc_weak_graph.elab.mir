    eval site=SiteId(6) ty=()
    use BindingId(1) weak site=SiteId(13) ty=Weak<Node> intent=Read
    return site=Some(SiteId(13)) ty=Weak<Node>
    drop BindingId(0) root ty=Rc<Node>
  drop_plans:
    return[bb0] ->
      drop _5 ty=Rc<Node> kind=rc_release guard=_6

