/// Generic free functions exported from a separate module group.
/// The caller invokes these via the module-qualified form
/// (e.g. `genericlib.identity<int>(x)`), which exercises the
/// cross-module monomorphization path that consumes the checker's
/// `call_type_args` side table.
pub fn identity<T>(x: T) -> T {
    x
}

pub fn pick_first<A, B>(a: A, b: B) -> A {
    b; // discard b
    a
}
