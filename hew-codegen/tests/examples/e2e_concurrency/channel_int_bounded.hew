import std::channel::channel;

fn main() {
    // Capacity-1 channel: each send blocks until the previous message
    // is consumed, verifying backpressure behaviour.
    let (tx, rx) = channel.new(1);

    tx.send(42);
    match rx.recv() {
        Some(first) => println(first),
        None => println("unexpected none"),
    }

    tx.send(99);
    match rx.recv() {
        Some(second) => println(second),
        None => println("unexpected none"),
    }

    tx.close();

    // After closing, recv should return None.
    match rx.recv() {
        Some(v) => println(v),
        None => println("none"),
    }

    rx.close();
}
