// Error handling with Result types
// Result<T, E> is a built-in enum — no import needed.
fn parse_number(s: string) -> Result<i64, string> {
    if s == "42" {
        Ok(42)
    } else {
        Err("Invalid number")
    }
}

fn is_ok(r: Result<i64, i64>) -> bool {
    match r {
        Ok(_) => true,
        Err(_) => false,
    }
}

fn is_err(r: Result<i64, i64>) -> bool {
    match r {
        Ok(_) => false,
        Err(_) => true,
    }
}

fn unwrap_or(r: Result<i64, i64>, fallback: i64) -> i64 {
    match r {
        Ok(v) => v,
        Err(_) => fallback,
    }
}

fn main() {
    let parsed = parse_number("42");
    let failed = parse_number("oops");
    // match is the clearest way to handle a Result.
    match parsed {
        Ok(n) => println(n),
        Err(msg) => println(msg),
    }
    match failed {
        Ok(n) => println(n),
        Err(msg) => println(msg),
    }
    // Helper functions show common Result<i64, i64> patterns.
    let helper_ok: Result<i64, i64> = Ok(42);
    let helper_err: Result<i64, i64> = Err(-1);
    println(is_ok(helper_ok));
    println(is_err(helper_err));
    println(unwrap_or(helper_ok, 0));
    println(unwrap_or(helper_err, -1));
}
