// W3.013 S0 verify: closed range-slice `xs[a..b]` on Vec<i32>.
//
// Exercises the full C-3 path:
//   checker  synthesize_index range arm  → Vec<i32> (Ty::Named{Vec})
//   HIR      HirExprKind::Slice{ start=Some, end=Some, inclusive=false }
//   MIR      lower_vec_slice → hew_vec_slice_range_i32(vec, 1, 3)
//   runtime  allocates a fresh HewVec containing [20, 30]
//
// Vec<i32> is used because the stdlib_catalog currently registers
// hew_vec_push_i32 (and not hew_vec_push_i64); the range-slice MIR lowering
// covers both i32 and i64 via the same dispatch arm.
//
// xs = [10, 20, 30, 40, 50]
// xs[1..3] = [20, 30]  →  len = 2  →  exit 2
fn main() -> i64 {
    let xs: Vec<i32> = Vec::new();
    xs.push(10);
    xs.push(20);
    xs.push(30);
    xs.push(40);
    xs.push(50);
    let s: Vec<i32> = xs[1..3];
    s.len()
}
