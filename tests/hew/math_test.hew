//! Tests for generic std::math helpers.
import std::math;
import std::testing;

#[test]
fn test_abs_dispatches_by_numeric_type() {
    let i: i64 = -5;
    let f: f64 = -5.5;
    testing.assert_true(math.abs(i) == 5);
    testing.assert_true(math.abs(f) == 5.5);
}

#[test]
fn test_min_returns_the_smaller_value() {
    testing.assert_true(math.min(3, 7) == 3);
    testing.assert_true(math.min(3.5, 1.25) == 1.25);
}

#[test]
fn test_max_returns_the_larger_value() {
    testing.assert_true(math.max(3, 7) == 7);
    testing.assert_true(math.max(3.5, 1.25) == 3.5);
}

#[test]
fn test_clamp_honors_valid_interval() {
    testing.assert_eq(math.clamp(8, 0, 5), 5);
}

#[test]
#[should_panic]
fn test_clamp_rejects_reversed_interval() {
    math.clamp(5, 10, 0);
}
