// Golden test: enum definition, variant construction, match
// Exercises: EnumConstructOp, EnumExtractTagOp, EnumExtractPayloadOp
enum Colour {
    Red;
    Green;
    Blue;
}

enum Shape {
    Circle(int);
    Rectangle(int);
}

fn colour_to_int(c: Colour) -> int {
    match c {
        Red => 1,
        Green => 2,
        Blue => 3,
        _ => 0,
    }
}

fn shape_area(s: Shape) -> int {
    match s {
        Circle(r) => r * r,
        Rectangle(side) => side * side,
        _ => 0,
    }
}

fn main() {
    // Unit variants
    println(colour_to_int(Red));
    println(colour_to_int(Green));
    println(colour_to_int(Blue));

    // Payload variants + destructuring
    let c = Circle(5);
    println(shape_area(c));

    let rect = Rectangle(4);
    println(shape_area(rect));

    // Match as expression
    let s = Circle(3);
    let val = match s {
        Circle(r) => r * 10,
        Rectangle(side) => side,
        _ => -1,
    };
    println(val);
}
