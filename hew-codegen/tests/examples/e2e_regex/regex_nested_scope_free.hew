// Regression: explicit .free() on a regex.Pattern defined inside a nested SCF
// region remains safe and leak-free.
import std::text::regex;

fn test() -> bool {
    // always-true branch: defOp for `re` lives inside this nested SCF region
    if true {
        let re = regex.new("[0-9]+");
        let matched = re.is_match("abc42");
        re.free();
        matched
    } else {
        false
    }
}

fn main() {
    println(test());
    println(test());
    println(test());
    println("ok");
}
