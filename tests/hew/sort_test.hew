//! Tests for std::sort — sort_ints, sort_strings, sort_floats and the
//! reverse_* family. Each function returns a new vector; the original
//! is never mutated.

import std::sort;
import std::testing;

// ── sort_ints ─────────────────────────────────────────────────────────

#[test]
fn test_sort_ints_ascending_order() {
    let v: Vec<i64> = Vec::new();
    v.push(3);
    v.push(1);
    v.push(4);
    v.push(1);
    v.push(5);
    let out = sort.sort_ints(v);
    testing.assert_eq(out.len(), 5);
    testing.assert_eq(out[0], 1);
    testing.assert_eq(out[1], 1);
    testing.assert_eq(out[2], 3);
    testing.assert_eq(out[3], 4);
    testing.assert_eq(out[4], 5);
}

#[test]
fn test_sort_ints_does_not_mutate_original() {
    let v: Vec<i64> = Vec::new();
    v.push(9);
    v.push(3);
    v.push(7);
    sort.sort_ints(v);
    testing.assert_eq(v[0], 9);
    testing.assert_eq(v[1], 3);
    testing.assert_eq(v[2], 7);
}

#[test]
fn test_sort_ints_already_sorted() {
    let v: Vec<i64> = Vec::new();
    v.push(1);
    v.push(2);
    v.push(3);
    let out = sort.sort_ints(v);
    testing.assert_eq(out[0], 1);
    testing.assert_eq(out[1], 2);
    testing.assert_eq(out[2], 3);
}

#[test]
fn test_sort_ints_reverse_sorted_input() {
    let v: Vec<i64> = Vec::new();
    v.push(5);
    v.push(4);
    v.push(3);
    v.push(2);
    v.push(1);
    let out = sort.sort_ints(v);
    testing.assert_eq(out[0], 1);
    testing.assert_eq(out[4], 5);
}

#[test]
fn test_sort_ints_single_element() {
    let v: Vec<i64> = Vec::new();
    v.push(42);
    let out = sort.sort_ints(v);
    testing.assert_eq(out.len(), 1);
    testing.assert_eq(out[0], 42);
}

#[test]
fn test_sort_ints_empty() {
    let v: Vec<i64> = Vec::new();
    let out = sort.sort_ints(v);
    testing.assert_eq(out.len(), 0);
}

#[test]
fn test_sort_ints_negative_values() {
    let v: Vec<i64> = Vec::new();
    v.push(0);
    v.push(-5);
    v.push(3);
    v.push(-2);
    let out = sort.sort_ints(v);
    testing.assert_eq(out[0], -5);
    testing.assert_eq(out[1], -2);
    testing.assert_eq(out[2], 0);
    testing.assert_eq(out[3], 3);
}

#[test]
fn test_sort_ints_comparison_bound_1024_reverse() {
    let v: Vec<i64> = Vec::new();
    for i in 0 .. 1024 {
        v.push(1023 - i);
    }

    let (out, comparisons) = sort.sort_ints_counted(v);

    // n * ceil(log2(n)) is a deterministic upper bound for the production
    // merge core. Selection sort performs 523,776 comparisons here.
    testing.assert_true(comparisons <= 1024 * 10);
    testing.assert_eq(out.len(), 1024);
    for i in 0 .. 1024 {
        testing.assert_eq(out[i], i);
        testing.assert_eq(v[i], 1023 - i);
    }
}

#[test]
fn test_sort_ints_non_power_of_two_permutation_and_equal_values() {
    let v: Vec<i64> = Vec::new();
    for i in 0 .. 17 {
        v.push((i * 7) % 5);
    }
    let out = sort.sort_ints(v);

    testing.assert_eq(out.len(), 17);
    for i in 1 .. out.len() {
        testing.assert_true(out[i - 1] <= out[i]);
    }
    var input_sum = 0;
    var output_sum = 0;
    var input_squares = 0;
    var output_squares = 0;
    for i in 0 .. 17 {
        input_sum = input_sum + v[i];
        output_sum = output_sum + out[i];
        input_squares = input_squares + v[i] * v[i];
        output_squares = output_squares + out[i] * out[i];
        testing.assert_eq(v[i], (i * 7) % 5);
    }
    testing.assert_eq(output_sum, input_sum);
    testing.assert_eq(output_squares, input_squares);

    let equal: Vec<i64> = Vec::new();
    for _i in 0 .. 33 {
        equal.push(7);
    }
    let equal_out = sort.sort_ints(equal);
    for i in 0 .. 33 {
        testing.assert_eq(equal_out[i], 7);
        testing.assert_eq(equal[i], 7);
    }
}

// ── sort_strings ──────────────────────────────────────────────────────

#[test]
fn test_sort_strings_alphabetical_order() {
    let v: Vec<string> = Vec::new();
    v.push("banana");
    v.push("apple");
    v.push("cherry");
    let out = sort.sort_strings(v);
    testing.assert_eq(out.len(), 3);
    testing.assert_eq_str(out[0], "apple");
    testing.assert_eq_str(out[1], "banana");
    testing.assert_eq_str(out[2], "cherry");
}

#[test]
fn test_sort_strings_does_not_mutate_original() {
    let v: Vec<string> = Vec::new();
    v.push("zebra");
    v.push("ant");
    sort.sort_strings(v);
    testing.assert_eq_str(v[0], "zebra");
    testing.assert_eq_str(v[1], "ant");
}

#[test]
fn test_sort_strings_single_element() {
    let v: Vec<string> = Vec::new();
    v.push("only");
    let out = sort.sort_strings(v);
    testing.assert_eq(out.len(), 1);
    testing.assert_eq_str(out[0], "only");
}

#[test]
fn test_sort_strings_empty() {
    let v: Vec<string> = Vec::new();
    let out = sort.sort_strings(v);
    testing.assert_eq(out.len(), 0);
}

#[test]
fn test_sort_strings_duplicate_entries() {
    let v: Vec<string> = Vec::new();
    v.push("b");
    v.push("a");
    v.push("b");
    let out = sort.sort_strings(v);
    testing.assert_eq_str(out[0], "a");
    testing.assert_eq_str(out[1], "b");
    testing.assert_eq_str(out[2], "b");
}

#[test]
fn test_sort_strings_comparison_bound_256_duplicate_reverse() {
    let v: Vec<string> = Vec::new();
    for i in 0 .. 256 {
        let key = match i % 8 {
            0 => "hotel",
            1 => "golf",
            2 => "foxtrot",
            3 => "echo",
            4 => "delta",
            5 => "charlie",
            6 => "bravo",
            _ => "alpha",
        };
        v.push(key);
    }

    let (out, comparisons) = sort.sort_strings_counted(v);

    // n * ceil(log2(n)) is a deterministic upper bound for the production
    // merge core. Selection sort performs 32,640 comparisons here.
    testing.assert_true(comparisons <= 256 * 8);
    testing.assert_eq(out.len(), 256);
    for i in 1 .. 256 {
        testing.assert_true(out[i - 1] <= out[i]);
    }
    for i in 0 .. 32 {
        testing.assert_eq_str(out[i], "alpha");
        testing.assert_eq_str(out[32 + i], "bravo");
        testing.assert_eq_str(out[64 + i], "charlie");
        testing.assert_eq_str(out[96 + i], "delta");
        testing.assert_eq_str(out[128 + i], "echo");
        testing.assert_eq_str(out[160 + i], "foxtrot");
        testing.assert_eq_str(out[192 + i], "golf");
        testing.assert_eq_str(out[224 + i], "hotel");
    }
    testing.assert_eq_str(v[0], "hotel");
    testing.assert_eq_str(v[7], "alpha");
    testing.assert_eq_str(v[248], "hotel");
    testing.assert_eq_str(v[255], "alpha");
}

// ── sort_floats ───────────────────────────────────────────────────────

#[test]
fn test_sort_floats_ascending_order() {
    let v: Vec<f64> = Vec::new();
    v.push(3.5);
    v.push(1.25);
    v.push(2.0);
    let out = sort.sort_floats(v);
    testing.assert_eq(out.len(), 3);
    testing.assert_true(out[0] == 1.25);
    testing.assert_true(out[1] == 2.0);
    testing.assert_true(out[2] == 3.5);
}

#[test]
fn test_sort_floats_negative_values() {
    let v: Vec<f64> = Vec::new();
    v.push(1.0);
    v.push(-3.0);
    v.push(0.5);
    v.push(-1.5);
    let out = sort.sort_floats(v);
    testing.assert_true(out[0] == -3.0);
    testing.assert_true(out[1] == -1.5);
    testing.assert_true(out[2] == 0.5);
    testing.assert_true(out[3] == 1.0);
}

#[test]
fn test_sort_floats_single_element() {
    let v: Vec<f64> = Vec::new();
    v.push(9.9);
    let out = sort.sort_floats(v);
    testing.assert_eq(out.len(), 1);
    testing.assert_true(out[0] == 9.9);
}

#[test]
fn test_sort_floats_empty() {
    let v: Vec<f64> = Vec::new();
    let out = sort.sort_floats(v);
    testing.assert_eq(out.len(), 0);
}

// ── reverse_ints ──────────────────────────────────────────────────────

#[test]
fn test_reverse_ints_three_elements() {
    let v: Vec<i64> = Vec::new();
    v.push(1);
    v.push(2);
    v.push(3);
    let out = sort.reverse_ints(v);
    testing.assert_eq(out[0], 3);
    testing.assert_eq(out[1], 2);
    testing.assert_eq(out[2], 1);
}

#[test]
fn test_reverse_ints_does_not_mutate_original() {
    let v: Vec<i64> = Vec::new();
    v.push(1);
    v.push(2);
    v.push(3);
    sort.reverse_ints(v);
    testing.assert_eq(v[0], 1);
}

#[test]
fn test_reverse_ints_single_element() {
    let v: Vec<i64> = Vec::new();
    v.push(7);
    let out = sort.reverse_ints(v);
    testing.assert_eq(out.len(), 1);
    testing.assert_eq(out[0], 7);
}

#[test]
fn test_reverse_ints_empty() {
    let v: Vec<i64> = Vec::new();
    let out = sort.reverse_ints(v);
    testing.assert_eq(out.len(), 0);
}

#[test]
fn test_reverse_then_sort_round_trips() {
    let v: Vec<i64> = Vec::new();
    v.push(3);
    v.push(1);
    v.push(2);
    let sorted = sort.sort_ints(v);
    let reversed = sort.reverse_ints(sorted);
    let re_sorted = sort.sort_ints(reversed);
    testing.assert_eq(re_sorted[0], 1);
    testing.assert_eq(re_sorted[1], 2);
    testing.assert_eq(re_sorted[2], 3);
}

// ── reverse_strings ───────────────────────────────────────────────────

#[test]
fn test_reverse_strings_three_elements() {
    let v: Vec<string> = Vec::new();
    v.push("a");
    v.push("b");
    v.push("c");
    let out = sort.reverse_strings(v);
    testing.assert_eq_str(out[0], "c");
    testing.assert_eq_str(out[1], "b");
    testing.assert_eq_str(out[2], "a");
}

#[test]
fn test_reverse_strings_single_element() {
    let v: Vec<string> = Vec::new();
    v.push("solo");
    let out = sort.reverse_strings(v);
    testing.assert_eq(out.len(), 1);
    testing.assert_eq_str(out[0], "solo");
}

#[test]
fn test_reverse_strings_empty() {
    let v: Vec<string> = Vec::new();
    let out = sort.reverse_strings(v);
    testing.assert_eq(out.len(), 0);
}

// ── reverse_floats ────────────────────────────────────────────────────

#[test]
fn test_reverse_floats_three_elements() {
    let v: Vec<f64> = Vec::new();
    v.push(1.0);
    v.push(2.5);
    v.push(3.0);
    let out = sort.reverse_floats(v);
    testing.assert_true(out[0] == 3.0);
    testing.assert_true(out[1] == 2.5);
    testing.assert_true(out[2] == 1.0);
}

#[test]
fn test_reverse_floats_single_element() {
    let v: Vec<f64> = Vec::new();
    v.push(4.4);
    let out = sort.reverse_floats(v);
    testing.assert_eq(out.len(), 1);
    testing.assert_true(out[0] == 4.4);
}

#[test]
fn test_reverse_floats_empty() {
    let v: Vec<f64> = Vec::new();
    let out = sort.reverse_floats(v);
    testing.assert_eq(out.len(), 0);
}
