// Test: Actor Lifecycle
// Exercises: Actor init, message processing, state evolution
actor Accumulator {
    let total: int;
    receive fn add(n: int) {
        total = total + n;
        println(f"Added {n}, total = {total}");
    }
    receive fn multiply(n: int) {
        total = total * n;
        println(f"Multiplied by {n}, total = {total}");
    }
    receive fn report() -> int {
        total
    }
}

fn main() {
    println("=== Actor Lifecycle ===");
    let acc = spawn Accumulator(total: 0);
    acc.add(5);
    acc.add(3);
    acc.multiply(2);
    acc.add(4);
    acc.multiply(3);
    await acc.report();
    // Expected: 0 + 5 = 5, + 3 = 8, * 2 = 16, + 4 = 20, * 3 = 60
    println("Done");
}
