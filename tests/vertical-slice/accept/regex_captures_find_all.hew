import std::text::regex;
import std::string;

fn main() {
    let words = regex.new("[a-z]+");
    let hits = words.find_all("12ab34cd");
    println(string.join(hits, ","));
    let misses = words.find_all("1234");
    println(f"misses={misses.len()}");
    words.close();

    let one = regex.new("([a-z]+)-(?P<num>[0-9]+)");
    match one.capture("abc-123", 1) {
        Some(word) => println(word),
        None => println("missing"),
    }
    match one.capture_named("abc-123", "num") {
        Some(num) => println(num),
        None => println("missing"),
    }
    match one.capture("abc-123", 99) {
        Some(value) => println(value),
        None => println("missing-index"),
    }
    match one.capture_named("abc-123", "missing") {
        Some(value) => println(value),
        None => println("missing-name"),
    }
    let first = one.captures("abc-123");
    println(f"first_rows={first.len()} first_width={first.width()}");
    match first.whole(0) {
        Some(value) => println(value),
        None => println("missing-whole"),
    }
    one.close();

    let many = regex.new("([a-z]+)([0-9]+)");
    let rows = many.find_all_submatch("a1 b22");
    println(f"rows={rows.len()} width={rows.width()}");
    match rows.group(1, 2) {
        Some(value) => println(value),
        None => println("missing-group"),
    }
    match rows.group(4, 0) {
        Some(value) => println(value),
        None => println("missing-row"),
    }
    many.close();
}
