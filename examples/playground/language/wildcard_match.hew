//! @name Wildcard Match
//! @description Enum dispatch with a catch-all wildcard arm

enum Signal { Go; Stop; Wait; Unknown; }

fn describe(s: Signal) -> string {
    match s {
        Go => "proceed",
        Stop => "halt",
        _ => "hold",
    }
}

fn main() {
    println(describe(Go));
    println(describe(Stop));
    println(describe(Wait));
    println(describe(Unknown));
}
