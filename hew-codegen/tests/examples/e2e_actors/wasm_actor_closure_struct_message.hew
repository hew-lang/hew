// WASM parity test: struct containing a closure field passed as an
// actor receive fn parameter.  Exercises deep-copy of closure env
// (hew_rc_clone on the env ptr) inside a struct at the actor boundary.
// WASM variant of test_actor_closure_struct_message.hew (no sleep_ms).
type Job {
    id: int;
    action: fn(int) -> int;
}

actor Runner {
    let last: int;

    receive fn run(job: Job) {
        {
            let f = job.action;
            println(f(job.id));
        };
        let g = job.action;
        last = g(job.id);
    }

    receive fn get_last() -> int {
        last
    }
}

fn main() {
    let offset = 100;
    let r = spawn Runner(last: 0);
    let action = (x: int) -> int => x + offset;
    let j = Job { id: 5, action: action };
    r.run(j);
    let v = await r.get_last();
    println(v);
}
