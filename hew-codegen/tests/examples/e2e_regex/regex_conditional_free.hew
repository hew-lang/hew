// Regression: explicit .free() in either branch of a conditional keeps both
// code paths safe and leak-free.
import std::text::regex;

fn test(use_digits: bool) -> bool {
    if use_digits {
        let re = regex.new("[0-9]+");
        let matched = re.is_match("abc42");
        re.free();
        matched
    } else {
        let re = regex.new("^abc");
        let matched = re.is_match("abc42");
        re.free();
        matched
    }
}

fn main() {
    println(test(true));
    println(test(false));
    println(test(true));
    println("ok");
}
