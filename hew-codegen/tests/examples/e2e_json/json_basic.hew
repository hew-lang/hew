// Test: parse a JSON string, access fields, print values.
import std::encoding::json;

fn main() {
    let val = json.parse("{\"name\": \"Hew\", \"version\": 1, \"active\": true}");

    // Access string field
    let name = val.get_field("name");
    println(name.get_string());

    // Access integer field
    let ver = val.get_field("version");
    println(ver.get_int());

    // Access boolean field
    let active = val.get_field("active");
    println(active.get_bool());

    // Stringify the whole object
    let s = val.stringify();
    println(s);

    println("=== Done ===");
}
