//! Regression tests for nested-collection `Vec` push ownership (#1722).
//!
//! `Vec<Vec<T>>` / `Vec<HashMap<..>>` / `Vec<HashSet<..>>` push must DEEP-COPY
//! the element (COPY-IN) so the outer `Vec` owns its own storage. Before the
//! fix the push stored the caller's inner-collection handle verbatim, so a
//! reused/cleared accumulator aliased every already-pushed row to one backing
//! store: a later `clear()` silently emptied stored rows and the outer free
//! double-freed the shared backing. Each test mutates the source AFTER the push
//! and asserts the stored element is unaffected — the property that fails when
//! the push aliases instead of copies.

import std::testing;

// ── Vec<Vec<string>>: the canonical CSV row-builder shape ──────────────────

// Reuse-then-`clear()`: the stored first row must keep its own cells after the
// accumulator is cleared and refilled. Pre-fix `cur.clear()` emptied row 0.
#[test]
fn test_vec_vec_string_reuse_keeps_each_row() {
    let rows: Vec<Vec<string>> = Vec::new();
    let cur: Vec<string> = Vec::new();
    cur.push("alpha");
    cur.push("beta");
    rows.push(cur);
    cur.clear();
    cur.push("gamma");
    rows.push(cur);

    testing.assert_eq(rows.len(), 2);
    let r0 = rows[0];
    testing.assert_eq(r0.len(), 2);
    testing.assert_eq_str(r0[0], "alpha");
    testing.assert_eq_str(r0[1], "beta");
    let r1 = rows[1];
    testing.assert_eq(r1.len(), 1);
    testing.assert_eq_str(r1[0], "gamma");
}

// Pushing the SAME accumulator twice must yield two independent rows, so a
// later mutation of the source leaves both stored rows intact.
#[test]
fn test_vec_vec_string_push_same_source_twice_is_independent() {
    let rows: Vec<Vec<string>> = Vec::new();
    let cur: Vec<string> = Vec::new();
    cur.push("one");
    rows.push(cur);
    rows.push(cur);
    cur.push("two");

    testing.assert_eq(rows.len(), 2);
    testing.assert_eq(rows[0].len(), 1);
    testing.assert_eq(rows[1].len(), 1);
    testing.assert_eq_str(rows[0][0], "one");
    testing.assert_eq_str(rows[1][0], "one");
    // Source kept growing without disturbing the stored copies.
    testing.assert_eq(cur.len(), 2);
}

// ── Vec<HashMap<string, i64>> ──────────────────────────────────────────────

// A key inserted into the source AFTER the push must not appear in the stored
// map: the push copied the map in, it did not alias the source handle.
#[test]
fn test_vec_hashmap_push_is_copy_in() {
    let rows: Vec<HashMap<string, i64>> = Vec::new();
    let m: HashMap<string, i64> = HashMap::new();
    m.insert("alpha", 1);
    rows.push(m);
    m.insert("beta", 2);

    let stored = rows[0];
    testing.assert_eq(stored.len(), 1);
    testing.assert_true(stored.contains_key("alpha"));
    testing.assert_false(stored.contains_key("beta"));
    // Source still carries both keys.
    testing.assert_eq(m.len(), 2);
}

// ── Vec<HashSet<string>> ───────────────────────────────────────────────────

// Same copy-in property for set values.
#[test]
fn test_vec_hashset_push_is_copy_in() {
    let rows: Vec<HashSet<string>> = Vec::new();
    let s: HashSet<string> = HashSet::new();
    s.insert("alpha");
    rows.push(s);
    s.insert("beta");

    let stored = rows[0];
    testing.assert_eq(stored.len(), 1);
    testing.assert_true(stored.contains("alpha"));
    testing.assert_false(stored.contains("beta"));
    testing.assert_eq(s.len(), 2);
}

// ── Vec<Vec<Vec<string>>>: deeper nesting still owns each level ─────────────

#[test]
fn test_vec_vec_vec_string_deep_nesting() {
    let outer: Vec<Vec<Vec<string>>> = Vec::new();
    let mid: Vec<Vec<string>> = Vec::new();
    let inner: Vec<string> = Vec::new();
    inner.push("alpha");
    inner.push("beta");
    mid.push(inner);
    outer.push(mid);
    // Mutate the inner accumulator after both pushes; the stored grid is fixed.
    inner.clear();

    testing.assert_eq(outer.len(), 1);
    let stored_mid = outer[0];
    testing.assert_eq(stored_mid.len(), 1);
    let stored_inner = stored_mid[0];
    testing.assert_eq(stored_inner.len(), 2);
    testing.assert_eq_str(stored_inner[0], "alpha");
    testing.assert_eq_str(stored_inner[1], "beta");
}
