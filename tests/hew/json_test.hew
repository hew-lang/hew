//! Behavioural tests for std::encoding::json.

import std::encoding::json;
import std::testing;

// ── try_parse ─────────────────────────────────────────────────────────

#[test]
fn test_try_parse_valid_returns_ok() {
    let r = json.try_parse("{\"x\": 1}");
    match r {
        Ok(val) => { val.free(); },
        Err(_) => panic("expected Ok, got Err"),
    }
}

#[test]
fn test_try_parse_invalid_returns_err() {
    let r = json.try_parse("{not valid json}");
    match r {
        Ok(val) => { val.free(); panic("expected Err, got Ok"); },
        Err(ParseError::Invalid(_)) => {},
    }
}

// ── from_int / get_int round-trip ─────────────────────────────────────

#[test]
fn test_from_int_get_int_round_trip() {
    let val = json.from_int(42);
    testing.assert_eq(val.get_int(), 42);
    val.free();
}

// ── object() builder + get_field ─────────────────────────────────────

#[test]
fn test_object_builder_string_field() {
    let obj = json.object().with_string("name", "Hew");
    let field = obj.get_field("name");
    testing.assert_eq_str(field.get_string(), "Hew");
    field.free();
    obj.free();
}

#[test]
fn test_object_builder_int_field() {
    let obj = json.object().with_int("version", 1);
    let field = obj.get_field("version");
    testing.assert_eq(field.get_int(), 1);
    field.free();
    obj.free();
}

// ── array + array_len ────────────────────────────────────────────────

#[test]
fn test_array_len() {
    let arr = json.array().push_int(10).push_int(20).push_int(30);
    testing.assert_eq(arr.array_len(), 3);
    arr.free();
}

// ── stringify round-trip ──────────────────────────────────────────────

#[test]
fn test_stringify_produces_valid_json() {
    let obj = json.object().with_int("n", 7);
    let s = obj.stringify();
    // re-parse the stringified output to confirm validity
    let r = json.try_parse(s);
    match r {
        Ok(reparsed) => {
            let field = reparsed.get_field("n");
            testing.assert_eq(field.get_int(), 7);
            field.free();
            reparsed.free();
        },
        Err(_) => panic("stringify produced unparseable JSON"),
    }
    obj.free();
}

// ── free() does not panic on valid value ──────────────────────────────

#[test]
fn test_free_no_panic() {
    let val = json.from_int(0);
    val.free();
}
