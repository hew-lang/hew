// Regression for #1698: HashSet::insert must transfer ownership of the
// String element identifier. Previously, the source identifier's drop slot
// was not nulled after hew_hashset_insert_string, so on inner scope exit
// the runtime freed the String buffer that the set's storage now pointed at,
// leaving the set's slot with a dangling pointer.
fn build_set() -> HashSet<String> {
    let s: HashSet<String> = HashSet::new();
    var i: i32 = 0;
    while i < 2 {
        let word: String = if i == 0 {
            "hello"
        } else {
            "world"
        };
        s.insert(word);
        i = i + 1;
    }
    s
}

fn main() {
    let s = build_set();
    if s.len() == 2 && s.contains("hello") && s.contains("world") {
        print("PASS\n");
    } else {
        print("FAIL\n");
    }
}
