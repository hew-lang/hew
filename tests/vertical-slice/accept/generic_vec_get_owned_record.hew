// #1929 Stage 2 dogfood proof, updated for the Index-trait `Vec<T>.get(i)`
// model: `get` now returns `Option<T>` whose `Some` payload is an INDEPENDENT
// drop-safe clone of the element (the `hew_vec_get_clone` choke point), not a
// borrow into the live slot. `Name` owns a heap `string`, so `Vec<Name>` is
// built through the owned descriptor ABI; the generic per-monomorphisation
// re-resolution must reach the element-agnostic clone getter so the returned
// `Some(elem)` owns a fresh copy. Because the returned value is a clone, the
// caller and the Vec own disjoint heaps: the scope-exit `hew_vec_free_owned`
// and the dropped `Some` payload each balance exactly one owner — no aliasing,
// no interior-borrow taint required. Instantiated at the owned record `Name`,
// the scalar `i64`, and the copy-on-write `string`, the generic helper
// re-resolves each element ABI through the one entry point.
type Name {
    label: string;
}

fn first<T>(v: Vec<T>) -> Option<T> {
    v.get(0)
}

fn main() {
    let vn: Vec<Name> = Vec::new();
    vn.push(Name { label: "owned-ok" });
    match first(vn) {
        Some(n) => println(n.label),
        None => println("empty"),
    }
    let vi: Vec<i64> = Vec::new();
    vi.push(42);
    match first(vi) {
        Some(x) => println(x),
        None => println("empty"),
    }
    let vs: Vec<string> = Vec::new();
    vs.push("ok");
    match first(vs) {
        Some(s) => println(s),
        None => println("empty"),
    }
}
