// Probe for F1: explicit type arguments on a struct literal.
// Before the fix, `Wrapper<string> { ... }` caused a parse error because
// the parser did not accept `<T>` between the struct path and `{`.
// After the fix, this must parse, type-check, and run successfully.
type Wrapper<T> {
    value: T;
}

fn main() {
    let w = Wrapper<string> { value: "hello" };
    println(w.value);
}
