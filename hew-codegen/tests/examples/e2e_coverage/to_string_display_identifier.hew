// Regression: to_string(named_local) where the type has a Display impl.
// Verifies ownership transfer — after to_string(g) the Display::fmt call consumes
// g; the caller must not attempt a second drop of the same binding.
pub type Greeting {
    who: String;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> String {
        "hello, " + val.who
    }
}

fn main() {
    let g = Greeting { who: "world" };
    let s = to_string(g);
    println(s);
}
