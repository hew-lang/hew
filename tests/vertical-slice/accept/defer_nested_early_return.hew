// Nested early return: defers in both inner block scope AND function scope
// run when return crosses them. LIFO order: inner scope defer (exit(10))
// runs first, then outer scope defer (exit(20)). We observe exit code 10.
fn check(x: i64) -> i64 {
    defer exit(20);
    defer exit(10);
    return x;
}
fn main() -> i64 {
    check(0)
}
