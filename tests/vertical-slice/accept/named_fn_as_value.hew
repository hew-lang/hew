fn double(x: i64) -> i64 { x * 2 }
fn apply(f: fn(i64) -> i64, x: i64) -> i64 { f(x) }
fn main() {
    println(apply(double, 7));          // 14: named fn passed as argument
    let r = apply(double, 3);
    println(r);                         // 6:  named fn passed, result in let
    let f = double;
    println(f(5));                      // 10: named fn stored in let binding
    println(apply(|x: i64| x * 3, 7)); // 21: lambda literal regression guard
}
