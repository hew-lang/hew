//! Vec<isize> must share the canonical platform-sized integer Vec ABI.

import std::testing;

fn first_isize<T>(xs: Vec<T>) -> T {
    xs[0]
}

#[test]
fn test_generic_vec_isize_push_get_pop() {
    let values: Vec<isize> = Vec::new();
    let first: isize = 41;
    let second: isize = 42;
    values.push(first);
    values.push(second);
    testing.assert_eq(first_isize(values) as i64, 41);
    testing.assert_eq(values[1] as i64, 42);
    testing.assert_eq(values.pop() as i64, 42);
}
