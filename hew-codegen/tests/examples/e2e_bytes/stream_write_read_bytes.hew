import std::stream;

fn main() {
    let (sink, input) = stream.channel(8);

    // Build byte buffers for "Hi" (72, 105) and "!" (33)
    let buf1: bytes = bytes::new();
    buf1.push(72);
    buf1.push(105);

    let buf2: bytes = bytes::new();
    buf2.push(33);

    sink.write_bytes(buf1);
    sink.write_bytes(buf2);
    sink.close();

    // Read back as bytes and verify lengths + content
    let first = input.next_bytes();
    println(first.len());
    println(first.get(0));
    println(first.get(1));

    let second = input.next_bytes();
    println(second.len());
    println(second.get(0));

    // EOF should return empty bytes
    let eof = input.next_bytes();
    println(eof.len());

    input.close();
}
