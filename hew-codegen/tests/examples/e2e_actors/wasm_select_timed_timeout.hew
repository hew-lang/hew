// WASM timed-select parity: `after 0ms` must win deterministically before any
// cooperative scheduler tick runs.
actor Responder {
    let value: int;
    receive fn get() -> int {
        value
    }
}

fn main() {
    let a = spawn Responder(value: 1);
    let b = spawn Responder(value: 2);

    let result = select {
        x from a.get() => x,
        y from b.get() => y,
        after 0ms => -1,
    };
    println(result);
}
