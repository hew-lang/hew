type Point {
    x: int;
    y: int;
}

impl Point {
    // Named receiver with explicit type annotation
    fn sum(pt: Point) -> int {
        pt.x + pt.y
    }
    
    fn double(pt: Point) -> int {
        pt.sum() * 2
    }
}

fn main() {
    let p = Point { x: 3, y: 4 };
    println(p.sum());
    println(p.double());
}
