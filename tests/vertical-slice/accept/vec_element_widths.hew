type Point {
    x: i64,
    y: i64,
}

fn main() -> i64 {
    let bs: Vec<bool> = Vec::new();
    bs.push(true);
    bs.push(false);
    bs.push(true);
    let bs2 = bs[1..3];
    println(bs2.len());
    println(bs2[0]);
    println(bs2[1]);

    let cs: Vec<char> = Vec::new();
    cs.push('a');
    cs.push('Z');
    cs.push('!');
    let cs2 = cs[0..2];
    println(cs2.len());
    if cs2[0] != 'a' { return 60; }
    if cs2[1] != 'Z' { return 61; }

    let i8s: Vec<i8> = Vec::new();
    i8s.push(-5);
    i8s.push(-1);
    i8s.push(7);
    i8s.set(0, -8);
    println(i8s[0] as i64);
    println(i8s[1] as i64);
    let i8s2 = i8s[1..3];
    println(i8s2[0] as i64);
    println(i8s2[1] as i64);

    let u8s: Vec<u8> = Vec::new();
    u8s.push(1);
    u8s.push(200);
    u8s.push(255);
    println(u8s[1] as i64);
    println(u8s.pop() as i64);

    let i16s: Vec<i16> = Vec::new();
    i16s.push(-1234);
    i16s.push(32767);
    println(i16s[0] as i64);
    println(i16s[1] as i64);

    let u16s: Vec<u16> = Vec::new();
    u16s.push(50000);
    u16s.push(65535);
    let u16s2 = u16s[0..2];
    println(u16s2[0] as i64);
    println(u16s2[1] as i64);

    let i64s: Vec<i64> = Vec::new();
    i64s.push(-9);
    i64s.push(9223372036854775807);
    println(i64s[0]);
    println(i64s[1]);

    let u64s: Vec<u64> = Vec::new();
    u64s.push(42);
    u64s.push(1234567890123);
    println(u64s[0]);
    println(u64s[1]);

    let f32s: Vec<f32> = Vec::new();
    f32s.push(1.5);
    f32s.push(2.5);
    let f32s2 = f32s[0..2];
    if f32s2[0] != 1.5 { return 70; }
    if f32s2[1] != 2.5 { return 71; }

    let points: Vec<Point> = Vec::new();
    points.push(Point { x: 1, y: 10 });
    points.push(Point { x: 2, y: 20 });
    points.set(0, Point { x: 3, y: 30 });
    let p = points[0];
    println(p.x + p.y);
    println(points.len());
    0
}
