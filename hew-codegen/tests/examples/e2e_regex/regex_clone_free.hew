// Regression test: calling .free() on a clone() temporary must remain safe,
// and the original pattern must still be explicitly released afterward.

import std::text::regex;

fn run_once() {
    let re: regex.Pattern = regex.new("[0-9]+");
    // Clone the pattern, immediately free the clone.
    re.clone().free();
    re.free();
}

fn main() {
    run_once();
    run_once();
    run_once();
    println("ok");
}
