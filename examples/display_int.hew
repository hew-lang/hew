//! Status: runnable
//! Description: Sample exercising primitive receiver trait-method dispatch end-to-end.

// Sample exercising primitive receiver trait-method dispatch end-to-end.
// Use the canonical primitive spelling directly; the `i64`↔`i64` alias case is
// tracked separately.
trait Display {
    fn fmt(val: Self) -> string;
}

impl Display for i64 {
    fn fmt(val: i64) -> string {
        "i64"
    }
}

fn main() {
    let x: i64 = 42;
    println(x.fmt());
}
