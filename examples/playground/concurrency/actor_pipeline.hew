//! @name Actor Pipeline
//! @description Actors processing messages independently

actor Doubler {
    receive fn process(n: int) -> int {
        let result = n * 2;
        print("Result: ");
        println(result);
        result
    }
}

fn main() {
    let doubler = spawn Doubler;
    await doubler.process(5);
    await doubler.process(21);
    await doubler.process(100);
}
