// ── count_f64 ─────────────────────────────────────────────────────────────

#[test]
fn test_count_f64_positives() {
    let v: Vec<f64> = Vec::new();
    v.push(1.0); v.push(-1.0); v.push(2.5);
    testing.assert_eq(iter.count_f64(v, (x: f64) => x > 0.0), 2);
