//! Generic free-function task spawn: a generic fn lowered through the
//! monomorphized-callee TaskEntry adapter.
//!
//! Exercises three spawn shapes across two distinct concrete type arguments:
//! - No-arg unit-returning spawn (ForkBlock form) — `fork { unit_work::<i64>(); }`
//! - No-arg value-returning spawn (named form) — `fork t = compute::<i64>()`
//! - Arg-bearing unit-returning spawn (named + await) — `fork t = add::<string>(a, b)`
//!
//! VALUE ASSERTIONS pin exact results so a mis-routed spawn or wrong
//! monomorphization is caught by mismatched values, not just exit-code.
//!
//! DROP SAFETY: the spawned tasks' owned results (strings and i64s) are
//! fully consumed via `await` inside the scope; the scope's join-all
//! ensures both tasks complete before the handler resumes.

import std::testing;

// No-arg unit-returning generic callee. The two type args (`i64`, `string`)
// each generate a separate monomorphized function (`unit_work$$i64`,
// `unit_work$$string`), and each gets its own task-entry adapter.
fn unit_work<T>() {}

// No-arg value-returning generic callee. Returns a hardcoded sentinel
// so the test can assert the exact value regardless of T.
fn compute_val<T>() -> i64 {
    return 42;
}

// Arg-bearing unit-returning generic callee. Takes a scalar arg
// (BitCopy, legal through the fork-env shim) and accumulates into
// a shared actor field via the reply.
fn add_ints<T>(a: i64, b: i64) -> i64 {
    return a + b;
}

actor TaskRunner {
    var total: i64 = 0;

    // ----------------------------------------------------------------
    // Spawn + await a no-arg value-returning generic fn at two types.
    // ----------------------------------------------------------------
    receive fn run_value_tasks() -> i64 {
        scope {
            fork t1 = compute_val::<i64>();
            fork t2 = compute_val::<string>();
            let v1 = await t1;
            let v2 = await t2;
            total = v1 + v2;
        };
        return total;
    }

    // ----------------------------------------------------------------
    // Spawn + await an arg-bearing value-returning generic fn at two types.
    // ----------------------------------------------------------------
    receive fn run_arg_tasks() -> i64 {
        scope {
            fork t1 = add_ints::<i64>(20, 22);
            fork t2 = add_ints::<string>(10, 32);
            let v1 = await t1;
            let v2 = await t2;
            total = v1 + v2;
        };
        return total;
    }

    // ----------------------------------------------------------------
    // ForkBlock (no-arg unit) form — fires generic spawn via the
    // `fork { generic_fn::<T>(); }` path.
    // ----------------------------------------------------------------
    receive fn run_unit_fork() -> i64 {
        scope {
            fork { unit_work::<i64>(); }
            fork { unit_work::<string>(); }
        };
        return 7;
    }
}

// ---- Tests ----

#[test]
fn test_generic_free_fn_task_spawn_value() {
    let r = spawn TaskRunner(total: 0);
    match await r.run_value_tasks() {
        Ok(n) => testing.assert_eq(n, 84),
        Err(_) => testing.assert_true(false),
    }
}

#[test]
fn test_generic_free_fn_task_spawn_args() {
    let r = spawn TaskRunner(total: 0);
    match await r.run_arg_tasks() {
        Ok(n) => testing.assert_eq(n, 84),
        Err(_) => testing.assert_true(false),
    }
}

#[test]
fn test_generic_free_fn_task_spawn_unit_fork_block() {
    let r = spawn TaskRunner(total: 0);
    match await r.run_unit_fork() {
        Ok(n) => testing.assert_eq(n, 7),
        Err(_) => testing.assert_true(false),
    }
}
