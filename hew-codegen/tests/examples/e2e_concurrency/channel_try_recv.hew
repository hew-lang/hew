import std::channel::channel;

fn main() {
    let (tx, rx) = channel.new(4);

    // Send two messages, then close.
    tx.send("alpha");
    tx.send("beta");
    tx.close();

    // try_recv should return Some(message) while messages are available.
    let first = rx.try_recv();
    let second = rx.try_recv();
    // After both consumed and sender closed, try_recv returns None.
    let third = rx.try_recv();

    match first {
        Some(v) => println(v),
        None => println("none"),
    }
    match second {
        Some(v) => println(v),
        None => println("none"),
    }
    match third {
        Some(_) => println("unexpected"),
        None => println("none"),
    }

    rx.close();
}
