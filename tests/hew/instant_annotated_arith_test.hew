//! Regression tests for instant arithmetic on an ANNOTATED or param-typed operand.
//!
//! Before the fix: `lower_type` (the field-type producer in `hew-hir/src/lower.rs`)
//! had no `instant` arm, so any binding produced from an annotation (`let t: instant`,
//! `fn f(t: instant)`, `-> instant`) kept `Named{Instant}` instead of `I64`. The
//! `binary_ty` helper then hit its wildcard and returned `Named{Instant}`, which
//! MIR rejected with `E_NOT_YET_IMPLEMENTED`. The fix canonicalises `Named{Instant}`
//! to `I64` at the top of `binary_ty` so arithmetic rules fire identically
//! regardless of how the binding was introduced.
//!
//! These tests pair every repro from the cross-eco defect report with an exact-value
//! assertion via `.duration_since`/`.nanos` so a garbage-path regression fails loudly.

import std::testing;

// ── helpers returning instant via an explicit return-type annotation ──────────
//
// This is the canonical "utility function" shape that the defect broke.
// A param typed `instant` arrived at `binary_ty` as Named{Instant}; the fix
// makes it canonicalise to I64 so `+` and `-` fire the integer path.

fn add_timeout(base: instant, d: duration) -> instant {
    return base + d;
}

fn sub_timeout(base: instant, d: duration) -> instant {
    return base - d;
}

// ── repro (a): let x: instant used as an arithmetic operand (+ side) ─────────
#[test]
fn annotated_instant_plus_duration_compiles_and_runs() {
    let anchor: instant = instant::now();
    let later: instant = anchor + 100ms;
    // later must be 100ms ahead of anchor: duration_since gives the gap.
    let gap: duration = later.duration_since(anchor);
    testing.assert_eq(gap.nanos(), 100000000);
}

// ── repro (b): typed function parameter as arithmetic operand (+ side) ────────
#[test]
fn param_typed_instant_plus_duration_compiles_and_runs() {
    let base: instant = instant::now();
    let later: instant = add_timeout(base, 200ms);
    let gap: duration = later.duration_since(base);
    testing.assert_eq(gap.nanos(), 200000000);
}

// ── repro (c): let x: instant used as an arithmetic operand (- side) ─────────
#[test]
fn annotated_instant_minus_duration_compiles_and_runs() {
    let anchor: instant = instant::now();
    let earlier: instant = anchor - 50ms;
    // anchor is 50ms ahead of earlier.
    let gap: duration = anchor.duration_since(earlier);
    testing.assert_eq(gap.nanos(), 50000000);
}

// ── typed parameter: subtract duration ───────────────────────────────────────
#[test]
fn param_typed_instant_minus_duration_compiles_and_runs() {
    let base: instant = instant::now();
    let earlier: instant = sub_timeout(base, 75ms);
    let gap: duration = base.duration_since(earlier);
    testing.assert_eq(gap.nanos(), 75000000);
}

// ── instant - instant still yields duration (the original binary_ty fix) ─────
// Checks that the Named{Instant} canonicalisation does not disturb the
// checker-promotion path that recovers Duration from i64-minus-i64.
#[test]
fn annotated_instant_minus_annotated_instant_yields_duration() {
    let a: instant = instant::now();
    // Displace b by 30ms using the fixed arithmetic path.
    let b: instant = a + 30ms;
    let diff: duration = b.duration_since(a);
    testing.assert_eq(diff.nanos(), 30000000);
}
