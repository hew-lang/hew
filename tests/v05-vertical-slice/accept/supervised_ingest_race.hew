// Acceptance fixture for supervisor child-accessor round-trip (S4).
//
// Exercises the full `supervisor.<child>` surface end-to-end:
//   1. `spawn App` runs the bootstrap: hew_supervisor_new + add_child_spec +
//      hew_supervisor_start.  Children are spawned synchronously inside
//      `add_child_spec`, so the slot is Live before `start` returns.
//   2. `app.w1` lowers through hew_supervisor_child_get (S2/S3): the result
//      tag must be 0 (Live) to yield a LocalPid<Worker> without trapping.
//   3. `w.ping(42)` sends a tell message to the child actor; the call is an
//      ask that returns the echoed value.
//   4. `main` returns the reply as the process exit code; exit 42 proves the
//      cross-actor send went through the child handle, not a shortcut.
//
// BLOCKED at runtime by two codegen bugs (follow-on scope; see llvm.rs):
//
//   Bug A — ABI mismatch in hew_supervisor_child_get declaration
//     (llvm.rs ~702): codegen declares return type as
//     `{ i8, i8, [6 x i8], ptr }` but Rust emits `[2 x i64]` (SysV/ARM64:
//     structs ≤ 16 bytes returned in x0:x1).  The field-by-field aggregate
//     triggers LLVM's indirect-return path (x8 pointer), so the caller reads
//     the tag byte from a stale x8 stack slot → non-zero tag → trap 206
//     (SupervisorChildUnavailable) at main+160.  Fix: change declaration to
//     `{ i64, i64 }`, truncate field 0 to i8 for tag, use field 1 directly
//     as the handle integer.  Evidence: Rust IR at
//     `define [2 x i64] @hew_supervisor_child_get`.
//
//   Bug B — hew_sched_init not called in supervisor bootstrap
//     (llvm.rs emit_supervisor_bootstrap_body ~1560): the plain-actor spawn
//     path (llvm.rs ~1370) calls hew_sched_init before hew_actor_spawn, but
//     the supervisor bootstrap path calls hew_supervisor_new without first
//     initialising the scheduler.  This causes a "scheduler not initialized"
//     panic (exit 134) once Bug A is fixed.
//
// Both bugs are confirmed fixed locally: exit 42 with both patches applied.
actor Worker {
    receive fn ping(n: i64) -> i64 {
        n
    }
}

supervisor App {
    strategy: one_for_one;
    max_restarts: 3;
    window: 60;

    child w1: Worker;
}

fn main() -> i64 {
    let app = spawn App;
    let w = app.w1;
    w.ping(42)
}
