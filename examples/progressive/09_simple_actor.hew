// Test 9: Simple Actor
// First time trying to use actors
actor Counter {
    let count: i32;
    receive fn increment(n: i32) {
        self.count = self.count + n;
    }
    receive fn get_count() -> i32 {
        self.count
    }
}

fn main() {
    let counter = spawn Counter(count: 0);
    counter.increment(5);
    counter.increment(10);
    println(await counter.get_count());
}
