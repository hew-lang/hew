// Regression for #1698: Vec::set of a non-Copy element (string) must
// transfer ownership to the slot. Previously, the source identifier's
// drop slot was not nulled after VecSetOp, so on inner scope exit the
// runtime freed the string buffer that the Vec's slot now pointed at,
// leaving the slot with a dangling pointer.
fn make_vec() -> Vec<string> {
    let v: Vec<string> = ["", ""];
    var i: i32 = 0;
    while i < 2 {
        let s: string = if i == 0 {
            "hello"
        } else {
            "world"
        };
        v.set(i as i64, s);
        i = i + 1;
    }
    v
}

fn main() {
    let v = make_vec();
    if v.get(0) == "hello" && v.get(1) == "world" {
        print("PASS\n");
    } else {
        print("FAIL\n");
    }
}
