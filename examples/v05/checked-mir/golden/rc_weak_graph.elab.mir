    branch[bb1: bb3/bb6] ->
      (none)
    return[bb2] ->
      drop _4 ty=Option<Rc<Node>> kind=enum_in_place
      drop _1 ty=Weak<Node> kind=weak_release guard=_2
    goto[bb3->bb2] ->
      (none)
    cancel[bb3] ->
      drop _4 ty=Option<Rc<Node>> kind=enum_in_place
      drop _1 ty=Weak<Node> kind=weak_release guard=_2
    goto[bb4->bb2] ->
      (none)
    cancel[bb4] ->
      drop _4 ty=Option<Rc<Node>> kind=enum_in_place
      drop _1 ty=Weak<Node> kind=weak_release guard=_2
    panic[bb5] ->
      drop _4 ty=Option<Rc<Node>> kind=enum_in_place
      drop _1 ty=Weak<Node> kind=weak_release guard=_2
    branch[bb6: bb4/bb5] ->
