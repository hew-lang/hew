// Simple counter actor
actor Counter {
    let count: i64;
    receive fn increment(n: i64) {
        count = count + n;
    }
    receive fn get_count() -> i64 {
        count
    }
}

fn main() {
    let counter = spawn Counter(count: 0);
    counter.increment(5);
    counter.increment(10);
    println(await counter.get_count());
}
