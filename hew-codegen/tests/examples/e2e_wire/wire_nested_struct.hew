// Test: nested wire struct — inner type declared before outer.
// Exercises to_json, from_json, binary encode/decode roundtrip.
#[wire]
struct Point {
    x: i32,
    y: i32,
}

#[wire]
struct Segment {
    start: Point,
    end: Point,
}

fn main() {
    let p1 = Point { x: 1, y: 2 };
    let p2 = Point { x: 3, y: 4 };
    let seg = Segment { start: p1, end: p2 };

    // JSON serialization
    let json = seg.to_json();
    println(json);

    // JSON roundtrip
    let seg2 = Segment.from_json(json);
    println(seg2.to_json());

    // Binary roundtrip
    let buf = seg.encode();
    let seg3 = Segment.decode(buf);
    println(seg3.to_json());
}
