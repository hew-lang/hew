//! @name Counter Actor
//! @description A simple actor that counts messages

actor Counter {
    let count: int;

    receive fn increment(n: int) -> int {
        count = count + n;
        print("Count is now: ");
        println(count);
        count
    }
}

fn main() {
    let c = spawn Counter;
    await c.increment(5);
    await c.increment(3);
    let total = await c.increment(12);
    print("Final total: ");
    println(total);
}
