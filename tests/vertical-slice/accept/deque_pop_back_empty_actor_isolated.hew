import std::deque;

actor DequePopBackCrasher {
    receive fn boom() {
        let dq = deque.new();
        let _ = dq.pop_back();
    }
}

actor DequePopBackProbe {
    receive fn ping() -> i64 {
        0
    }
}

fn main() -> i64 {
    let crasher = spawn DequePopBackCrasher;
    let probe = spawn DequePopBackProbe;
    crasher.boom();
    sleep(300ms);
    match await probe.ping() {
        Ok(v) => v,
        Err(_) => 1,
    }
}
