// ── last_str ──────────────────────────────────────────────────────────────

#[test]
fn test_last_str_non_empty() {
    let v: Vec<String> = Vec::new();
    v.push("one");
    v.push("two");
    v.push("three");
    testing.assert_eq_str(vec.last_str(v), "three");
}

#[test]
fn test_last_str_empty_returns_empty_string() {
    let v: Vec<String> = Vec::new();
    testing.assert_eq_str(vec.last_str(v), "");
}

// ── min_i32 ───────────────────────────────────────────────────────────────

#[test]
fn test_min_i32_several_elements() {
    let v: Vec<i32> = Vec::new();
    v.push(3);
    v.push(1);
    v.push(2);
    testing.assert_eq(vec.min_i32(v), 1);
}

#[test]
fn test_min_i32_single_element() {
    let v: Vec<i32> = Vec::new();
    v.push(42);
    testing.assert_eq(vec.min_i32(v), 42);
}

#[test]
fn test_min_i32_all_same() {
    let v: Vec<i32> = Vec::new();
    v.push(5);
    v.push(5);
    v.push(5);
    testing.assert_eq(vec.min_i32(v), 5);
}

#[test]
fn test_min_i32_min_is_first() {
    let v: Vec<i32> = Vec::new();
    v.push(1);
    v.push(9);
    v.push(7);
    testing.assert_eq(vec.min_i32(v), 1);
}

#[test]
fn test_min_i32_min_is_last() {
    let v: Vec<i32> = Vec::new();
    v.push(9);
    v.push(7);
    v.push(1);
    testing.assert_eq(vec.min_i32(v), 1);
}

// ── min_i64 ───────────────────────────────────────────────────────────────

#[test]
fn test_min_i64_several_elements() {
    let v: Vec<i64> = Vec::new();
    v.push(300);
    v.push(100);
    v.push(200);
    testing.assert_eq(vec.min_i64(v), 100);
}

#[test]
fn test_min_i64_single_element() {
    let v: Vec<i64> = Vec::new();
    v.push(77);
    testing.assert_eq(vec.min_i64(v), 77);
}

// ── min_f64 ───────────────────────────────────────────────────────────────

#[test]
fn test_min_f64_several_elements() {
    let v: Vec<f64> = Vec::new();
    v.push(3.0);
    v.push(1.5);
    v.push(2.0);
    testing.assert_true(vec.min_f64(v) == 1.5);
}

#[test]
fn test_min_f64_single_element() {
    let v: Vec<f64> = Vec::new();
    v.push(9.9);
    testing.assert_true(vec.min_f64(v) == 9.9);
}

// ── max_i32 ───────────────────────────────────────────────────────────────

#[test]
fn test_max_i32_several_elements() {
    let v: Vec<i32> = Vec::new();
    v.push(3);
    v.push(1);
    v.push(2);
    testing.assert_eq(vec.max_i32(v), 3);
}

#[test]
fn test_max_i32_single_element() {
    let v: Vec<i32> = Vec::new();
    v.push(42);
    testing.assert_eq(vec.max_i32(v), 42);
}

#[test]
fn test_max_i32_all_same() {
    let v: Vec<i32> = Vec::new();
    v.push(4);
    v.push(4);
    v.push(4);
    testing.assert_eq(vec.max_i32(v), 4);
}

#[test]
fn test_max_i32_max_is_first() {
    let v: Vec<i32> = Vec::new();
    v.push(9);
    v.push(1);
    v.push(5);
    testing.assert_eq(vec.max_i32(v), 9);
}

#[test]
fn test_max_i32_max_is_last() {
    let v: Vec<i32> = Vec::new();
    v.push(1);
    v.push(5);
    v.push(9);
    testing.assert_eq(vec.max_i32(v), 9);
}

