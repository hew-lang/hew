// Regression: compound assignment on self.field
actor Counter {
    let value: int;

    receive fn set(v: int) {
        self.value = v;
    }

    receive fn double() {
        self.value *= 2;
    }

    receive fn scale(n: int) {
        self.value *= n;
    }

    receive fn print_value() -> int {
        println(self.value);
        self.value
    }
}

fn main() {
    let counter = spawn Counter(value: 0);
    counter.set(3);
    counter.double();
    counter.scale(4);
    await counter.print_value();
}
