type User {
    name: string,
}

fn emit_user(print_it: bool) -> i64 {
    let first = "Ada";
    let last = "Lovelace";
    let full = first + " " + last;
    let user = User { name: full };
    if print_it {
        println(user.name);
    }
    0
}

fn main() -> i64 {
    var i: i64 = 0;
    while i < 100000 {
        emit_user(i == 0);
        i = i + 1;
    }
    0
}
