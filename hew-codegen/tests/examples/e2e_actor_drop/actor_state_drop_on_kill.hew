// Regression: when an actor is killed (terminate path runs and the runtime
// frees its state allocation), the codegen-emitted state-drop function must
// invoke `impl Drop` on every owned field of the state struct. A bare
// `libc::free(a.state)` would silently bypass the field-level `impl Drop`
// callbacks and leak any handles the state owns.
//
// `Token` carries a custom `impl Drop` that prints "drop_state:<id>". The
// actor holds one `Token` and one `Vec<string>` in its state. After the
// program awaits a ping (proving the actor is alive and the Token has been
// stored), the cleanup at program exit closes the actor, runs its terminate
// path, and the state-drop function fires `impl Drop` on the `Token` field.
// The expected output therefore contains TWO `drop_state:9` lines after
// "done": one from the spawning scope's `starter` cleanup (because actor
// spawn deep-copies init args), and one from the state-drop running on the
// actor's `tok` field before its state allocation is freed.
type Token {
    id: int;
}

impl Drop for Token {
    fn drop(t: Token) {
        println(f"drop_state:{t.id}");
    }
}

actor Holder {
    let tok: Token;
    let labels: Vec<string>;
    init(t: Token) {
        tok = t;
        let v: Vec<string> = [];
        v.push("alpha");
        v.push("beta");
        labels = v;
    }
    receive fn ping() -> int {
        tok.id
    }
}

fn main() {
    let starter = Token { id: 9 };
    let h = spawn Holder(t: starter);
    let n = await h.ping();
    println(n);
    println("done");
}
