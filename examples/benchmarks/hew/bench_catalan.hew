fn catalan(n: i64) -> i64 {
    let dp = Vec::new();
    dp.push(1);
    dp.push(1);
    for i in 2 .. n + 1 {
        dp.push(0);
        for j in 0 .. i {
            dp.set(i, dp[i] + dp[j] * dp[i - 1 - j]);
        }
    }
    dp[n]
}

const ITERS: i64 = 500000;

fn main() {
    var sum = 0;
    for i in 0 .. ITERS {
        sum = sum + catalan(15);
    }
    println(ITERS);
    println(sum);
}
