// E2E: generator that yields String values.
// Exercises the !hew.string_ref lowering path: toLLVMStorageType converts
// !hew.string_ref -> !llvm.ptr so that llvm.store and the __next stub
// signature are valid. Uses the direct-call form `for t in moves()` to
// keep the generator handle lifetime simple.

gen fn moves() -> String {
    for i in 0..=8 {
        yield("MOVE");
        if i == 6 { yield("RIGHT"); }
    }
}

fn main() {
    for t in moves() {
        println(t);
    }
}
