// An actor's `receive gen fn` handler with no params and no state reads:
// the minimal stream-producer dispatch (channel construction, tell-shaped
// start message, pump activation) with no env snapshot involved.
actor Emitter {
    receive gen fn ticks() -> i64 {
        yield 1;
        yield 2;
        yield 3;
    }
}

fn main() {
    let e = spawn Emitter;
    for await v in e.ticks() {
        println(f"{v}");
    }
}
