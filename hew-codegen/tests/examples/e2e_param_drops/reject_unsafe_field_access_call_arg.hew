// Reject test: passing an unsafe-wrapped field access to a function that
// takes ownership.  The unsafe block is transparent to ownership — the
// same double-free hazard applies.

type Inner {
    value: String;
}

impl Drop for Inner {
    fn drop(i: Inner) {
        println(i.value);
    }
}

type Outer {
    inner: Inner;
    tag: String;
}

fn consume(i: Inner) {
    println(i.value);
}

fn main() -> int {
    let obj = Outer { inner: Inner { value: "hello" }, tag: "t" };
    consume(unsafe { obj.inner });  // rejected: unsafe-wrapped field-access arg
    return 0;
}
