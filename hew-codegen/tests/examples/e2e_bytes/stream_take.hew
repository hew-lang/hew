import std::stream;

fn main() {
    let (sink, input) = stream.channel(8);

    sink.write("one");
    sink.write("two");
    sink.write("three");
    sink.write("four");
    sink.write("five");
    sink.close();

    let limited = input.take(3);

    for await item in limited {
        println(item);
    }
}
