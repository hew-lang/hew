// W3.004 S1: Vec<i64> push / pop / get / contains catalog coverage.
//
// hew_vec_push_i64, hew_vec_pop_i64, hew_vec_get_i64, hew_vec_contains_i64
// were absent from stdlib_catalog.rs; all four resolved to "undefined
// function".  This fixture exercises all four in a single end-to-end slice.
//
// Expected exit: 10  (v.contains(10) is true -> v[0] -> 10)
fn main() -> i64 {
    let v: Vec<i64> = Vec::new();
    v.push(10);
    v.push(20);
    v.push(30);
    v.pop();             // drops 30; len now 2
    if v.contains(10) { v[0] } else { 0 }
}
