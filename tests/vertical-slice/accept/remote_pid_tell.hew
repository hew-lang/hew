// Accept: RemotePid<T>::tell end-to-end — in-place Result<(), SendError> construction.
//
// Exercises the full codegen path for `pid.tell(msg)` on a `RemotePid<T>`:
//   - Checker rewrites the method call to `hew_remote_pid_tell` (MethodCallRewrite)
//   - MIR lowers it to Terminator::Call("hew_remote_pid_tell", [pid, msg])
//   - Codegen intercepts by callee name, emits `hew_actor_send_by_id`, and
//     constructs `Result<(), SendError>` in-place in the dest slot.
//
// Single-process Err path: `RemotePid::from_raw(1, 0)` yields a synthetic pid
// whose node_id (1) is remote (non-local). With no peer online the runtime
// returns a nonzero rc, which codegen maps to tag=1/SendError::NodeRoutingNotWired.
//
// Exit 42 proves the Err arm was reached AND the SendError discriminant was
// NodeRoutingNotWired (variant 2). Any other exit signals a regression in the
// in-place tag/payload construction.
//
// TODO(cross-node-ok): positive Ok path (tag=0, no-payload) is deferred until
// test/native-m3-quic-mesh-cross-node-integration lands. Add a two-process
// variant that starts a real node, registers Worker, calls tell, and asserts
// Result::Ok.
record Ping {
    n: i64,
}

actor Worker {
    receive fn ping(msg: Ping) {}
}

impl ActorMsg for Worker {
    type Msg = Ping;
    type Reply = ();
}

fn main() -> i64 {
    let pid: RemotePid<Worker> = RemotePid::<Worker>::from_raw(1, 0);
    let result: Result<(), SendError> = pid.tell(Ping { n: 0 });
    match result {
        Result::Ok(_) => 0,
        Result::Err(e) => match e {
            SendError::NodeRoutingNotWired => 42,
            SendError::Full => 1,
            SendError::Closed => 2,
        },
    }
}
