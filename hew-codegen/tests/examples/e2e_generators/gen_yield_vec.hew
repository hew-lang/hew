// E2E: generator that yields Vec<int> values.
// Exercises the !hew.vec_ref lowering path: toLLVMStorageType converts
// !hew.vec_ref -> !llvm.ptr so that llvm.store and the __next stub
// signature are valid, then a BitcastOp reconstructs !hew.vec_ref at
// the call site so Vec methods (.len()) work correctly in the loop body.

gen fn ranges() -> Vec<int> {
    let a: Vec<int> = Vec::new();
    a.push(1);
    a.push(2);
    yield a;
    let b: Vec<int> = Vec::new();
    b.push(10);
    b.push(20);
    b.push(30);
    yield b;
}

fn main() {
    for v in ranges() {
        println(v.len());
    }
}
