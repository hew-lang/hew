//! Generic Vec<T> range slicing must select the concrete element ABI.

import std::testing;

type VecSliceName {
    label: string;
}

type VecSlicePoint {
    x: i64;
    y: i64;
}

enum VecSliceColour {
    Red;
    Green;
    Blue;
}

enum VecSliceShape {
    Circle(i64);
    Rect(i64, i64);
}

fn generic_slice<T>(xs: Vec<T>, start: i64, end: i64) -> Vec<T> {
    xs[start..end]
}

fn colour_tag(c: VecSliceColour) -> i64 {
    match c {
        VecSliceColour::Red => 1,
        VecSliceColour::Green => 2,
        VecSliceColour::Blue => 3,
    }
}

fn shape_measure(s: VecSliceShape) -> i64 {
    match s {
        VecSliceShape::Circle(r) => r,
        VecSliceShape::Rect(w, h) => w * h,
    }
}

#[test]
fn test_generic_vec_slice_i64_string_records_enums() {
    let ints: Vec<i64> = Vec::new();
    ints.push(1);
    ints.push(2);
    ints.push(3);
    let int_slice = generic_slice(ints, 1, 3);
    testing.assert_eq(int_slice.len(), 2);
    testing.assert_eq(int_slice.get(0), 2);
    testing.assert_eq(int_slice.get(1), 3);

    let strings: Vec<string> = Vec::new();
    strings.push("alpha");
    strings.push("beta");
    strings.push("gamma");
    let string_slice = generic_slice(strings, 0, 2);
    testing.assert_eq(string_slice.len(), 2);
    testing.assert_eq_str(string_slice.get(0), "alpha");
    testing.assert_eq_str(string_slice.get(1), "beta");

    let records: Vec<VecSliceName> = Vec::new();
    records.push(VecSliceName { label: "zero" });
    records.push(VecSliceName { label: "one" });
    records.push(VecSliceName { label: "two" });
    let record_slice = generic_slice(records, 1, 3);
    testing.assert_eq(record_slice.len(), 2);
    testing.assert_eq_str(record_slice.get(0).label, "one");
    testing.assert_eq_str(record_slice.get(1).label, "two");

    let points: Vec<VecSlicePoint> = Vec::new();
    points.push(VecSlicePoint { x: 10, y: 20 });
    points.push(VecSlicePoint { x: 30, y: 40 });
    points.push(VecSlicePoint { x: 50, y: 60 });
    let point_slice = generic_slice(points, 1, 3);
    testing.assert_eq(point_slice.len(), 2);
    testing.assert_eq(point_slice.get(0).x, 30);
    testing.assert_eq(point_slice.get(0).y, 40);
    testing.assert_eq(point_slice.get(1).x, 50);
    testing.assert_eq(point_slice.get(1).y, 60);

    let colours: Vec<VecSliceColour> = Vec::new();
    colours.push(VecSliceColour::Red);
    colours.push(VecSliceColour::Green);
    colours.push(VecSliceColour::Blue);
    colours.push(VecSliceColour::Red);
    let colour_slice = generic_slice(colours, 1, 3);
    testing.assert_eq(colour_slice.len(), 2);
    testing.assert_eq(colour_tag(colour_slice.get(0)), 2);
    testing.assert_eq(colour_tag(colour_slice.get(1)), 3);

    let shapes: Vec<VecSliceShape> = Vec::new();
    shapes.push(VecSliceShape::Circle(2));
    shapes.push(VecSliceShape::Rect(3, 4));
    shapes.push(VecSliceShape::Circle(7));
    let shape_slice = generic_slice(shapes, 1, 3);
    testing.assert_eq(shape_slice.len(), 2);
    testing.assert_eq(shape_measure(shape_slice.get(0)), 12);
    testing.assert_eq(shape_measure(shape_slice.get(1)), 7);
}
