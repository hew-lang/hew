import std::net::tls;

extern "C" {
    fn hew_bytes_from_str(s: string) -> bytes;
}

// Exercises the record-returning `hew_tls_write_result` extern AT RUNTIME:
// the connect fails fast offline (port 1 refused) and the Rust side still
// constructs the `TlsWriteFfiResult { i32, i32 }` return, so the classified
// coerced-int carrier is proven on a real call, not dead code.
fn try_write_probe() -> i64 {
    let stream = tls.connect("127.0.0.1", 1);
    match tls.try_write(stream, unsafe {
        hew_bytes_from_str("ping")
    }) {
        Ok(n) => n,
        Err(_) => -2,
    }
}

// Exercises the record-returning `hew_tls_read_result` extern AT RUNTIME:
// the 24-byte `TlsReadFfiResult { bytes, i32 }` return carries a BytesTriple
// field through the classified sret path, and the Rust side constructs it
// even for the failed-connect stream — a real call through the indirect
// return, not dead code.
fn read_probe() -> i64 {
    let stream = tls.connect("127.0.0.1", 1);
    match tls.read(stream, 16) {
        Ok(data) => data.len(),
        Err(_) => -3,
    }
}

fn main() {
    let stream = tls.connect("127.0.0.1", 1);
    let n = tls.write(stream, unsafe {
        hew_bytes_from_str("ping")
    });
    println(f"write={n}");
    let w = try_write_probe();
    println(f"try_write={w}");
    let r = read_probe();
    println(f"read={r}");
}
