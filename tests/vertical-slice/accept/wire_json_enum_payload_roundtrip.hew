// Validation: a payload-variant `#[wire]` enum serializes to a single-key JSON
// object `{"Variant": [field0, field1, ...]}` (the positional payload array
// mirroring the CBOR map-of-one shape), and `from_json` parses it back. This
// fixture constructs `Rect(40, 2)`; the recovered fields sum to 42.
#[wire]
enum Shape {
    Dot;
    Circle(i64);
    Rect(i64, i64);
}

fn main() -> i64 {
    let s = Shape::Rect(40, 2);
    let j = s.to_json();
    if j != "{\"Rect\":[40,2]}" { return 1; }
    match Shape.from_json(j) {
        Ok(back) => match back {
            Shape::Dot => 2,
            Shape::Circle(r) => r,
            Shape::Rect(w, h) => w + h,
        },
        Err(_) => 3,
    }
}
