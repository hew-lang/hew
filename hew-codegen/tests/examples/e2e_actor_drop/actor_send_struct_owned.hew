// Test: identified struct containing owned String fields sent to an
// actor.  The actor-send alias path is currently disabled in
// codegen (see codegen.cpp:1432, `useAliasPath = false && ...`),
// so this exercises the legacy copy path: deepCopyOwnedArgs walks
// the struct and clones every owned field (head, body) into the
// envelope payload.  Sender owns originals, receiver owns clones,
// no shared heap state; both the sender's scope-exit drop and the
// receiver's post-dispatch drop must succeed without double-freeing.
//
// When the alias path is re-enabled in a future change, this test
// will additionally exercise nullOutAliasedSenderBindings'
// whole-aggregate invalidation of the struct slot.  Regression for
// PR #1721 review item 3.
type Greeting {
    head: String;
    body: String;
}

actor Logger {
    receive fn log_greeting(g: Greeting) {
        println(f"head:{g.head}");
        println(f"body:{g.body}");
    }
    receive fn ping() -> int {
        0
    }
}

fn main() {
    let l = spawn Logger;
    let g = Greeting { head: "hello", body: "world" };
    l.log_greeting(g);
    await l.ping();
}
