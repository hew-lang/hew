// Computed timeout expressions should lower to finite timeout_ms on all targets.
actor Responder {
    let value: int;
    receive fn get() -> int {
        sleep_ms(50);
        value
    }
}

fn delayed_zero_timeout() -> duration {
    sleep_ms(250);
    0ms + 0ms
}

fn main() {
    let first = spawn Responder(value: 1);
    let second = spawn Responder(value: 2);

    let result = select {
        x from first.get() => x,
        y from second.get() => y,
        after delayed_zero_timeout() => -1,
    };
    println(result);

    let fast = spawn Responder(value: 42);
    let timeout_later = 250ms + 250ms;
    let result2 = select {
        x from fast.get() => x,
        after timeout_later => -1,
    };
    println(result2);
}
