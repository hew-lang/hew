// Regression: explicit `.free()` on a json.Value must consume ownership so
// that the scope-exit `impl Drop` does NOT double-free the same handle.
//
// Without the fix (unregisterDroppable / slot-nulling after .free()),
// this program crashes with heap corruption even without ASAN because macOS
// malloc aborts on double-free ("pointer being freed was not allocated").
// With ASAN the abort is guaranteed on all platforms.
//
// The test is falsifiable: if the double-free regression is reintroduced,
// the process exits non-zero and ctest marks it FAILED.

import std::encoding::json;

fn do_explicit_free() -> i32 {
    let val = json.parse("{\"x\": 42}");
    let t = val.type_of();
    val.free();
    // scope exit: impl Drop must NOT fire again for `val`
    t
}

fn main() {
    println(do_explicit_free());
    println(do_explicit_free());
    println(do_explicit_free());
    println("no double free");
}
