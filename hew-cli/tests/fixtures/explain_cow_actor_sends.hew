// Fixture for --explain-cow golden test.
//
// Contains two actor send sites:
//   1. A last-use string transfer
//   2. An i64 bit-copy snapshot
//
// The golden test verifies that both sites appear in --explain-cow output
// with MIR-authored ownership modes.
actor Printer {
    receive fn print_message(msg: string) {
    }
}

actor Counter {
    receive fn increment(amount: i64) {
    }
}

fn main() {
    let printer = spawn Printer;
    let counter = spawn Counter;
    let greeting = "hello";
    printer.print_message(greeting);
    counter.increment(42);
}
