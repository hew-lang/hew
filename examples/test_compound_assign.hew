// Regression: compound assignment on field
actor Counter {
    let value: int;
    receive fn set(v: int) {
        value = v;
    }
    receive fn double() {
        value *= 2;
    }
    receive fn scale(n: int) {
        value *= n;
    }
    receive fn print_value() -> int {
        println(value);
        value
    }
}

fn main() {
    let counter = spawn Counter(value: 0);
    counter.set(3);
    counter.double();
    counter.scale(4);
    await counter.print_value();
}
