// ── last_f64 ──────────────────────────────────────────────────────────────

#[test]
fn test_last_f64_non_empty() {
    let v: Vec<f64> = Vec::new();
    v.push(1.1);
    v.push(2.2);
    v.push(3.3);
    testing.assert_true(vec.last_f64(v) == 3.3);
