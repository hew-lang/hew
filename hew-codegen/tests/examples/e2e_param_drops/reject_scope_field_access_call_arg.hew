// Reject test: passing a scope-wrapped field access to a function that
// takes ownership.  The scope block is transparent to ownership — the
// same double-free hazard applies.

type Inner {
    value: string;
}

impl Drop for Inner {
    fn drop(i: Inner) {
        println(i.value);
    }
}

type Outer {
    inner: Inner;
    tag: string;
}

fn consume(i: Inner) {
    println(i.value);
}

fn main() -> int {
    let obj = Outer { inner: Inner { value: "hello" }, tag: "t" };
    consume(scope { obj.inner });  // rejected: scope-wrapped field-access arg
    return 0;
}
