// Reject test: returning a field of a callee-dropped parameter.
// Without field-alias tracking, either:
// - the param IS dropped (freeing the returned field → use-after-free), or
// - the param is excluded from drops (leaking sibling owned fields).
// Both outcomes are unsound, so reject at compile time.

type Wrapper {
    name: String;
    extra: String;
}

impl Drop for Wrapper {
    fn drop(w: Wrapper) {
        println(w.name);
    }
}

fn extract_name(w: Wrapper) -> String {
    w.name  // rejected: returning field of callee-dropped param
}

fn main() -> int {
    let w = Wrapper { name: "hello", extra: "world" };
    let n = extract_name(w);
    println(n);
    return 0;
}
