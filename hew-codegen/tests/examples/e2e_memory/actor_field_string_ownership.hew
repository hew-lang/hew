// Test: Actor field string ownership — no double-free or use-after-free
// Exercises: string fields in actors, multiple reads/writes, ownership safety
actor Store {
    let data: string;

    receive fn set(value: string) {
        data = value;
        println(f"set: {data}");
    }

    receive fn get() -> string {
        println(f"get: {data}");
        data
    }

    receive fn append(suffix: string) {
        data = data + suffix;
        println(f"append: {data}");
    }
}

fn main() {
    println("=== Actor string Ownership ===");
    let s = spawn Store(data: "initial");
    await s.get();
    await s.set("hello");
    await s.get();
    await s.append(" world");
    await s.get();
    await s.set("replaced");
    await s.get();
    println("PASS");
}
