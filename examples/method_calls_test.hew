type Point {
    x: f64;
    y: f64;
}

trait PointMethods {
    fn distance(pt: Point) -> f64;
    fn translate(pt: Point, dx: f64, dy: f64) -> Point;
    fn magnitude(pt: Point) -> f64;
}

impl PointMethods for Point {
    fn distance(pt: Point) -> f64 {
        pt.x * pt.x + pt.y * pt.y
    }

    fn translate(pt: Point, dx: f64, dy: f64) -> Point {
        Point { x: pt.x + dx, y: pt.y + dy }
    }

    fn magnitude(pt: Point) -> f64 {
        let d = pt.distance();
        d * 2.0
    }
}

fn main() {
    let p1 = Point { x: 3.0, y: 4.0 };
    let dist = p1.distance();
    let p2 = p1.translate(1.0, 2.0);
    let mag = p2.magnitude();
}
