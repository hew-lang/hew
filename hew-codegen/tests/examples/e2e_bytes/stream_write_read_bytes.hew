import std::stream;

fn main() {
    // Use the generic bytes_channel constructor — returns (Sink<bytes>, Stream<bytes>).
    let (sink, input) = stream.bytes_channel(8);

    // Build byte buffers: "Hi" (72, 105), empty, "!" (33)
    let buf1: bytes = bytes::new();
    buf1.push(72);
    buf1.push(105);

    let empty: bytes = bytes::new();

    let buf2: bytes = bytes::new();
    buf2.push(33);

    // Generic `.write(b)` dispatches to hew_sink_write_bytes for Sink<bytes>.
    sink.write(buf1);
    sink.write(empty);
    sink.write(buf2);
    sink.close();

    // Generic `.next()` dispatches to hew_stream_next_bytes for Stream<bytes>,
    // returning Option<bytes>.
    var count: int = 0;
    var done = false;
    while !done {
        match input.next() {
            Some(data) => {
                println(data.len());
                count = count + 1;
            },
            None => {
                done = true;
            },
        }
    }
    println(count);

    input.close();
}
