import std::text::template;

fn main() {
    match template.try_parse("hello {{.name") {
        Ok(_) => println("unclosed-ok"),
        Err(_) => println("unclosed-error"),
    }

    match template.try_parse("{{end}}") {
        Ok(_) => println("end-ok"),
        Err(_) => println("end-error"),
    }

    let ctx = template.new_ctx();
    let t = template.parse("before {{.missing}} after");
    match template.render_try(t, ctx) {
        Ok(s) => println(s),
        Err(_) => println("missing-error"),
    }
}
