// Tests the public to_string builtin for signed integer primitives.
//
// Before this fix, hew build failed with:
//   "undefined function 'to_string'"
//   "undeclared variable 's'; did you mean to declare it with 'let' or 'var'?"
// The second error was a cascade from the first.  Both are gone after the fix.
fn main() {
    let s1 = to_string(42);
    println(s1);

    let s2 = to_string(-7);
    println(s2);

    let s3 = to_string(0);
    println(s3);

    // Original repro: let-binding of to_string must work without cascade errors.
    let s = to_string(42);
    println(s);
}
