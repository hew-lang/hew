//! Ratchets generic Display coverage for canonical numeric primitives through
//! `println`, `to_string`, and f-string interpolation.

import std::testing;

fn print_generic<T: Display>(x: T) {
    println(x);
}

fn render_generic<T: Display>(x: T) -> string {
    to_string(x)
}

fn interpolate_generic<T: Display>(x: T) -> string {
    f"{x}"
}

#[test]
fn test_generic_println_accepts_canonical_numeric_primitives() {
    let i8v: i8 = -7;
    let i16v: i16 = -1234;
    let i32v: i32 = -123456;
    let i64v: i64 = -1234567890123;
    let u8v: u8 = 250;
    let u16v: u16 = 65000;
    let u32v: u32 = 4000000000;
    let u64v: u64 = (-1) as u64;
    let isizev: isize = -4096;
    let usizev: usize = 4000000000;
    let f32v: f32 = 1.5;
    let f64v: f64 = -2.25;

    print_generic(i8v);
    print_generic(i16v);
    print_generic(i32v);
    print_generic(i64v);
    print_generic(u8v);
    print_generic(u16v);
    print_generic(u32v);
    print_generic(u64v);
    print_generic(isizev);
    print_generic(usizev);
    print_generic(f32v);
    print_generic(f64v);
}

#[test]
fn test_generic_to_string_formats_canonical_numeric_primitives() {
    let i8v: i8 = -7;
    let i16v: i16 = -1234;
    let i32v: i32 = -123456;
    let i64v: i64 = -1234567890123;
    let u8v: u8 = 250;
    let u16v: u16 = 65000;
    let u32v: u32 = 4000000000;
    let u64v: u64 = (-1) as u64;
    let isizev: isize = -4096;
    let usizev: usize = 4000000000;
    let f32v: f32 = 1.5;
    let f64v: f64 = -2.25;

    testing.assert_eq_str(render_generic(i8v), "-7");
    testing.assert_eq_str(render_generic(i16v), "-1234");
    testing.assert_eq_str(render_generic(i32v), "-123456");
    testing.assert_eq_str(render_generic(i64v), "-1234567890123");
    testing.assert_eq_str(render_generic(u8v), "250");
    testing.assert_eq_str(render_generic(u16v), "65000");
    testing.assert_eq_str(render_generic(u32v), "4000000000");
    testing.assert_eq_str(render_generic(u64v), "18446744073709551615");
    testing.assert_eq_str(render_generic(isizev), "-4096");
    testing.assert_eq_str(render_generic(usizev), "4000000000");
    testing.assert_eq_str(render_generic(f32v), "1.5");
    testing.assert_eq_str(render_generic(f64v), "-2.25");
}

#[test]
fn test_generic_fstring_formats_canonical_numeric_primitives() {
    let i8v: i8 = -7;
    let i16v: i16 = -1234;
    let i32v: i32 = -123456;
    let i64v: i64 = -1234567890123;
    let u8v: u8 = 250;
    let u16v: u16 = 65000;
    let u32v: u32 = 4000000000;
    let u64v: u64 = (-1) as u64;
    let isizev: isize = -4096;
    let usizev: usize = 4000000000;
    let f32v: f32 = 1.5;
    let f64v: f64 = -2.25;

    testing.assert_eq_str(interpolate_generic(i8v), "-7");
    testing.assert_eq_str(interpolate_generic(i16v), "-1234");
    testing.assert_eq_str(interpolate_generic(i32v), "-123456");
    testing.assert_eq_str(interpolate_generic(i64v), "-1234567890123");
    testing.assert_eq_str(interpolate_generic(u8v), "250");
    testing.assert_eq_str(interpolate_generic(u16v), "65000");
    testing.assert_eq_str(interpolate_generic(u32v), "4000000000");
    testing.assert_eq_str(interpolate_generic(u64v), "18446744073709551615");
    testing.assert_eq_str(interpolate_generic(isizev), "-4096");
    testing.assert_eq_str(interpolate_generic(usizev), "4000000000");
    testing.assert_eq_str(interpolate_generic(f32v), "1.5");
    testing.assert_eq_str(interpolate_generic(f64v), "-2.25");
}
