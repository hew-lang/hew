// W3.013 S0 verify: inclusive range-slice `xs[a..=b]` on Vec<i32>.
//
// MIR lowers inclusive end to `b + 1` (via IntArithChecked Add with overflow
// trap); hew_vec_slice_range_i32(vec, 1, 4) → [20, 30, 40].
//
// xs = [10, 20, 30, 40, 50]
// xs[1..=3] = [20, 30, 40]  →  len = 3  →  exit 3
fn main() -> i64 {
    let xs: Vec<i32> = Vec::new();
    xs.push(10);
    xs.push(20);
    xs.push(30);
    xs.push(40);
    xs.push(50);
    let s: Vec<i32> = xs[1..=3];
    s.len()
}
