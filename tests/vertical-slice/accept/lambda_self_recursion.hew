// Accept fixture: lambda actor with recursive self-call via let-binding.
// The let-binding name `fib` is the recursion handle; the actor body may
// reference it to send itself a message (tell-shaped recursive dispatch).
// Architecture §5.9 ratification 2: recursive lambda-actor self-call must
// typecheck clean at slice 2.
// WASM-PASS: type-check level only for slice 2; runtime landing is slice 4.
fn main() {
    let fib = actor |n: i64| {
        if n > 1 {
            fib(n - 1);
        }
    };
    fib(10);
}
