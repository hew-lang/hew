// Test: Actor-per-request HTTP handler pattern
// Demonstrates spawning one Handler actor per request.
// Each actor receives a simulated Request and responds through a Sink.
// The Request is automatically freed (via Drop) when handle() returns.
import std::stream;

type HttpReq {
    path: String;
}

impl Drop for HttpReq {
    fn drop(req: HttpReq) {
        println(f"drop {req.path}");
    }
}

actor Handler {
    receive fn handle(req: HttpReq, sink: Sink<String>) {
        let path = req.path;
        sink.write(f"handled: {path}");
        sink.close();
        // req is automatically freed by Drop here
    }

    receive fn ping() -> int {
        0
    }
}

fn main() {
    let (sink1, resp1) = stream.pipe(4);
    let (sink2, resp2) = stream.pipe(4);
    let (sink3, resp3) = stream.pipe(4);

    let h1 = spawn Handler;
    h1.handle(HttpReq { path: "/api/users" }, sink1);
    var handled1 = "";
    for await r in resp1 { handled1 = f"{r}"; }
    await h1.ping();
    println(handled1);
    resp1.close();

    let h2 = spawn Handler;
    h2.handle(HttpReq { path: "/api/items" }, sink2);
    var handled2 = "";
    for await r in resp2 { handled2 = f"{r}"; }
    await h2.ping();
    println(handled2);
    resp2.close();

    let h3 = spawn Handler;
    h3.handle(HttpReq { path: "/health" }, sink3);
    var handled3 = "";
    for await r in resp3 { handled3 = f"{r}"; }
    await h3.ping();
    println(handled3);
    resp3.close();
}
