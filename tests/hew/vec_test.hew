fn test_last_i32_single_element() {
    let v: Vec<i32> = Vec::new();
    v.push(55);
    testing.assert_eq(vec.last_i32(v), 55);
}

#[test]
fn test_last_i32_empty_returns_zero() {
    let v: Vec<i32> = Vec::new();
    testing.assert_eq(vec.last_i32(v), 0);
}

