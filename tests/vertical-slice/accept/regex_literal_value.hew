// End-to-end fixture: a `re"..."` literal bound in value position is a
// first-class `regex.Pattern` handle — usable through the stdlib regex API
// and passable to a function. The compiled handle is loaded from the
// module-init regex-handle global array into the binding's local.
import std::text::regex;

fn count_digit_runs(re: regex.Pattern, text: string) -> i64 {
    re.find_all(text).len()
}

fn main() {
    let digits = re"[0-9]+";
    // Direct method dispatch on the literal handle.
    if digits.is_match("abc123def") {
        println("matched");
    } else {
        println("no match");
    }
    println(digits.find("xx42yy"));
    // Pass the literal handle to a function taking `regex.Pattern`.
    println(count_digit_runs(digits, "a1b22c333"));
}
