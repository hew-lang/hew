fn main() {
    println("=== Lambda Actors ===");

    // Basic lambda actor
    let doubler = spawn (x: i32) => {
        println(x * 2);
    };
    doubler.send(21);
    close(doubler);
    await doubler;

    // Multiple lambda actors running concurrently
    let printer = spawn (msg: i32) => {
        println(f"Got: {msg}");
    };
    let multiplier = spawn (x: i32) => {
        println(f"Triple: {x * 3}");
    };
    let adder = spawn (x: i32) => {
        println(f"Plus 10: {x + 10}");
    };
    // Send to all concurrently
    printer.send(100);
    multiplier.send(7);
    adder.send(5);
    printer.send(200);
    close(printer);
    close(multiplier);
    close(adder);
    await printer;
    await multiplier;
    await adder;

    // Lambda actors within scope blocks
    {
        let scoped_actor = spawn (msg: i32) => {
            println(f"Scoped: {msg}");
        };
        scoped_actor.send(42);
        close(scoped_actor);
        await scoped_actor;
    };
    // Multiple sends to same actor
    let counter = spawn (x: i32) => {
        println(f"Count: {x}");
    };
    counter.send(1);
    counter.send(2);
    counter.send(3);
    close(counter);
    await counter;

    // Lambda actor with complex body (if/else, function calls)
    let complex_actor = spawn (n: i32) => {
        if n > 10 {
            println(f"Large number: {n}");
        } else {
            println(f"Small number: {n}");
        }
        let result = n * 2 + 1;
        println(f"Formula result: {result}");
    };
    complex_actor.send(5);
    complex_actor.send(15);
    close(complex_actor);
    await complex_actor;

    // Test actor factory pattern
    run_multiplier_actor(4, 10); // should print 40
    println("=== Done ===");
}

// Actor factory pattern - create and drain a lambda actor from a function
fn run_multiplier_actor(factor: i32, value: i32) {
    let worker = spawn (x: i32) => {
        println(f"Multiplied by {factor}: {x * factor}");
    };
    worker.send(value);
    close(worker);
    await worker;
    return;
}
