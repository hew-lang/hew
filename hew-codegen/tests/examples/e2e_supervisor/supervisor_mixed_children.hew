// Regression: `actorChildIndex` in the supervisor codegen must not advance for
// nested-supervisor children — only for actor children.  The index is used by
// `hew_supervisor_set_child_state_drop` to tie a state-drop callback to a
// specific entry in the runtime's `child_specs` array.  If a nested-supervisor
// child incorrectly bumped the counter, subsequent actor children would have
// their state-drop callbacks stored at the wrong `child_specs` slot and their
// heap-owned state would leak on restart.
//
// Setup: Root has [w1:Worker, pool:Inner, w2:Worker] — the nested supervisor
// sits BETWEEN the two actor children.  actorChildIndex must be 0 for w1 and
// 1 for w2.  With the bug, pool would bump the counter to 1, so w2 would be
// registered at index 2 (a slot that doesn't exist in child_specs[]) instead
// of at index 1, silently corrupting the state-drop wiring.  This layout —
// nested supervisor BETWEEN actor children — is the configuration where the
// off-by-one manifests; an `[actors..., supervisor]` layout would not catch
// it because the supervisor is processed last and never affects an actor's
// index.
//
// Workers carry a `String` field (heap-owned) so that state-drop matters: a
// wrong index leaves the state-drop callback at the wrong child_specs slot,
// which on restart either leaks the String or reads from a freed pointer.
//
// Inner has one Worker child for structural completeness.
//
// The test crashes both w1 and w2, waits for them to restart, then confirms
// they can still respond to messages.  Successful restart after a crash with
// heap-owned state requires that state-drop was registered at the correct index.
actor Worker {
    let id: int;
    let name: String;
    receive fn ping() -> int {
        print("ping ");
        println(name);
        id
    }
    receive fn crash_now() {
        println(f"crash {name}");
        panic("crash");
    }
}

supervisor Inner {
    strategy: one_for_one;
    max_restarts: 3;
    window: 60;

    child wi: Worker(99, "inner");
}

supervisor Root {
    strategy: one_for_one;
    max_restarts: 5;
    window: 60;

    child w1: Worker(1, "alpha");
    child pool: Inner;
    child w2: Worker(2, "beta");
}

fn main() {
    let root = spawn Root;
    sleep_ms(100);
    // Access w1 and w2 by name.  Named child access resolves actor-only vs.
    // supervisor-only indices correctly, so root.w1 calls
    // hew_supervisor_get_child_wait(root, 0) and root.w2 calls
    // hew_supervisor_get_child_wait(root, 1) regardless of where `pool: Inner`
    // appears in the declaration order.
    let a = root.w1;
    let b = root.w2;
    await a.ping();
    await b.ping();
    // Crash workers one at a time and wait for each restart before proceeding.
    // This keeps crash-message ordering deterministic for the expected output.
    a.crash_now();
    sleep_ms(300);
    b.crash_now();
    sleep_ms(300);
    let a2 = root.w1;
    let b2 = root.w2;
    await a2.ping();
    await b2.ping();
    println("done");
}
