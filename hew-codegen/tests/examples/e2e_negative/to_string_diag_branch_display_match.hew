// Negative test: to_string of a match expression that yields an owned Display
// value in each arm is rejected at codegen.  extractYieldedIdentifier cannot
// resolve a single canonical owner for multi-branch shapes; after Display::fmt
// consumes the selected arm's value, but that selected binding remains
// registered for caller-side drop -> double-free.
// Supported workaround: bind the match result to a local variable first.
type Greeting {
    text: string;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> string {
        val.text
    }
}

fn main() {
    let x = 1;
    let g = Greeting { text: "hello" };
    let h = Greeting { text: "world" };
    let s = to_string(match x {
        1 => g,
        _ => h,
    });
    println(s);
}
