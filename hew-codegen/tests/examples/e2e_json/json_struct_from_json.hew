// Regression: non-wire struct.from_json() returns Result<Self, String>.
// Covers three cases:
//   1. Valid JSON with all fields present     -> Ok(struct)
//   2. Unparseable JSON                       -> Err (parse failure)
//   3. Valid JSON but a required field absent -> Err (missing field)

type Point {
    x: int;
    y: int;
}

fn main() {
    // Case 1: round-trip — all fields present
    let p = Point { x: 3, y: 7 };
    let json = p.to_json();

    match Point.from_json(json) {
        Ok(decoded) => { println(decoded.x); println(decoded.y) },
        Err(_) => println("unexpected error"),
    }

    // Case 2: unparseable input
    match Point.from_json("{not valid json}") {
        Ok(_) => println("unexpected ok"),
        Err(_) => println("parse error caught"),
    }

    // Case 3: parseable but missing required field 'y'
    match Point.from_json("{\"x\":5}") {
        Ok(_) => println("unexpected ok on missing field"),
        Err(_) => println("missing field caught"),
    }
}
