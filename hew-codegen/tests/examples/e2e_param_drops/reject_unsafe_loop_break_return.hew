// Reject test: returning from an unsafe block whose value comes from
// a loop break expression yielding a field of a callee-dropped param.
// NOTE: Currently caught by type checker (loops produce ()) before codegen
// guard fires.  Guard is defense-in-depth for typed break-values.

type Wrapper {
    name: String;
    extra: String;
}

impl Drop for Wrapper {
    fn drop(w: Wrapper) {
        println(w.name);
    }
}

fn extract_name(w: Wrapper) -> String {
    unsafe {
        loop {
            break w.name;
        }
    }
}

fn main() -> int {
    let w = Wrapper { name: "hello", extra: "world" };
    let n = extract_name(w);
    println(n);
    return 0;
}
