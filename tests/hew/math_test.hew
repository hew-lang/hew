//! Tests for std::math float helpers.
import std::math;

import std::testing;

#[test]
fn test_min_f_returns_the_smaller_float() {
    testing.assert_true(math.min_f(3.5, 1.25) == 1.25);
    testing.assert_true(math.min_f(-2.0, -5.0) == -5.0);
}

#[test]
fn test_max_f_returns_the_larger_float() {
    testing.assert_true(math.max_f(3.5, 1.25) == 3.5);
    testing.assert_true(math.max_f(-2.0, -5.0) == -2.0);
}

#[test]
fn test_clamp_f_enforces_bounds() {
    testing.assert_true(math.clamp_f(-1.0, 0.5, 2.5) == 0.5);
    testing.assert_true(math.clamp_f(3.0, 0.5, 2.5) == 2.5);
    testing.assert_true(math.clamp_f(1.5, 0.5, 2.5) == 1.5);
}
