// Regression: supervisor restart must not corrupt or leak heap-owned actor
// state (e.g. string fields) across crash/restart cycles.
//
// `hew_supervisor_add_child_spec` byte-copies the init_state into the spec.
// On restart `restart_child_from_spec` passes that byte-copy as the init_state
// for the fresh spawn.  The runtime skips `state_drop_fn` for crashed actors
// (actor.rs: `if !actor_is_crashed`) so there is no double-free on the
// original instance's string field.  The fresh spawn deep-copies the spec's
// byte-copy, so post-restart the new actor owns a valid string.
//
// This test confirms that after a crash/restart cycle the restarted actor can
// still return its original string field value without corruption or SIGSEGV.
actor Greeter {
    let greeting: string;
    receive fn greet() -> string {
        greeting
    }
    receive fn crash_now() {
        println("crashing");
        panic("crash");
    }
}

supervisor GreeterSup {
    strategy: one_for_one;
    max_restarts: 5;
    window: 60;

    child g: Greeter("hello");
}

fn main() {
    let sup = spawn GreeterSup;
    sleep_ms(50);
    let g = supervisor_child(sup, 0);
    let msg1 = await g.greet();
    println(msg1);
    g.crash_now();
    sleep_ms(500);
    let g2 = supervisor_child(sup, 0);
    let msg2 = await g2.greet();
    println(msg2);
    println("done");
}
