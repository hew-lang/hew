// Backpressure test - bounded mailbox demo
// Demonstrates bounded mailboxes and await-on-void synchronization.
// The first three messages are sent fire-and-forget; the fourth is awaited
// so that main blocks until the handler finishes, making output deterministic.
actor SlowWorker {
    let id: int;

    mailbox 4;
    receive fn process(value: int) {
        print("SlowWorker ");
        print(id);
        println(f": processing {value}");
        sleep_ms(50);
    }
}

fn main() {
    println("=== Backpressure Test ===");
    let worker = spawn SlowWorker(id: 1);
    worker.process(0);
    worker.process(1);
    worker.process(2);
    // await blocks until this handler completes, giving us deterministic output
    await worker.process(3);
    println("=== Done ===");
}
