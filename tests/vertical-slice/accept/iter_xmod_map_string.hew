// Cross-module chained generic-adapter monomorphisation with a cross-type,
// owned-element terminal.
//
// `iter::map` maps each i64 to a distinct heap `string`; `iter::collect`
// gathers them into a fresh owned `Vec<string>`. Each element is an
// independently-droppable owner: the closure reads its i64 argument by value
// (a borrow, no callee-side drop) and produces a new string the collected Vec
// then owns. Summing the lengths reads each owned string before the Vec drops.
//
// Countdown{3} yields [3,2,1]; map -> ["xxx","xx","x"]; length sum = 6.
import std::iter;

type Countdown {
    n: i64;
}

impl Iterator for Countdown {
    type Item = i64;
    fn next(var self) -> Option<i64> {
        if self.n <= 0 {
            None
        } else {
            let cur = self.n;
            self.n = self.n - 1;
            Some(cur)
        }
    }
}

pub fn main() -> i64 {
    let mapped = iter::map(Countdown { n: 3 }, |x: i64| "x".repeat(x));
    let v: Vec<string> = iter::collect(mapped);
    var total = 0;
    for s in v {
        total = total + s.len();
    }
    total
}
