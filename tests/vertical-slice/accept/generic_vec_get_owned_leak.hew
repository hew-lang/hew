// #1929 Stage 2 leak proof, updated for the Index-trait `Vec<T>.get(i)` model:
// `Vec<T>.push`/`.get` for a NON-Copy record element under a type parameter,
// exercised 100k times. Each iteration builds a fresh owned `Name`, pushes it
// into a `Vec<Name>` through the generic owned ABI, gets it back out via a
// returning generic helper (`first<T> -> Option<T>`), reads the field, and
// drops both the returned record and the Vec at scope exit.
//
// `get` now resolves — for EVERY element class, concrete or type-parameter —
// to the single drop-safe choke point `hew_vec_get_clone`, which writes a FRESH
// OWNER into the `Option<T>` payload. The returned `Some(Name)` and the Vec's
// own slot are therefore DISJOINT heaps: the caller drops the clone, the Vec's
// scope-exit `hew_vec_free_owned` drops its element — no aliasing, no
// interior-borrow taint. A double-free of one heap string would SIGABRT within
// a few iterations; a missed drop (the clone or the slot) would grow RSS
// linearly across 100k iterations. A clean run with flat RSS is the
// exactly-once witness for the generic clone-getter ABI.
type Name {
    label: string;
}

fn first<T>(v: Vec<T>) -> Option<T> {
    v.get(0)
}

fn roundtrip(print_it: bool) -> i64 {
    let vn: Vec<Name> = Vec::new();
    vn.push(Name { label: "owned-ok" });
    match first(vn) {
        Some(got) => {
            if print_it {
                println(got.label);
            }
            got.label.len()
        }
        None => 0,
    }
}

fn main() -> i64 {
    var i: i64 = 0;
    while i < 100000 {
        roundtrip(i == 0);
        i = i + 1;
    }
    0
}
