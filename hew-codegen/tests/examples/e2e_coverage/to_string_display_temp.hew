// Regression: to_string(AnonymousTemp{...}) where the type has a Display impl.
// Verifies that the temporary struct value is materialized into a tracked alloca
// and its drop slot is nulled after Display::fmt consumes the receiver, so the
// scope-exit drop does not double-free the struct fields.
pub type Greeting {
    who: string;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> string {
        "hello, " + val.who
    }
}

fn main() {
    let s = to_string(Greeting { who: "world" });
    println(s);
}
