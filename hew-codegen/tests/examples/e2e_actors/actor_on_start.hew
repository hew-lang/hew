// Test: on(start) hook runs after init and before first message
// Exercises: #[on(start)] body executes once at actor startup
actor Greeter {
    let name: string;

    #[on(start)]
    fn greet() {
        println(f"hello from {name}");
    }

    receive fn ping() {
        println(f"{name} received ping");
    }
}

fn main() {
    println("=== On Start ===");
    let g = spawn Greeter(name: "alice");
    await g.ping();
    stop(g);
    println("=== End ===");
}
