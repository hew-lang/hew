// Cancelling a `receive gen fn` stream mid-drain (`for await ... break`) must
// not livelock the producer actor: the peer-closed check unwedges the pump
// (which never resumes past the check), and the actor answers a later ask
// normally. An infinite generator makes this unambiguous — the only way the
// program terminates is if cancellation actually works.
actor Ticker {
    receive gen fn stream() -> i64 {
        var i: i64 = 0;
        loop {
            yield i;
            i = i + 1;
        }
    }
    receive fn ping() -> i64 {
        99
    }
}

fn main() {
    let t = spawn Ticker;
    var count: i64 = 0;
    for await v in t.stream() {
        println(f"{v}");
        count = count + 1;
        if count >= 3 {
            break;
        }
    }
    let r = await t.ping();
    match r {
        Ok(v) => println(f"ping={v}"),
        Err(_) => println("ping failed"),
    }
}
