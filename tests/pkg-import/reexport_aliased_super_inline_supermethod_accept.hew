// Accept fixture: an ALIASED re-exported supertrait. `SubA` is imported from
// `hew::reexsubalias`, where `trait SubA: B` and `B` is `reexbase.Base` re-imported
// under an alias (`import reexbase::{ Base as B }`). The importer provides the
// inherited `base` inline. There is no `reexsubalias.B` def, so the super edge
// must follow `reexsubalias`'s aliased import binding to the SOURCE identity
// `reexbase.Base` (`-> i64`) — the alias renames the binding, not the identity.
// `base`'s methods are folded into the KNOWN set through that owner, and the
// inline `base`'s signature is checked against `reexbase.Base`. Run e2e.
import hew::reexsubalias::{SubA};

type W {
    id: i64;
}

impl SubA for W {
    fn base(w: W) -> i64 {
        w.id
    }
    fn tag(w: W) -> i64 {
        w.id + 100
    }
}

fn main() {
    let w = W { id: 7 };
    println(f"tag {w.tag()} base {w.base()}");
}
