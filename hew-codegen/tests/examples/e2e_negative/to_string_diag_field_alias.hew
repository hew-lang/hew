// Negative test: to_string of a field-aliased Display value is rejected at
// codegen.  Without field-alias / partial-move tracking, Display::fmt would
// consume the field value and the owning struct's scope-exit drop would free
// it again — a double-free.  Binding the field to a local variable first
// is the supported workaround.
type Greeting {
    text: string;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> string {
        val.text
    }
}

type Holder {
    greeting: Greeting;
}

fn main() {
    let holder = Holder { greeting: Greeting { text: "hello" } };
    let s = to_string(holder.greeting);
    println(s);
}
