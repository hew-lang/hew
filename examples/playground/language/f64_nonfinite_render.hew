//! @name F64 Non-Finite Render
//! @description f64 non-finite values (inf, -inf, nan) render identically to native printf %g

fn main() {
    // Overflow via compound-assign produces +inf.
    var big: f64 = .0;
    big *= 10.0;
    println(big);

    // Overflow via compound-assign with negative base produces -inf.
    var neg_big: f64 = -.0;
    neg_big *= 10.0;
    println(neg_big);

    // 0.0 / 0.0 produces NaN.
    let zero: f64 = 0.0;
    let nan: f64 = zero / zero;
    println(nan);

    // Direct assignments mirror the same values via arithmetic.
    let inf: f64 = 1.0 / zero;
    println(inf);
    let neg_inf: f64 = -1.0 / zero;
    println(neg_inf);
}
