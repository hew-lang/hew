// Pins the fail-closed surface for generic enums.
//
// Generic enums (`enum Maybe<T> { Just(T); Nothing }`) require a
// monomorphisation-keyed layout registry that the next-stage
// `EnumLayoutRegistry` substrate will land. Until then this fixture
// asserts the compiler emits `E_NOT_YET_IMPLEMENTED` with a
// generic-enum diagnostic rather than silently mis-laying out the type.
enum Maybe<T> {
    Just(T);
    Nothing;
}

fn main() {
    println("never reached");
}
