// Error handling with Result types
import std::result;

fn parse_number(s: string) -> Result<i64, string> {
    if s == "42" {
        Ok(42)
    } else {
        Err("Invalid number")
    }
}

fn main() {
    let parsed = parse_number("42");
    let failed = parse_number("oops");
    // match is the clearest way to handle a string error message.
    match parsed {
        Ok(n) => println(n),
        Err(msg) => println(msg),
    }
    match failed {
        Ok(n) => println(n),
        Err(msg) => println(msg),
    }
    // std::result also ships helpers for common Result<i64, i64> cases.
    let helper_ok: Result<i64, i64> = Ok(42);
    let helper_err: Result<i64, i64> = Err(-1);
    println(result.is_ok_int(helper_ok));
    println(result.is_err_int(helper_err));
    println(result.unwrap_or_int(helper_ok, 0));
    println(result.unwrap_or_int(helper_err, -1));
}
