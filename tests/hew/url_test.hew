//! Tests for the std::net::url percent-encoding helpers.

import std::net::url;

import std::testing;

#[test]
fn test_encode_preserves_existing_ascii_behavior() {
    testing.assert_eq_str(url.encode(""), "");
    testing.assert_eq_str(url.encode("hello world"), "hello%20world");
    testing.assert_eq_str(url.encode("a=1&b=2"), "a%3D1%26b%3D2");
}

#[test]
fn test_encode_utf8_bytes_as_uppercase_hex() {
    testing.assert_eq_str(url.encode("café"), "caf%C3%A9");
}

#[test]
fn test_decode_preserves_existing_behavior() {
    testing.assert_eq_str(url.decode("hello%20world"), "hello world");
    testing.assert_eq_str(url.decode("bad%2Zseq"), "bad%2Zseq");
    testing.assert_eq_str(url.decode("plus+sign"), "plus+sign");
}

#[test]
fn test_decode_invalid_utf8_returns_empty_string() {
    testing.assert_eq_str(url.decode("%FF%FE"), "");
}

#[test]
fn test_decode_truncates_at_decoded_nul() {
    testing.assert_eq_str(url.decode("%00"), "");
    testing.assert_eq_str(url.decode("a%00b"), "a");
}

#[test]
fn test_decode_query_empty_returns_empty_vec() {
    let pairs = url.decode_query("");
    testing.assert_eq(pairs.len(), 0);
}

#[test]
fn test_decode_query_decodes_form_pairs_in_order() {
    let pairs = url.decode_query("name=hello+world&x=a%2Bb&empty=&a=b=c");
    testing.assert_eq(pairs.len(), 4);
    testing.assert_eq_str(pairs[0].0, "name");
    testing.assert_eq_str(pairs[0].1, "hello world");
    testing.assert_eq_str(pairs[1].0, "x");
    testing.assert_eq_str(pairs[1].1, "a+b");
    testing.assert_eq_str(pairs[2].0, "empty");
    testing.assert_eq_str(pairs[2].1, "");
    testing.assert_eq_str(pairs[3].0, "a");
    testing.assert_eq_str(pairs[3].1, "b=c");
}

#[test]
fn test_decode_query_skips_entries_without_equals() {
    let pairs = url.decode_query("skip-me&ok=yes&&also=no");
    testing.assert_eq(pairs.len(), 2);
    testing.assert_eq_str(pairs[0].0, "ok");
    testing.assert_eq_str(pairs[0].1, "yes");
    testing.assert_eq_str(pairs[1].0, "also");
    testing.assert_eq_str(pairs[1].1, "no");
}

#[test]
fn test_port_returns_none_when_absent() {
    let parsed = url.parse("http://localhost/path");
    let port = parsed.port();
    parsed.free();
    match port {
        Some(value) => panic(f"expected None, got Some({value})"),
        None => {},
    }
}

#[test]
fn test_port_returns_some_when_explicit() {
    let parsed = url.parse("http://localhost:8080/path");
    let port = parsed.port();
    parsed.free();
    match port {
        Some(value) => testing.assert_eq(value, 8080),
        None => panic("expected Some(8080), got None"),
    }
}

// `#[ignore]`-tracked: `encode_query` calls `encode` internally and hits the
// same pre-existing char-vs-byte `byte_char` abort. See the note above the
// `encode` tests. Tracked: std::net::url encoder byte-model redesign.
#[test]
fn test_encode_query_skips_invalid_lines_and_uses_first_equals() {
    testing.assert_eq_str(url.encode_query("name=hello world\nskip-me\na=b=c"), "name=hello%20world&a=b%3Dc");
}

#[test]
fn test_encode_query_matches_existing_pair_encoding() {
    testing.assert_eq_str(url.encode_query("name=hello world\r\npage=1&2\nother=a+b"), "name=hello%20world&page=1%262&other=a%2Bb");
}
