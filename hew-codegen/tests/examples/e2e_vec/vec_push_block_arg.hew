// Regression for #1697 / services_pub_sub: Vec::push of a non-Copy
// function-parameter (BlockArgument) must not insert the hoisted-guard
// alloca after its store. Before the fix, nullOutDropSlot's
// BlockArgument fallback path created the guard alloca at the current
// (.push site) insertion point but inserted the live-handle store at
// the start of the owner block, producing IR that failed MLIR's SSA
// dominance check ("operand does not dominate this use").
//
// Shape: a function takes a `String` parameter and pushes it onto a
// locally-built `Vec<String>`. The parameter is a BlockArgument of the
// function entry block, exactly mirroring the actor receive-handler
// pattern in examples/services/pub_sub.hew (`Broker::subscribe`),
// where the topic parameter is a block argument of the dispatched
// handler block.
fn build(topic: String) -> Vec<String> {
    let bag: Vec<String> = [];
    bag.push(topic);
    bag
}

fn main() {
    let v = build("orders");
    if v.len() == 1 {
        print("PASS\n");
    } else {
        print("FAIL\n");
    }
}
