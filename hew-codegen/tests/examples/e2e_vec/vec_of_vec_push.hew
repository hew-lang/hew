// Regression for #1694: Vec<Vec<string>> push must transfer ownership of the
// inner Vec's heap buffer. Previously, the source identifier's RAII guard
// alloca was not nulled after `Vec::push` of a non-Copy element, so on inner
// scope exit the runtime freed a buffer that the outer Vec now owned, leaving
// the pushed slot with a dangling pointer.
fn make_rows() -> Vec<Vec<string>> {
    let result: Vec<Vec<string>> = [];
    var i: i32 = 0;
    while i < 2 {
        let row: Vec<string> = [];
        row.push("hello");
        row.push("world");
        result.push(row);
        i = i + 1;
    }
    result
}

fn main() {
    let rows = make_rows();
    var ok = true;
    var ri: i32 = 0;
    while ri < 2 {
        let row = rows.get(ri as i64);
        if row.len() != 2 {
            ok = false;
        }
        ri = ri + 1;
    }
    if ok {
        print("PASS\n");
    } else {
        print("FAIL\n");
    }
}
