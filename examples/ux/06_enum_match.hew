// Enum with pattern matching
enum Colour {
    Red;
    Green;
    Blue;
}

fn colour_name(c: Colour) {
    match c {
        Red => println("Red"),
        Green => println("Green"),
        Blue => println("Blue"),
    }
}

fn main() {
    let c1 = Red;
    let c2 = Green;
    let c3 = Blue;
    colour_name(c1);
    colour_name(c2);
    colour_name(c3);
}
