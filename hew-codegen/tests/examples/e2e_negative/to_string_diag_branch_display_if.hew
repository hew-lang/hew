// Negative test: to_string of an if expression that yields an owned Display
// value in each branch is rejected at codegen.  extractYieldedIdentifier
// cannot resolve a single canonical owner for multi-branch shapes; after
// Display::fmt consumes the selected branch value, but that selected binding
// remains registered for caller-side drop -> double-free.
// Supported workaround: bind the if result to a local variable first.
type Greeting {
    text: String;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> String {
        val.text
    }
}

fn main() {
    let flag = true;
    let g = Greeting { text: "hello" };
    let h = Greeting { text: "world" };
    let s = to_string(if flag { g } else { h });
    println(s);
}
