// Enum with payload

enum Maybe {
    Just(int);
    Nothing;
}

fn unwrap_or(m: Maybe, fallback: int) -> int {
    match m {
        Just(x) => x,
        Nothing => fallback,
    }
}

fn main() {
    let val1 = Just(42);
    let val2 = Nothing;

    println(unwrap_or(val1, 0));
    println(unwrap_or(val2, 99));
}
