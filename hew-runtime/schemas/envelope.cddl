; Hew wire envelope CDDL schema — doc-of-truth for the CBOR wire layer.
;
; Every on-wire CBOR frame produced by the Hew runtime MUST conform to one
; of the two top-level rules below. Decoders MUST reject frames that do not
; match (unknown-version, wrong major type, missing required fields).
;
; Encoding note: this schema describes the *payload* shape. The transport
; layer (QUIC stream or TCP) is responsible for framing (e.g. length-prefix
; or chunked reads). The payload length MUST NOT be re-encoded inside the
; CBOR envelope — doing so would create a redundant source of truth.
;
; Version note: the `version` field guards the whole schema. Decoders that
; do not recognise a version value MUST return an UnknownVersion error rather
; than attempting to parse further.
;
; CP-1 coordination: A2 (QUIC stream framing) owns the transport container.
; The CDDL below describes what lives inside that container.
;
; W2 will add handshake.cddl once the handshake codec lands.

; ── Top-level rule ───────────────────────────────────────────────────────────
;
; A wire frame is either a control frame or a data envelope frame.
; Both share the same outer map structure; `frame_type` selects the branch.

wire-frame = control-frame / envelope-frame

; ── Control frame ────────────────────────────────────────────────────────────
;
; Used for node-level signalling: keep-alive, capability negotiation, etc.
; Payload is a byte string whose interpretation is protocol-defined.
;
; ctrl_kind = 1 carries registry-gossip-payload.
; ctrl_kind = 2 carries the SWIM control payload (defined by the SWIM codec).
; ctrl_kind = 3 carries monitor-req-payload   (cross-node monitor request).
; ctrl_kind = 4 carries monitor-down-payload  (cross-node monitor DOWN).
; ctrl_kind = 5 carries monitor-req-payload   (cross-node demonitor request;
;                                              same identifying triple as req).
; ctrl_kind = 6 carries link-req-payload      (cross-node link request).
; ctrl_kind = 7 carries monitor-down-payload  (cross-node link DOWN; same
;                                              {ref_id, reason} shape as monitor
;                                              DOWN — the divergence is the
;                                              receiver's mailbox-EXIT handling).
; ctrl_kind = 8 carries link-req-payload      (cross-node unlink request; same
;                                              identifying payload as link req).
; ctrl_kind = 9 carries setup-result-payload  (monitor setup acknowledgement).
; ctrl_kind = 10 carries setup-result-payload (link setup acknowledgement).

control-frame = {
    version:    1 => wire-version,
    frame_type: 2 => 0,            ; 0 = control
    ctrl_kind:  3 => uint,         ; protocol-defined control kind tag
    payload:    4 => bstr,         ; 0..* bytes; empty bstr for bare signals
}

registry-gossip-payload = {
    op:       1 => registry-gossip-op,
    name:     2 => text,           ; bounded by runtime to 1024 UTF-8 bytes
    location: 3 => location,       ; exact identity for both add and remove
}

registry-gossip-op = 5 / 6         ; add / remove

; ── Cross-node monitor payloads ───────────────────────────────────────────────
;
; monitor-req-payload identifies a monitor registration: watcher node W,
; registration ref_id, watching target actor `serial` on the owning node. Used
; by both CTRL_MONITOR_REQ (register) and CTRL_DEMONITOR (retract).
;
; monitor-down-payload carries the terminal signal back to the watcher: the
; echoed ref_id and the terminal reason code.

monitor-req-payload = {
    watcher: 1 => location,
    ref_id:  2 => uint,            ; watcher's local monitor-registration id
    target:  3 => location,
    setup_id: 4 => uint,           ; zero for demonitor
}

monitor-down-payload = {
    ref_id: 1 => uint,             ; echoed from the request
    target: 2 => location,
    reason: 3 => down-reason,
}

down-reason = {
    tag:  1 => 1,                  ; 1 = actor-state
    code: 2 => int,
}

; ── Cross-node link payloads ──────────────────────────────────────────────────
;
; link-req-payload establishes a BIDIRECTIONAL cross-node link: linker node L,
; registration ref_id, links target actor `target_serial` on the owning node
; under `policy_tag`. It carries the linking actor's serial (linker_serial) so
; the owning node can register the reverse link (the owning actor's death must
; also fire into the linker). Used by both CTRL_LINK_REQ (establish) and
; CTRL_UNLINK (retract). A cross-node link DOWN reuses monitor-down-payload.
;
; policy_tag is the PartitionPolicy discriminant (FailFast=0, Deadline=1,
; MonitorLost=2, CrashLinked=3, Quarantine=4).

link-req-payload = {
    linker:      1 => location,
    ref_id:      2 => uint,        ; linker's local link-registration id
    target:      3 => location,
    policy_tag:  4 => uint,        ; PartitionPolicy discriminant (0..4)
    reciprocate: 5 => uint,        ; 1 = original request, 0 = reverse (bounds the
                                   ; bidirectional handshake to one round trip)
    setup_id:    6 => uint,        ; zero for unlink
}

setup-result-payload = {
    setup_id: 1 => uint,
    ref_id:   2 => uint,
    target:   3 => location,
    status:   4 => 0..2,
}

; ── Envelope frame ───────────────────────────────────────────────────────────
;
; Carries a single actor-to-actor message across a node boundary.
; Field numbers mirror the legacy HBF field ordering (fields 1-6) so that
; tooling and documentation can cross-reference both representations.
;
; source_node_id is 0 on reply envelopes; non-zero on outbound ask requests.
; request_id is 0 for fire-and-forget; > 0 means a reply is expected (or this
; is a reply to a prior ask).

envelope-frame = {
    version:          1 => wire-version,
    frame_type:       2 => 1,            ; 1 = envelope
    target:           3 => location / nil, ; nil only for replies
    source:           4 => location / nil,
    msg_type:         5 => int,          ; signed; valid range 0..=2^30-1 (zigzag legacy)
    payload:          6 => bstr,         ; serialised message body; 0..* bytes.
                                         ; The bytes inside this bstr are the
                                         ; per-`#[wire]`-type CBOR body described
                                         ; by `wire-body.cddl` (`wire-body` rule).
    request_id:       7 => uint,         ; 0 = fire-and-forget
}

; ── Primitive aliases ────────────────────────────────────────────────────────

wire-version = 2        ; current schema version; decoders reject unknown values
node-id = bstr .size 16
location = {
    node:        1 => node-id,
    slot:        2 => uint, ; non-zero
    incarnation: 3 => uint, ; non-zero, <= u32 max
}

node-session = {
    node:        1 => node-id,
    incarnation: 2 => uint, ; non-zero, <= u32 max
}

swim-gossip-entry = {
    member:      1 => node-session,
    state:       2 => int,
    incarnation: 3 => uint,
}

swim-control-payload = {
    msg_type:   1 => int,
    from:       2 => node-session,
    incarnation: 3 => uint,
    target:     4 => node-session / nil,
    gossip:     5 => [* swim-gossip-entry],
}
