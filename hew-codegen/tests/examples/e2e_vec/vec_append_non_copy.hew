// Regression for #1698: Vec::append transfers ownership of the source Vec's
// heap buffer. Previously, the source identifier's drop slot was not nulled
// after hew_vec_append, so on inner scope exit the runtime freed the source
// Vec's backing store that the destination Vec now owned, leaving the
// destination's newly appended elements with dangling pointers.
fn make_combined() -> Vec<string> {
    let dst: Vec<string> = [];
    var i: i32 = 0;
    while i < 2 {
        let batch: Vec<string> = [];
        batch.push("hello");
        batch.push("world");
        dst.append(batch);
        i = i + 1;
    }
    dst
}

fn main() {
    let v = make_combined();
    if v.len() == 4 && v.get(0) == "hello" && v.get(2) == "hello" {
        print("PASS\n");
    } else {
        print("FAIL\n");
    }
}
