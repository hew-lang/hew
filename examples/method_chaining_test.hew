type Point {
    x: f64;
    y: f64;
}

impl PointMethods for Point {
    fn translate(pt: Point, dx: f64, dy: f64) -> Point {
        return Point { x: pt.x + dx, y: pt.y + dy };
    }
    fn distance(pt: Point) -> f64 {
        return pt.x * pt.x + pt.y * pt.y;
    }
    fn scale(pt: Point, factor: f64) -> Point {
        return Point { x: pt.x * factor, y: pt.y * factor };
    }
}

fn main() {
    let p1 = Point { x: 3.0, y: 4.0 };
    // Test method chaining through variables
    let p2 = p1.translate(1.0, 1.0);
    let p3 = p2.scale(2.0);
    let d = p3.distance();
}
