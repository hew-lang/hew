#!/usr/bin/env bash
set -euo pipefail

# hew-viz — Legacy batch visualizer for pre-v0.5 AST/MLIR emitters.
#
# Usage:
#   hew-viz <file.hew> [output-dir]
#
# Status:
#   Disabled for Hew v0.5. The old `hew build --emit-ast` and
#   `hew build --emit-mlir` producers were removed, so this wrapper fails closed
#   instead of guessing at a stale visualization.
#
# Current v0.5 inspection entry points:
#   hew compile --dump-mir raw|checked|elab <file.hew>
#   hew machine diagram [--format mermaid|graphviz|json] <file.hew>
#   hew machine list <file.hew>
#
# Options:
#   --help, -h            Show this help

INPUT=""
OUTDIR=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            awk 'NR >= 4 { if ($0 !~ /^#/) exit; sub(/^# ?/, ""); print }' "$0"
            exit 0
            ;;
        -fn|--function)
            shift 2 ;;
        -f|--format)
            shift 2 ;;
        -*)
            echo "Unknown option: $1" >&2; exit 1 ;;
        *)
            if [[ -z "$INPUT" ]]; then
                INPUT="$1"
            elif [[ -z "$OUTDIR" ]]; then
                OUTDIR="$1"
            else
                echo "Unexpected argument: $1" >&2; exit 1
            fi
            shift ;;
    esac
done

if [[ -z "$INPUT" ]]; then
    echo "Usage: hew-viz <file.hew> [output-dir] [--function name]" >&2
    exit 1
fi

if [[ ! -f "$INPUT" ]]; then
    echo "Error: $INPUT not found" >&2
    exit 1
fi

cat >&2 <<'EOF'
Error: scripts/viz/generate-all requires the removed pre-v0.5 AST/MLIR emitters.

Current v0.5 inspection entry points are:
  hew compile --dump-mir raw|checked|elab <file.hew>
  hew machine diagram [--format mermaid|graphviz|json] <file.hew>
  hew machine list <file.hew>

Batch visualization is disabled rather than emitting stale or guessed diagrams.
EOF
exit 2
