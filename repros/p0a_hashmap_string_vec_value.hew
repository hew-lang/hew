fn main() {
    let m: HashMap<string, Vec<i64>> = HashMap::new();
    let xs: Vec<i64> = Vec::new();
    xs.push(1);
    xs.push(2);
    xs.push(3);
    m.insert("vec", clone xs);
    xs.push(99);
    let got: Option<Vec<i64>> = m.get("vec");
    m.remove("vec");
    match got {
        Some(v) => println(f"got={v.len()}:{v.get(0)}:{v.get(1)}:{v.get(2)} src={xs.len()}"),
        None => println("missing"),
    }
}
