//! Status: aspirational (Hew roadmap: actor/supervisor codegen-rs runtime parity)
//! Description: Test: Actors and Messaging

// Test: Actors and Messaging
// Exercises: actor definition, receive fn, spawn, message send, actor state, stop
actor Counter {
    let count: i64;
    receive fn increment(amount: i64) {
        count = count + amount;
    }
    receive fn get_count() -> i64 {
        count
    }
    receive fn reset() {
        count = 0;
    }
}

actor Printer {
    let prefix: i64;
    receive fn print_msg(value: i64) -> i64 {
        println(f"  [Printer {prefix}] got: {value}");
        value
    }
}

fn test_basic_actor() -> i64 {
    println("--- test_basic_actor ---");
    let counter = spawn Counter(count: 0);
    counter.increment(10);
    counter.increment(20);
    counter.increment(12);
    let count = await counter.get_count();
    if count == 42 {
        println("PASS: basic actor spawn + messaging");
        1
    } else {
        println("FAIL: basic actor spawn + messaging");
        0
    }
}

fn test_multiple_actors() -> i64 {
    println("--- test_multiple_actors ---");
    let p1 = spawn Printer(prefix: 1);
    let p2 = spawn Printer(prefix: 2);
    let first = p1.print_msg(100);
    let second = p2.print_msg(200);
    let third = p1.print_msg(300);
    await first;
    await second;
    await third;
    println("PASS: multiple actors");
    1
}

fn test_lambda_actor() -> i64 {
    println("--- test_lambda_actor ---");
    let doubler = actor |x: i64| {
        println(f"  doubled: {x * 2}");
    };
    doubler.send(21);
    doubler.send(5);
    await doubler.close();
    println("PASS: lambda actor");
    1
}

fn test_actor_factory() -> i64 {
    println("--- test_actor_factory ---");
    let m = make_multiplier(3);
    m.send(10);
    m.send(7);
    await m.close();
    println("PASS: actor factory");
    1
}

fn make_multiplier(factor: i64) -> Duplex<i64, ()> {
    actor |x: i64| {
        println(f"  multiplied: {x * factor}");
    }
}

fn test_complex_lambda() -> i64 {
    println("--- test_complex_lambda ---");
    let processor = actor |n: i64| {
        if n > 10 {
            println(f"  large: {n}");
        } else {
            println(f"  small: {n}");
        }
    };
    processor.send(5);
    processor.send(15);
    await processor.close();
    println("PASS: complex lambda actor");
    1
}

fn main() -> i64 {
    println("=== Test: Actors & Messaging ===");
    var passed: i64 = 0;
    let total: i64 = 5;
    passed = passed + test_basic_actor();
    passed = passed + test_multiple_actors();
    passed = passed + test_lambda_actor();
    passed = passed + test_actor_factory();
    passed = passed + test_complex_lambda();
    println("");
    println(f"Passed: {passed}/{total}");
    if passed == total {
        0
    } else {
        1
    }
}
