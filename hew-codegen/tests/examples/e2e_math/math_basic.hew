import std::math;

fn main() {
    // Integer abs
    println(math.abs(-5));
    println(math.abs(3));
    println(math.abs(0));

    // Integer min/max
    println(math.min(3, 7));
    println(math.max(3, 7));

    // Clamp
    println(math.clamp(10, 0, 5));
    println(math.clamp(-3, 0, 5));
    println(math.clamp(3, 0, 5));

    // Sign
    println(math.sign(-42));
    println(math.sign(0));
    println(math.sign(99));

    // Float abs
    println(math.abs_f(-2.5));

    // Sqrt
    println(math.sqrt(4.0));
    println(math.sqrt(9.0));

    // Pow
    println(math.pow(2.0, 3.0));
    println(math.pow(3.0, 2.0));

    // Floor / Ceil / Round
    println(math.floor(2.7));
    println(math.ceil(2.3));
    println(math.round(2.5));
    println(math.round(2.4));

    // Constants
    println(math.pi());
    println(math.e());
}
