// Multiple stdlib imports with handle types — tests cross-module
// method dispatch and trait impl generation don't cause duplicate
// generation or mangling conflicts. Regression test for #384.
import std::net::url;
import std::text::regex;

fn main() {
    // Use url module (Url handle type)
    let u = url.parse("https://hew.sh");
    println(u.host());

    // Use regex module (Regex handle type)
    let re = regex.new("[a-z]+");
    let found = re.is_match("hello");
    println(found);

    // Both handle types are dropped here — exercises cross-module cleanup
    println("done");
}
