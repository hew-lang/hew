import std::channel::channel;

fn producer(tx: Sender, label: String) {
    tx.send(label + ":alpha");
    tx.send(label + ":beta");
    tx.close();
}

fn main() {
    let (tx, rx): (channel.Sender, channel.Receiver<String>) = channel.new(8);

    // Clone the sender for a second producer.
    let tx2 = tx.clone();

    // Two producers send through their own sender handles.
    producer(tx, "P1");
    producer(tx2, "P2");

    // The single consumer drains all messages.
    var count: int = 0;
    var done = false;
    while !done {
        match rx.recv() {
            Some(msg) => {
                println(msg);
                count = count + 1;
            },
            None => { done = true; },
        }
    }

    println(count);
    rx.close();
}
