actor BytesSliceCrasher {
    receive fn boom() {
        let b: bytes = bytes::new();
        b.push(1);
        b.push(2);
        let _slice: bytes = b[0..99];
    }
}

actor BytesSliceProbe {
    receive fn ping() -> i64 {
        0
    }
}

fn main() -> i64 {
    let crasher = spawn BytesSliceCrasher;
    let probe = spawn BytesSliceProbe;
    crasher.boom();
    sleep(300ms);
    match await probe.ping() {
        Ok(v) => v,
        Err(_) => 1,
    }
}

