// `bytes.set(i, b)` with an out-of-range index fails closed: the runtime routes
// through the bytes index-OOB trap rather than writing past the buffer. In main
// context there is no actor recovery frame, so the helper aborts with exit 134,
// matching bytes_index_oob_traps.
fn main() -> i64 {
    let b: bytes = bytes::new();
    b.push(1);
    b.push(2);
    b.push(3);
    // Index 99 is past the end of a length-3 buffer: must trap before the write.
    b.set(99, 7);
    // Unreachable: the OOB trap fires above.
    0
}
