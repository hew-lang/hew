//! @name Wire Types
//! @description Wire structs and enums for serialization

#[wire]
struct UserMessage {
    name: string @1,
    age: int @2,
}

wire enum Command {
    Start;
    Stop;
    Pause;
}

fn main() {
    println("Wire types define serialization schemas.");
    println("Fields have explicit tags (@1, @2) for");
    println("backwards-compatible binary encoding.");
}
