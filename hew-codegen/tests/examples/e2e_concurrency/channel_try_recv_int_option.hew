import std::channel::channel;

fn main() {
    let (tx, rx) = channel.new(4);

    // Send 0 — must be distinguishable from "no message".
    tx.send(0);
    tx.send(42);
    tx.send(-1);

    // try_recv returns Some(value) while messages are available.
    match rx.try_recv() {
        Some(v) => println(f"got: {v}"),
        None => println("unexpected none"),
    }
    match rx.try_recv() {
        Some(v) => println(f"got: {v}"),
        None => println("unexpected none"),
    }
    match rx.try_recv() {
        Some(v) => println(f"got: {v}"),
        None => println("unexpected none"),
    }

    tx.close();

    // Channel drained and closed — try_recv returns None.
    match rx.try_recv() {
        Some(v) => println(f"unexpected: {v}"),
        None => println("none"),
    }

    rx.close();
}
