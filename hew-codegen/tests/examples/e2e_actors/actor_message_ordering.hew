// Test: Messages arrive in FIFO order
// Verifies: mailbox guarantees send-order processing
actor Recorder {
    receive fn log_msg(n: int) {
        println(f"msg {n}");
    }
}

fn main() {
    let r = spawn Recorder;
    for i in 0 .. 10 {
        r.log_msg(i);
    }
    await close(r);
    println("done");
}
