// Accept fixture: ask-shaped lambda actor with call-syntax dispatch.
// `actor |n: i64| -> i64 { n*2 }` produces `LambdaPid<i64, i64>`.
// Calling `dbl(5)` returns `Result<i64, AskError>` at the type level.
// Runtime: `hew_lambda_actor_ask` is called, the dispatch thread invokes
// the synthesised body, the reply is delivered through a one-shot reply
// channel, and the codegen wraps the payload in `Ok(v)`. On any non-Ok
// status code (stopped / send-fail / orphaned panic), the B2 ask-error
// branch materialises `Err(AskError)` — see runtime tests
// `ask_body_panic_orphans_reply_channel` and `panic_marks_stopped` for
// the Err-status producer side (HEW source has no expression that
// constructs a body panic without UB, so the runtime side is unit-tested
// in `hew-runtime` rather than driven through a vertical-slice fixture).
fn main() {
    let dbl = actor |n: i64| -> i64 {
        n * 2
    };
    let r = dbl(5);
    match r {
        Ok(v) => println(f"ask {v}"),
        Err(_) => println("err"),
    }
}
