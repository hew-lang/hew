// Negative test: to_string of a block expression whose value position is an
// if/else that yields an owned Display value is rejected at codegen.
// The block wrapper smuggles a multi-branch shape past the direct ExprIf
// check; after Display::fmt consumes the selected branch value, the other
// binding's caller-side drop registration would fire at scope exit -> double-free.
// Supported workaround: bind the if result to a local variable first.
type Greeting {
    text: string;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> string {
        val.text
    }
}

fn main() {
    let flag = true;
    let g = Greeting { text: "hello" };
    let h = Greeting { text: "world" };
    let s = to_string({ if flag { g } else { h } });
    println(s);
}
