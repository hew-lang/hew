//! @name Async/Await
//! @description Actor call-and-await

actor FibPrinter {
    receive fn print_fib(n: i64) -> i64 {
        let result = fib(n);
        print("fib(10) = ");
        println(result);
        result
    }
}

fn fib(n: i64) -> i64 {
    if n <= 1 {
        n
    } else {
        fib(n - 1) + fib(n - 2)
    }
}

fn main() {
    let fibber = spawn FibPrinter;
    await fibber.print_fib(10);
}
