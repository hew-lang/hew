import std::stream;

fn main() {
    let (sink, input) = stream.bytes_channel(8);

    let buf1: bytes = bytes::new();
    buf1.push(10);

    let buf2: bytes = bytes::new();
    buf2.push(20);

    let buf3: bytes = bytes::new();
    buf3.push(30);

    sink.write(buf1);
    sink.write(buf2);
    sink.write(buf3);
    sink.close();

    // Take only the first 2 items
    let taken = input.take(2);

    for await item in taken {
        println(item.get(0));
    }
    println("done");
}
