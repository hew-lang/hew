//! Status: aspirational (Hew roadmap: actor/supervisor codegen-rs runtime parity)
//! Description: Regression: compound assignment on field

// Regression: compound assignment on field
actor Counter {
    let value: i64;
    receive fn set(v: i64) {
        value = v;
    }
    receive fn double() {
        value *= 2;
    }
    receive fn scale(n: i64) {
        value *= n;
    }
    receive fn print_value() -> i64 {
        println(value);
        value
    }
}

fn main() {
    let counter = spawn Counter(value: 0);
    counter.set(3);
    counter.double();
    counter.scale(4);
    await counter.print_value();
}
