/// Second library that intentionally re-uses the same generic free-function
/// name (`identity<T>`) as `genericlib`.  Used by the
/// `cross_module_generic_collision` regression to prove that the codegen
/// generic-function registry distinguishes definitions by module, not by
/// bare name.  The body prints a marker so a wrong-body dispatch (the
/// pre-fix behaviour) prints `genericlib::identity` for both call sites
/// instead of one each, and fails the test.
pub fn identity<T>(x: T) -> T {
    println("alt::identity");
    x
}
