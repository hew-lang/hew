//! Round-trip tests for std::encoding::compress.

import std::encoding::compress;

import std::testing;

// WASM-TODO(#1451): Add wasm coverage once std::encoding::compress is verified on wasm32-wasip1.
const DEFAULT_DECOMPRESS_LIMIT: i64 = 64 * 1024 * 1024;

fn assert_bytes_eq(actual: bytes, expected: bytes) {
    testing.assert_eq(actual.len(), expected.len());
    for i in 0 .. expected.len() {
        testing.assert_eq_u8(actual[i], expected[i]);
    }
}

#[test]
fn test_gzip_round_trip() {
    let input: bytes = bytes::new();
    input.push(72); // H
    input.push(101); // e
    input.push(108); // l
    input.push(108); // l
    input.push(111); // o
    let compressed = compress.gzip_compress(input);
    let decompressed = compress.gzip_decompress(compressed, DEFAULT_DECOMPRESS_LIMIT);
    assert_bytes_eq(decompressed, input);
}

#[test]
fn test_gzip_round_trip_empty() {
    let input: bytes = bytes::new();
    let compressed = compress.gzip_compress(input);
    let decompressed = compress.gzip_decompress(compressed, DEFAULT_DECOMPRESS_LIMIT);
    assert_bytes_eq(decompressed, input);
}

#[test]
fn test_deflate_round_trip() {
    let input: bytes = bytes::new();
    input.push(0);
    input.push(1);
    input.push(2);
    input.push(3);
    input.push(255);
    let compressed = compress.deflate_compress(input);
    let decompressed = compress.deflate_decompress(compressed, DEFAULT_DECOMPRESS_LIMIT);
    assert_bytes_eq(decompressed, input);
}

#[test]
fn test_deflate_round_trip_empty() {
    let input: bytes = bytes::new();
    let compressed = compress.deflate_compress(input);
    let decompressed = compress.deflate_decompress(compressed, DEFAULT_DECOMPRESS_LIMIT);
    assert_bytes_eq(decompressed, input);
}

#[test]
fn test_zlib_round_trip() {
    let input: bytes = bytes::new();
    input.push(120); // x
    input.push(121); // y
    input.push(122); // z
    let compressed = compress.zlib_compress(input);
    let decompressed = compress.zlib_decompress(compressed, DEFAULT_DECOMPRESS_LIMIT);
    assert_bytes_eq(decompressed, input);
}

#[test]
fn test_zlib_round_trip_empty() {
    let input: bytes = bytes::new();
    let compressed = compress.zlib_compress(input);
    let decompressed = compress.zlib_decompress(compressed, DEFAULT_DECOMPRESS_LIMIT);
    assert_bytes_eq(decompressed, input);
}
