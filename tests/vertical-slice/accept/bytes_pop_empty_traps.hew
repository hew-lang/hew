// `bytes.pop()` on an empty buffer fails closed: the spec pop signature has no
// Option, so the empty case routes through the bytes runtime bounds trap rather
// than returning a fabricated sentinel. In main context there is no actor
// recovery frame, so the helper aborts with exit 134, matching the b[i] index
// OOB trap (bytes_index_oob_traps).
fn main() -> i64 {
    let b: bytes = bytes::new();
    // Empty buffer: pop must trap before returning.
    let x: u8 = b.pop();
    // Unreachable: the empty-pop trap fires above.
    x as i64
}
