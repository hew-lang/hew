// HashMap test

fn main() {
    let map: HashMap<String, i32> = HashMap::new();
    map.insert("a", 100);
    map.insert("b", 200);

    match map.get("a") {
        Some(v) => println(v),
        None => println("missing"),
    }
    match map.get("b") {
        Some(v) => println(v),
        None => println("missing"),
    }
}
