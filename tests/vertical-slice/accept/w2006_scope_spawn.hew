// Accept fixture: w2006_scope_spawn — positive `scope { fork ... }` MIR
// invariant for W2.006 Stage 1.
//
// What this proves:
//   * `hew check` accepts a `scope { fork { worker(); } }` body inside an
//     actor handler (the source-syntax surface is preserved unchanged).
//   * `hew compile --dump-mir raw` produces a RawMirFunction whose
//     instruction stream contains the canonical `hew_task_new` and
//     `hew_task_scope_spawn` runtime-ABI calls (and the
//     `hew_task_scope_new`/`hew_task_scope_destroy` scope lifecycle pair).
//   * The legacy `hew_scope_spawn`/`hew_scope_create`/`hew_scope_free`
//     symbols MUST NOT appear in the MIR dump (W2.006 removal).
//   * The full native binary links and runs after W4.010's TaskEntry adapter
//     bridges the free function to SpawnTaskDirect.
//
// Harness verb: hew check; hew compile --dump-mir raw; hew compile; execute binary

fn worker() {
    // No-arg, unit-returning callee — the shape lower_spawned_fn_task accepts.
}

actor _Driver {
    receive fn drive() {
        scope {
            fork { worker(); }
        };
    }
}

fn main() -> i64 {
    let d = spawn _Driver;
    d.drive();
    0
}
