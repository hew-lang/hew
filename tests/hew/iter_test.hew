fn test_take_str_fewer_than_length() {
    let v: Vec<String> = Vec::new();
    v.push("a"); v.push("b"); v.push("c");
    let result = iter.take_str(v, 2);
    testing.assert_eq(result.len(), 2);
    testing.assert_eq_str(result.get(0), "a");
    testing.assert_eq_str(result.get(1), "b");
}

