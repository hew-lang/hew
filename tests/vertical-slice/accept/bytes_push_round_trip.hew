//! Behavioural proof that `bytes.push(...)` mutation propagates back to the
//! caller's `BytesTriple` local and a subsequent value-position
//! `bytes.to_string()` reads the updated buffer.
//!
//! Pushes the ASCII bytes for `Hi` onto a fresh buffer, then converts to a
//! `string` and prints it. A successful run prints `Hi` exactly and exits 0,
//! exercising the full push write-back + `Bytes -> String` conversion ABI:
//! the runtime, the catalog, the `std/io.hew` `extern_symbol` annotations, and
//! the codegen FFI seam all agree that `bytes` is a `BytesTriple` value
//! (LLVM `{ptr, i32, i32}`).

fn main() -> i64 {
    let b: bytes = bytes::new();
    b.push(72); // 'H'
    b.push(105); // 'i'
    let s: string = b.to_string();
    println(s);
    0
}
