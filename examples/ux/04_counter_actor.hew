// Simple counter actor

actor Counter {
    let count: int;

    receive fn increment(n: int) {
        self.count = self.count + n;
    }

    receive fn get_count() -> int {
        self.count
    }
}

fn main() {
    let counter = spawn Counter(count: 0);
    counter.increment(5);
    counter.increment(10);
    println(await counter.get_count());
}
