actor Counter {
    let count: i64;

    init(initial: i64) {
        count = initial;
    }

    receive fn increment(n: i64) {
        count = count + n;
    }

    receive fn total() -> i64 {
        count
    }

    #[on(start)]
    fn boot() {
        count += 1;
    }
}

fn main() -> i64 {
    let counter = spawn Counter(initial: 9);
    counter.increment(32);
    counter.total()
}
