// Reject test: scope-wrapped while loop whose break value is a field access
// passed as a call argument that takes ownership.
// NOTE: Currently caught by type checker (loops produce ()) before codegen
// guard fires.  Guard is defense-in-depth for typed break-values.

type Inner {
    value: String;
}

impl Drop for Inner {
    fn drop(i: Inner) {
        println(i.value);
    }
}

type Outer {
    inner: Inner;
    tag: String;
}

fn consume(i: Inner) {
    println(i.value);
}

fn main() -> int {
    let flag = true;
    let obj = Outer { inner: Inner { value: "hello" }, tag: "t" };
    consume(scope { while flag { break obj.inner; } });
    return 0;
}
