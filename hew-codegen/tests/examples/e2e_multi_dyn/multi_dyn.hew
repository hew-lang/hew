trait Printable {
    fn to_text(val: Self) -> string;
}

trait Measurable {
    fn size(val: Self) -> int;
}

struct Box {
    label: string,
    width: int,
}

impl Printable for Box {
    fn to_text(b: Box) -> string {
        b.label
    }
}

impl Measurable for Box {
    fn size(b: Box) -> int {
        b.width
    }
}

fn describe(item: dyn (Printable + Measurable)) {
    println(item.to_text());
    println(item.size());
}

fn main() {
    let b = Box { label: "cargo", width: 10 };
    describe(b);
}
