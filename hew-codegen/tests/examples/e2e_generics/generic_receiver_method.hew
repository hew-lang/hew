type Pair<T> {
    first: T;
    second: T;
}

fn make_pair<T>(a: T, b: T) -> Pair<T> {
    Pair { first: a, second: b }
}

fn swap<T>(p: Pair<T>) -> Pair<T> {
    Pair { first: p.second, second: p.first }
}

fn first_of<T>(p: Pair<T>) -> T {
    p.first
}

fn main() {
    let p1 = make_pair<int>(10, 20);
    let s1 = swap<int>(p1);
    println(s1.first);
    println(s1.second);

    let p2 = make_pair<int>(3, 7);
    println(first_of<int>(p2));

    let p3 = make_pair<String>("hello", "world");
    let s3 = swap<String>(p3);
    println(s3.first);
    println(s3.second);

    let p4 = make_pair<String>("foo", "bar");
    println(first_of<String>(p4));
}
