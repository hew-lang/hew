// Tests AssertOp, AssertEqOp, AssertNeOp — all have zero E2E coverage.
fn main() {
    // assert(cond) — passes when condition is computed
    let sum = 2 + 3;
    assert(sum == 5);
    let positive = 42 - 10;
    assert(positive > 0);

    // assert_eq(a, b) — passes when equal (integers)
    let doubled = 50 * 2;
    assert_eq(doubled, 100);

    // assert_eq with floats
    let pi = 3.0 + 0.14;
    assert_eq(pi, 3.14);

    // assert_ne(a, b) — passes when not equal
    let a = 1;
    let b = a + 1;
    assert_ne(a, b);

    // assert_eq with strings
    let greeting = "hello";
    assert_eq(greeting, "hello");

    // assert_ne with strings
    assert_ne("hello", "world");

    println("all assertions passed");
}
