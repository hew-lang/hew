// Tests to_string for unsigned integer primitives.
// 2147483648 = INT32_MAX + 1; stored as i32 0x80000000.
// With is_unsigned=false (wrong): hew_int_to_string gives "-2147483648".
// With is_unsigned=true  (correct): hew_uint_to_string gives "2147483648".
fn main() {
    let x: u32 = 2147483648;
    println(to_string(x));

    let y: u8 = 255;
    println(to_string(y));

    let z: u16 = 65535;
    println(to_string(z));
}
