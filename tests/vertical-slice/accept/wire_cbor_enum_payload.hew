// Validation: a `#[wire]` enum with payload variants round-trips through the
// CBOR body codec. Under the map-of-one shape a payload variant encodes as a
// single-entry map `{tag: [field0, field1, ...]}`, while a unit variant stays a
// bare tag. This fixture constructs `Rect(40, 2)`; the recovered fields sum to
// 42, so a mis-tagged or mis-ordered payload changes the exit code.
#[wire]
enum Shape {
    Dot;
    Circle(i64);
    Rect(i64, i64);
}

fn main() -> i64 {
    let s = Shape::Rect(40, 2);
    let back = Shape.decode(s.encode());
    match back {
        Shape::Dot => 0,
        Shape::Circle(r) => r,
        Shape::Rect(w, h) => w + h,
    }
}
