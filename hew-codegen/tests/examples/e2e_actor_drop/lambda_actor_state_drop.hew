// Regression: the codegen-emitted state-drop function for a lambda actor
// (`generateSpawnLambdaActorExpr` in MLIRGenActor.cpp) must invoke `impl Drop`
// on every owned captured variable when the actor is killed.  Without the
// state-drop function the captured value is raw-freed and its `impl Drop`
// is never called.
//
// `Token` has a custom `impl Drop` that prints "drop_lambda:<id>".  A lambda
// actor captures `tok` by value (move) from the enclosing scope.  After the
// actor is confirmed alive (ping round-trip), the actor is closed; this runs
// its terminate path and fires the state-drop function, which must call
// `Token`'s `impl Drop`.
//
// Because `tok` is moved into the lambda actor's state at spawn time, there
// is exactly one owner and therefore exactly one drop.  Expected output:
// one "pong", "done", then one "drop_lambda:7".
type Token {
    id: int;
}

impl Drop for Token {
    fn drop(t: Token) {
        println(f"drop_lambda:{t.id}");
    }
}

type Ping {
}

fn main() {
    let tok = Token { id: 7 };
    let a = actor |msg: Ping| {
        println(f"pong:{tok.id}");
    };
    a.send(Ping {  });
    await close(a);
    println("done");
}
