}

#[test]
fn test_last_str_single_element_returns_some() {
    let v: Vec<String> = Vec::new();
    v.push("only");
    let result = vec.last_str(v);
    testing.assert_true(option.is_some_str(result));
    testing.assert_eq_str(option.unwrap_or_str(result, ""), "only");
}

#[test]
fn test_last_str_empty_returns_none() {
    let v: Vec<String> = Vec::new();
    testing.assert_true(option.is_none_str(vec.last_str(v)));
}

// ── min_i32 ───────────────────────────────────────────────────────────────

#[test]
fn test_min_i32_several_elements() {
    let v: Vec<i32> = Vec::new();
    v.push(3);
    v.push(1);
    v.push(2);
    testing.assert_eq(vec.min_i32(v), 1);
}

#[test]
fn test_min_i32_single_element() {
    let v: Vec<i32> = Vec::new();
    v.push(42);
    testing.assert_eq(vec.min_i32(v), 42);
}

#[test]
fn test_min_i32_all_same() {
    let v: Vec<i32> = Vec::new();
    v.push(5);
    v.push(5);
    v.push(5);
    testing.assert_eq(vec.min_i32(v), 5);
}

#[test]
fn test_min_i32_min_is_first() {
    let v: Vec<i32> = Vec::new();
    v.push(1);
    v.push(9);
    v.push(7);
    testing.assert_eq(vec.min_i32(v), 1);
}

#[test]
fn test_min_i32_min_is_last() {
    let v: Vec<i32> = Vec::new();
    v.push(9);
    v.push(7);
    v.push(1);
    testing.assert_eq(vec.min_i32(v), 1);
}

// ── min_i64 ───────────────────────────────────────────────────────────────

#[test]
fn test_min_i64_several_elements() {
    let v: Vec<i64> = Vec::new();
    v.push(300);
    v.push(100);
    v.push(200);
    testing.assert_eq(vec.min_i64(v), 100);
}

#[test]
fn test_min_i64_single_element() {
    let v: Vec<i64> = Vec::new();
    v.push(77);
    testing.assert_eq(vec.min_i64(v), 77);
}

// ── min_f64 ───────────────────────────────────────────────────────────────

#[test]
fn test_min_f64_several_elements() {
    let v: Vec<f64> = Vec::new();
    v.push(3.0);
    v.push(1.5);
    v.push(2.0);
    testing.assert_true(vec.min_f64(v) == 1.5);
}

#[test]
fn test_min_f64_single_element() {
    let v: Vec<f64> = Vec::new();
    v.push(9.9);
    testing.assert_true(vec.min_f64(v) == 9.9);
}

// ── max_i32 ───────────────────────────────────────────────────────────────

#[test]
fn test_max_i32_several_elements() {
    let v: Vec<i32> = Vec::new();
    v.push(3);
    v.push(1);
    v.push(2);
    testing.assert_eq(vec.max_i32(v), 3);
}

#[test]
fn test_max_i32_single_element() {
    let v: Vec<i32> = Vec::new();
    v.push(42);
    testing.assert_eq(vec.max_i32(v), 42);
}

#[test]
fn test_max_i32_all_same() {
    let v: Vec<i32> = Vec::new();
    v.push(4);
    v.push(4);
    v.push(4);
    testing.assert_eq(vec.max_i32(v), 4);
}

#[test]
fn test_max_i32_max_is_first() {
    let v: Vec<i32> = Vec::new();
    v.push(9);
    v.push(1);
    v.push(5);
    testing.assert_eq(vec.max_i32(v), 9);
}

#[test]
fn test_max_i32_max_is_last() {
    let v: Vec<i32> = Vec::new();
    v.push(1);
    v.push(5);
    v.push(9);
    testing.assert_eq(vec.max_i32(v), 9);
}

// ── max_i64 ───────────────────────────────────────────────────────────────

#[test]
fn test_max_i64_several_elements() {
    let v: Vec<i64> = Vec::new();
    v.push(300);
    v.push(100);
    v.push(200);
    testing.assert_eq(vec.max_i64(v), 300);
}

#[test]
fn test_max_i64_single_element() {
    let v: Vec<i64> = Vec::new();
    v.push(77);
    testing.assert_eq(vec.max_i64(v), 77);
}

// ── max_f64 ───────────────────────────────────────────────────────────────

#[test]
fn test_max_f64_several_elements() {
    let v: Vec<f64> = Vec::new();
    v.push(3.0);
    v.push(1.5);
    v.push(2.0);
    testing.assert_true(vec.max_f64(v) == 3.0);
}

#[test]
fn test_max_f64_single_element() {
    let v: Vec<f64> = Vec::new();
    v.push(9.9);
    testing.assert_true(vec.max_f64(v) == 9.9);
}

// ── negative-value edge cases ─────────────────────────────────────────────

#[test]
fn test_min_i32_with_negatives() {
    let v: Vec<i32> = Vec::new();
    v.push(5);
    v.push(-3);
    v.push(2);
    testing.assert_eq(vec.min_i32(v), -3);
}

#[test]
fn test_max_i32_with_negatives() {
    let v: Vec<i32> = Vec::new();
    v.push(-5);
    v.push(-1);
    v.push(-9);
    testing.assert_eq(vec.max_i32(v), -1);
}

#[test]
fn test_min_f64_with_negatives() {
    let v: Vec<f64> = Vec::new();
    v.push(1.0);
    v.push(-2.5);
    v.push(0.5);
    testing.assert_true(vec.min_f64(v) == -2.5);
}

#[test]
fn test_max_f64_with_negatives() {
    let v: Vec<f64> = Vec::new();
    v.push(-1.0);
    v.push(-0.5);
    v.push(-3.0);
    testing.assert_true(vec.max_f64(v) == -0.5);
}

#[test]
fn test_index_of_i32_negative_value() {
    let v: Vec<i32> = Vec::new();
    v.push(10);
    v.push(-7);
    v.push(3);
    testing.assert_eq(vec.index_of_i32(v, -7), 1);
}

#[test]
fn test_index_of_i32_zero_value() {
    let v: Vec<i32> = Vec::new();
    v.push(1);
    v.push(0);
    v.push(2);
    testing.assert_eq(vec.index_of_i32(v, 0), 1);
}

// ── min/max empty-vector explicit panic guards ─────────────────────────────
// These tests verify that min_*/max_* emit an explicit panic (rather than
// relying on v.get(0) bounds-checking) when called on an empty vector.

#[test]
#[should_panic]
fn test_min_i32_empty_panics() {
    let v: Vec<i32> = Vec::new();
    vec.min_i32(v);
}

#[test]
#[should_panic]
fn test_max_i32_empty_panics() {
    let v: Vec<i32> = Vec::new();
    vec.max_i32(v);
}

#[test]
#[should_panic]
fn test_min_i64_empty_panics() {
    let v: Vec<i64> = Vec::new();
    vec.min_i64(v);
}

#[test]
#[should_panic]
fn test_max_i64_empty_panics() {
    let v: Vec<i64> = Vec::new();
    vec.max_i64(v);
}

#[test]
#[should_panic]
fn test_min_f64_empty_panics() {
    let v: Vec<f64> = Vec::new();
    vec.min_f64(v);
}

#[test]
#[should_panic]
fn test_max_f64_empty_panics() {
    let v: Vec<f64> = Vec::new();
    vec.max_f64(v);
}
