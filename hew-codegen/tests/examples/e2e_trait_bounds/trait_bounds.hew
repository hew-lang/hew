trait Describable {
    fn describe(val: Self) -> string;
}

type Dog {
    name: string;
}

impl Describable for Dog {
    fn describe(d: Dog) -> string {
        d.name
    }
}

fn show<T: Describable>(item: T) {
    println(item.describe());
}

fn main() {
    let d = Dog { name: "Rex" };
    show(d);
}
