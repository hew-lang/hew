//! Proofs that stdlib public surfaces accept and return `int` end-to-end.
//! One assertion per migrated module — extended in each migration commit.

import std::channel::channel;
import std::encoding::json;
import std::encoding::toml;
import std::encoding::yaml;
import std::fs;
import std::semaphore;
import std::text::semver;
import std::testing;
import std::vec;

#[test]
fn test_channel_new_accepts_int_capacity() {
    let capacity: int = 16;
    let (tx, rx) = channel.new(capacity);
    tx.close();
    rx.close();
}

#[test]
fn test_json_int_round_trip() {
    let v = json.from_int(42);
    let i: int = v.get_int();
    testing.assert_eq(i, 42);
    v.free();
}

#[test]
fn test_json_array_len_returns_int() {
    let arr = json.array().push_int(1).push_int(2).push_int(3);
    let n: int = arr.array_len();
    testing.assert_eq(n, 3);
    arr.free();
}

#[test]
fn test_toml_int_round_trip() {
    let v = toml.from_int(99);
    let i: int = v.get_int();
    testing.assert_eq(i, 99);
    v.free();
}

#[test]
fn test_yaml_int_round_trip() {
    let v = yaml.from_int(7);
    let i: int = v.get_int();
    testing.assert_eq(i, 7);
    v.free();
}

#[test]
fn test_fs_write_returns_int() {
    let path = "/tmp/hew_stdlib_int_test.txt";
    let result: int = fs.write(path, "hello");
    testing.assert_eq(result, 0);
    fs.delete(path);
}

#[test]
fn test_fs_size_returns_int() {
    let path = "/tmp/hew_stdlib_int_size_test.txt";
    fs.write(path, "hello");
    let sz: int = fs.size(path);
    testing.assert_eq(sz, 5);
    fs.delete(path);
}

#[test]
fn test_fs_mkdir_returns_int() {
    let dir = "/tmp/hew_stdlib_int_mkdir_test";
    let result: int = fs.mkdir(dir);
    testing.assert_eq(result, 0);
    fs.delete(dir);
}

#[test]
fn test_vec_contains_accepts_int() {
    let v: Vec<int> = Vec::new();
    v.push(10);
    v.push(20);
    testing.assert_eq(vec.contains(v, 10), true);
    testing.assert_eq(vec.contains(v, 99), false);
}

#[test]
fn test_vec_min_max_return_int() {
    let v: Vec<int> = Vec::new();
    v.push(3);
    v.push(1);
    v.push(2);
    let lo: int = vec.min(v);
    let hi: int = vec.max(v);
    testing.assert_eq(lo, 1);
    testing.assert_eq(hi, 3);
}

#[test]
fn test_semver_major_minor_patch_return_int() {
    let v = semver.parse("2.5.11");
    let maj: int = v.major();
    let min: int = v.minor();
    let pat: int = v.patch();
    testing.assert_eq(maj, 2);
    testing.assert_eq(min, 5);
    testing.assert_eq(pat, 11);
}

#[test]
fn test_semaphore_new_accepts_int() {
    let sem = semaphore.new(3);
    let n: int = sem.count();
    testing.assert_eq(n, 3);
    sem.free();
}
