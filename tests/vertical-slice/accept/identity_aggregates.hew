record Ping {
    value: i64,
}

actor Worker {
    receive fn ping(msg: Ping) {}
}

impl ActorMsg for Worker {
    type Msg = Ping;
    type Reply = ();
}

fn main() -> i64 {
    Node::set_transport("tcp");
    Node::load_keys("/tmp/hew-cap13-identity-aggregates.key");
    Node::start("127.0.0.1:0");

    let node_id = match Node::id() {
        Some(id) => id,
        None => return 1,
    };
    let worker = spawn Worker();
    Node::register("identity-worker", worker);
    let pid = match Node::lookup<Worker>("identity-worker") {
        Ok(found) => found,
        Err(_) => return 2,
    };
    let location = pid.location();

    if pid.node_id() != node_id { return 3; }
    if location.node_id() != node_id { return 4; }
    if pid.slot() != location.slot() { return 5; }
    if pid.incarnation() != location.incarnation() { return 6; }
    if pid != pid || location != location || node_id != node_id { return 7; }

    let nodes: HashMap<NodeId, i64> = HashMap::new();
    nodes.insert(node_id, 11);
    if nodes.get(node_id).unwrap_or(0) != 11 { return 8; }

    let locations: HashMap<Location, i64> = HashMap::new();
    locations.insert(location, 12);
    if locations.get(location).unwrap_or(0) != 12 { return 9; }

    let pids: HashMap<RemotePid<Worker>, i64> = HashMap::new();
    pids.insert(pid, 13);
    if pids.get(pid).unwrap_or(0) != 13 { return 10; }

    let node_text = to_string(node_id);
    let location_text = to_string(location);
    let pid_text = f"{pid}";
    if node_text.len() != 32 { return 11; }
    if location_text != pid_text { return 12; }

    Node::shutdown();
    0
}
