// Test: multiple on(stop) hooks run in lexical declaration order
// Exercises: #[on(stop)] hooks concatenated in source order (spec §9.1.2 rule 6)
actor Logger {
    let id: int;

    #[on(stop)]
    fn flush() {
        println(f"logger {id} flush");
    }

    #[on(stop)]
    fn close() {
        println(f"logger {id} close");
    }

    receive fn log(msg: string) {
        println(f"[{id}] {msg}");
    }
}

fn main() {
    println("=== Multi On Stop ===");
    let l = spawn Logger(id: 42);
    await l.log("entry");
    stop(l);
    sleep_ms(100);
    println("=== End ===");
}
