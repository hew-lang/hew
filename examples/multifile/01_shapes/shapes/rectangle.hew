// rectangle.hew — peer file inside the `shapes` directory module.
//
// Same pattern as circle.hew: type + impl + factory, all merged into the
// single `shapes` namespace at import time.
pub type Rectangle {
    width: i64;
    height: i64;
}

pub fn make_rectangle(width: i64, height: i64) -> Rectangle {
    Rectangle { width: width, height: height }
}

impl Drawable for Rectangle {
    fn draw(r: Rectangle) -> string {
        f"Rectangle({r.width}x{r.height})"
    }
}
