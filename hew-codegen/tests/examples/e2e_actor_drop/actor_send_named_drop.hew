// Test: Named string value sent to an actor is properly handled. The runtime
// deep-copies string args via strdup(), so the sender keeps the original.
// Before this fix, unregisterDroppable suppressed the sender's string drop,
// leaking the original string allocation.
//
// This test verifies no crash or double-free from the retained sender drop.

fn make_greeting(name: string) -> string {
    return f"hello {name}";
}

actor Echo {
    receive fn say(msg: string) {
        println(f"echo: {msg}");
    }

    receive fn ping() -> int {
        0
    }
}

fn main() {
    let e = spawn Echo;
    let greeting = make_greeting("world");
    e.say(greeting);
    await e.ping();
}
