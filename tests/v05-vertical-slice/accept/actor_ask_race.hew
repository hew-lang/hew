// Acceptance fixture for select{} with actor-ask arms and an after-timeout.
//
// Design intent:
//   - FastWorker.compute() returns immediately (no sleep); always wins.
//   - SlowWorker.compute() sleeps 50 ms before returning; always loses.
//   - after 100ms: safety-net timeout arm, should never fire under normal CI load.
//
// Timing assumption: select{} calls hew_select_first which waits for the first
// reply. FastWorker is dispatched first and replies with no blocking, so it wins
// before SlowWorker wakes. CI machines may be slow, but 100 ms >> 50 ms with
// zero-delay fast path, so the fast arm reliably wins.
//
// Exit-code contract: main returns the winning value (42). POSIX exit is 8-bit,
// so the value must be in 0..=255. 42 is the canonical fixture value.
//
// Cancel-loser proof: the compiler lowers the loser path through
// hew_reply_channel_cancel + hew_reply_channel_free (see Terminator::Select
// codegen in hew-codegen-rs/src/llvm.rs). This fixture exercises that path
// every run: SlowWorker is always the loser and its channel is cancelled.
actor FastWorker {
    receive fn compute(query: int) -> int {

        // No sleep — reply immediately. This arm always wins the select{}.
        query
    }
}

actor SlowWorker {
    receive fn compute(query: int) -> int {

        // Park this thread for 50 ms so FastWorker replies first.
        sleep_ms(50);
        query
    }
}

fn main() -> int {
    let fast = spawn FastWorker;
    let slow = spawn SlowWorker;
    // Ask both workers the same query. Select picks the first reply.
    // The after 100ms arm fires only if both workers fail to reply within
    // the deadline — should not happen in normal execution.
    let winner = select {
        reply from fast.compute(42) => reply,
        reply from slow.compute(99) => reply,
        after 100ms => 0,
    };
    // Return the winning value as the process exit code.
    // FastWorker wins and returns 42; exit code == 42.
    winner
}
