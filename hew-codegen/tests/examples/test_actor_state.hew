actor Accumulator {
    let total: int;
    let count: int;

    receive fn add(x: int) {
        total = total + x;
        count = count + 1;
    }

    receive fn print_result() -> int {
        println(total);
        println(count);
        total
    }
}

fn main() {
    let acc = spawn Accumulator(total: 0, count: 0);
    acc.add(10);
    acc.add(20);
    acc.add(30);
    await acc.print_result();
}
