// Negative test: to_string of an unsafe block whose value position is a match
// expression that yields an owned Display value is rejected at codegen.
// The unsafe block wrapper smuggles a multi-branch match past the direct
// ExprMatch check; after Display::fmt consumes the selected arm's value, that
// binding's caller-side drop registration would fire at scope exit -> double-free.
// Supported workaround: bind the match result to a local variable first.
type Greeting {
    text: String;
}

impl Display for Greeting {
    fn fmt(val: Greeting) -> String {
        val.text
    }
}

fn main() {
    let x = 1;
    let g = Greeting { text: "hello" };
    let h = Greeting { text: "world" };
    let s = to_string(unsafe { match x {
        1 => g,
        _ => h,
    }});
    println(s);
}
